<%- contentFor('HeaderCss') %>
<% if ((typeof direction !== 'undefined' && direction === 'rtl') || (typeof currentLang !== 'undefined' && currentLang === 'ar')) { %>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet">
<% } %>
<link rel="stylesheet" href="/assets/rCSS/create-edit-order.css">
<link rel="stylesheet" href="/assets/css/area-selection-modal.css">
<link href="/assets/libs/sweetalert2/sweetalert2.min.css" rel="stylesheet" type="text/css" />

<%- contentFor('body') %>
<% 
  var Co = (typeof translation !== 'undefined' && translation.business && translation.business.pages && translation.business.pages.createOrder) ? translation.business.pages.createOrder : {};
  var Cj = (typeof translation !== 'undefined' && translation.business && translation.business.js && translation.business.js.createOrder) ? translation.business.js.createOrder : {};
  var Sh = (typeof translation !== 'undefined' && translation.business && translation.business.shell) ? translation.business.shell : {};
  var Bc = (typeof translation !== 'undefined' && translation.business && translation.business.breadcrumb) ? translation.business.breadcrumb : {};
  var _coRtl = (typeof isRTL !== 'undefined' && isRTL) || (typeof currentLang !== 'undefined' && currentLang === 'ar');
  var _coStepBadge = (Cj.stepOf || 'Step {cur} of {max}').replace('{cur}','1').replace('{max}','4');
  var _coUser = (typeof user !== 'undefined' && user) ? user : ((typeof userData !== 'undefined' && userData) ? userData : {});
  var _coPickupAddrs = (Array.isArray(_coUser.pickUpAddresses) && _coUser.pickUpAddresses.length) ? _coUser.pickUpAddresses : [];
%>
<!-- ═══════════════════════════════════════════════════════════════════
     Create Order – Redesigned Wizard
     ═══════════════════════════════════════════════════════════════════ -->

<div class="co-page<% if (_coRtl) { %> co-page--rtl<% } %>" lang="<%= typeof currentLang !== 'undefined' ? currentLang : 'en' %>" dir="<%= _coRtl ? 'rtl' : 'ltr' %>">

  <!-- Breadcrumb -->
  <div class="co-breadcrumb">
    <a href="/business/dashboard"><i class="ri-home-3-line"></i> <%= Sh.dashboard || 'Dashboard' %></a>
    <span class="co-breadcrumb__sep"><i class="ri-arrow-right-s-line"></i></span>
    <a href="/business/orders"><%= Bc.orders || 'Orders' %></a>
    <span class="co-breadcrumb__sep"><i class="ri-arrow-right-s-line"></i></span>
    <span class="co-breadcrumb__current"><%= Co.title || 'Create Order' %></span>
  </div>

  <div class="co-layout">

    <!-- ── Main Form Card ────────────────────────────────────────────── -->
    <div class="co-form-col">
      <div class="co-card">

        <!-- Card Header with Step Indicator -->
        <div class="co-card__header">
          <div class="co-card__title-row">
            <div>
              <h1 class="co-card__title" id="co-step-title"><%= Cj.wizStep1Title || Co.stepShipping %></h1>
              <p class="co-card__subtitle" id="co-step-subtitle"><%= Cj.wizStep1Sub || Co.shippingInfoSubtitle %></p>
            </div>
            <span class="co-step-badge" id="co-step-badge"><%= _coStepBadge %></span>
          </div>

          <!-- Step Indicator -->
          <div class="co-step-indicator">
            <!-- progress line -->
            <div class="co-step-indicator__line-wrap">
              <div class="co-step-indicator__track-bg"></div>
              <div class="co-step-indicator__track-fill" id="co-progress-fill"></div>
            </div>
            <!-- step 1 -->
            <div class="co-step-node-wrap">
              <div class="co-step-node co-step-node--active" id="co-node-1">
                <i class="ri-truck-line"></i>
              </div>
              <span class="co-step-label co-step-label--active" id="co-label-1"><%= Co.stepShipping %></span>
            </div>
            <!-- step 2 -->
            <div class="co-step-node-wrap">
              <div class="co-step-node" id="co-node-2">
                <i class="ri-user-3-line"></i>
              </div>
              <span class="co-step-label" id="co-label-2"><%= Co.stepCustomer %></span>
            </div>
            <!-- step 3 -->
            <div class="co-step-node-wrap">
              <div class="co-step-node" id="co-node-3">
                <i class="ri-settings-4-line"></i>
              </div>
              <span class="co-step-label" id="co-label-3"><%= Co.stepAdditional %></span>
            </div>
            <!-- step 4 -->
            <div class="co-step-node-wrap">
              <div class="co-step-node" id="co-node-4">
                <i class="ri-check-double-line"></i>
              </div>
              <span class="co-step-label" id="co-label-4"><%= Co.stepComplete %></span>
            </div>
          </div>
        </div><!-- /.co-card__header -->

        <!-- Form body with step panels -->
        <form id="createOrderForm" novalidate>
          <div class="co-card__body">

            <!-- ═══ STEP 1: SHIPPING DETAILS ═══════════════════════════ -->
            <div class="step-panel step-panel--active" id="co-step-1">

              <p class="co-section-label"><%= Co.selectOrderTypeHeading %></p>

              <div class="co-type-grid">
                <!-- Deliver -->
                <button type="button" class="co-type-card" id="co-type-deliver"
                        onclick="coSelectOrderType('Deliver', this)">
                  <div class="co-type-card__check"><i class="ri-check-line"></i></div>
                  <div class="co-type-card__icon-wrap"><i class="ri-truck-line"></i></div>
                  <p class="co-type-card__name"><%= Co.typeDelivery %></p>
                  <p class="co-type-card__desc"><%= Co.typeDescDelivery %></p>
                </button>
                <!-- Exchange -->
                <button type="button" class="co-type-card" id="co-type-exchange"
                        onclick="coSelectOrderType('Exchange', this)">
                  <div class="co-type-card__check"><i class="ri-check-line"></i></div>
                  <div class="co-type-card__icon-wrap"><i class="ri-refresh-line"></i></div>
                  <p class="co-type-card__name"><%= Co.typeExchange %></p>
                  <p class="co-type-card__desc"><%= Co.typeDescExchange %></p>
                </button>
                <!-- Return -->
                <button type="button" class="co-type-card" id="co-type-return"
                        onclick="coSelectOrderType('Return', this)">
                  <div class="co-type-card__check"><i class="ri-check-line"></i></div>
                  <div class="co-type-card__icon-wrap"><i class="ri-arrow-go-back-line"></i></div>
                  <p class="co-type-card__name"><%= Co.typeReturn %></p>
                  <p class="co-type-card__desc"><%= Co.typeDescReturn %></p>
                </button>
              </div>

              <!-- Hidden orderType value -->
              <input type="hidden" name="orderType" id="orderTypeInput" value="">

              <!-- Delivery Details section (shown after type selected) -->
              <div class="co-collapsible" id="co-delivery-details">

                <!-- DELIVER section -->
                <div class="co-type-section" id="co-section-deliver">
                  <div class="co-divider">
                    <div class="co-divider__line"></div>
                    <span class="co-divider__text"><%= Co.deliveryDetailsLabel %></span>
                    <div class="co-divider__line"></div>
                  </div>

                  <div class="co-field">
                    <label class="co-field__label" for="productDescription">
                      <%= Co.productDescLabel %> <span class="co-required">*</span>
                    </label>
                    <textarea class="co-textarea" id="productDescription" name="productDescription"
                              rows="3" placeholder="<%= Co.phDescribeProducts %>"></textarea>
                    <div class="co-field-error" id="err-productDescription"><%= Co.errProductDescription %></div>
                  </div>

                  <div class="co-field">
                    <label class="co-field__label"><%= Co.itemsCount %></label>
                    <div class="co-counter">
                      <button type="button" class="co-counter__btn" id="co-decrement">
                        <i class="ri-subtract-line"></i>
                  </button>
                      <div class="co-counter__display" id="co-num-display">1</div>
                      <button type="button" class="co-counter__btn co-counter__btn--plus" id="co-increment">
                        <i class="ri-add-line"></i>
                  </button>
                      <span class="co-counter__label" id="co-num-label"><%= Cj.itemSingular || 'item' %></span>
                </div>
                    <input type="hidden" name="numberOfItems" id="numberOfItems" value="1">
                  </div>

                  <!-- Express + COD toggles -->
                  <p class="co-section-label" style="margin-top:1.25rem;"><%= Co.shippingOptionsHeading %></p>
                  <div class="co-toggle-grid">
                    <!-- Express Shipping -->
                    <button type="button" class="co-toggle-card" id="co-express-toggle"
                            onclick="coToggleCard(this, 'isExpressShipping', 'co-express-toggle')">
                      <div class="co-toggle-card__icon"><i class="ri-flashlight-line"></i></div>
                      <div class="co-toggle-card__content">
                        <p class="co-toggle-card__title"><%= Co.expressShippingLabel %></p>
                        <p class="co-toggle-card__sub"><%= Co.expressShippingSub %></p>
                      </div>
                      <div class="co-toggle-card__check"><i class="ri-check-line"></i></div>
                  </button>

                    <!-- Cash on Delivery -->
                    <button type="button" class="co-toggle-card" id="co-cod-toggle"
                            onclick="coToggleCOD()">
                      <div class="co-toggle-card__icon"><i class="ri-money-dollar-circle-line"></i></div>
                      <div class="co-toggle-card__content">
                        <p class="co-toggle-card__title"><%= Co.codLabel %></p>
                        <p class="co-toggle-card__sub"><%= Co.codSub %></p>
                </div>
                      <div class="co-toggle-card__check"><i class="ri-check-line"></i></div>
                  </button>
                </div>
                  <input type="hidden" name="COD" id="COD-input" value="">
                  <input type="hidden" name="isExpressShipping" id="isExpressShipping-input" value="">

                  <!-- COD Amount (collapsible) -->
                  <div class="co-collapsible" id="co-cod-amount-wrap">
                    <div class="co-field" style="margin-top:0.75rem;">
                      <label class="co-field__label" for="amountCOD">
                        <%= Co.amountCollectLabel %> <span class="co-required">*</span>
                      </label>
                      <div class="co-input-suffix">
                        <input type="number" class="co-input" id="amountCOD" name="amountCOD"
                               placeholder="0.00" min="0" step="0.01" dir="ltr">
                        <span class="co-input-suffix__text"><%= Co.currencyCode != null ? Co.currencyCode : 'EGP' %></span>
          </div>
                    </div>
                  </div>
                </div><!-- /#co-section-deliver -->

                <!-- EXCHANGE section -->
                <div class="co-type-section" id="co-section-exchange">
                  <div class="co-divider">
                    <div class="co-divider__line"></div>
                    <span class="co-divider__text"><%= Co.exchangeDetailsLabel %></span>
                    <div class="co-divider__line"></div>
              </div>

                  <div class="co-field-row">
                    <div class="co-field">
                      <label class="co-field__label" for="currentPD">
                        <%= Co.currentProductShort %> <span class="co-required">*</span>
                      </label>
                      <input type="text" class="co-input" id="currentPD" name="currentPD"
                             placeholder="<%= Co.phExchangeCurrent %>">
                </div>
                    <div class="co-field">
                      <label class="co-field__label" for="numberOfItemsCurrentPD">
                        <%= Co.itemsToCollect %> <span class="co-required">*</span>
                        </label>
                      <div class="co-counter">
                        <button type="button" class="co-counter__btn" id="co-ex-cur-decrement"
                                onclick="coAdjustCounter('numberOfItemsCurrentPD','co-ex-cur-display', -1)">
                          <i class="ri-subtract-line"></i>
                        </button>
                        <div class="co-counter__display" id="co-ex-cur-display">1</div>
                        <button type="button" class="co-counter__btn co-counter__btn--plus" id="co-ex-cur-increment"
                                onclick="coAdjustCounter('numberOfItemsCurrentPD','co-ex-cur-display', 1)">
                          <i class="ri-add-line"></i>
                        </button>
                      </div>
                      <input type="hidden" name="numberOfItemsCurrentPD" id="numberOfItemsCurrentPD" value="1">
                    </div>
                  </div>

                  <div class="co-field-row" style="margin-top:0.5rem;">
                    <div class="co-field">
                      <label class="co-field__label" for="newPD">
                        <%= Co.newProductShort %> <span class="co-required">*</span>
                        </label>
                      <input type="text" class="co-input" id="newPD" name="newPD"
                             placeholder="<%= Co.phExchangeNew %>">
                      </div>
                    <div class="co-field">
                      <label class="co-field__label" for="numberOfItemsNewPD">
                        <%= Co.itemsToDeliver %> <span class="co-required">*</span>
                        </label>
                      <div class="co-counter">
                        <button type="button" class="co-counter__btn" id="co-ex-new-decrement"
                                onclick="coAdjustCounter('numberOfItemsNewPD','co-ex-new-display', -1)">
                          <i class="ri-subtract-line"></i>
                        </button>
                        <div class="co-counter__display" id="co-ex-new-display">1</div>
                        <button type="button" class="co-counter__btn co-counter__btn--plus" id="co-ex-new-increment"
                                onclick="coAdjustCounter('numberOfItemsNewPD','co-ex-new-display', 1)">
                          <i class="ri-add-line"></i>
                        </button>
                      </div>
                      <input type="hidden" name="numberOfItemsNewPD" id="numberOfItemsNewPD" value="1">
                    </div>
                  </div>

                  <p class="co-section-label" style="margin-top:1.25rem;"><%= Co.shippingOptionsHeading %></p>
                  <div class="co-toggle-grid co-toggle-grid--single">
                    <!-- Cash Difference (express is Deliver-only) -->
                    <button type="button" class="co-toggle-card" id="co-cd-toggle"
                            onclick="coToggleCD()">
                      <div class="co-toggle-card__icon"><i class="ri-exchange-dollar-line"></i></div>
                      <div class="co-toggle-card__content">
                        <p class="co-toggle-card__title"><%= Co.collectCashDiffTitle %></p>
                        <p class="co-toggle-card__sub"><%= Co.collectCashDiffSub %></p>
              </div>
                      <div class="co-toggle-card__check"><i class="ri-check-line"></i></div>
                    </button>
                  </div>
                  <input type="hidden" name="CashDifference" id="CashDifference-input" value="">

                  <div class="co-collapsible" id="co-cd-amount-wrap">
                    <div class="co-field" style="margin-top:0.75rem;">
                      <label class="co-field__label" for="amountCashDifference">
                        <%= Co.phCashDiffAmount %> <span class="co-required">*</span>
                      </label>
                      <div class="co-input-suffix">
                        <input type="number" class="co-input" id="amountCashDifference" name="amountCashDifference"
                               placeholder="0.00" min="0" step="0.01" dir="ltr">
                        <span class="co-input-suffix__text"><%= Co.currencyCode %></span>
                </div>
                  </div>
                    </div>
                </div><!-- /#co-section-exchange -->

                <!-- RETURN section -->
                <div class="co-type-section" id="co-section-return">
                  <div class="co-divider">
                    <div class="co-divider__line"></div>
                    <span class="co-divider__text"><%= Co.returnDetailsLabel %></span>
                    <div class="co-divider__line"></div>
                  </div>

                  <p class="co-field-hint co-field-hint--muted co-field-hint--show" id="co-return-info-line" style="margin-bottom:0.75rem;">
                    <%= Co.returnInfoText || '' %>
                  </p>

                  <div class="co-field">
                    <label class="co-field__label" for="returnProductDescription">
                      <%= Co.returnDescLabel %> <span class="co-required">*</span>
                    </label>
                    <textarea class="co-textarea" id="returnProductDescription" rows="2"
                              placeholder="<%= Co.returnDescPlaceholder %>"></textarea>
                    <div class="co-field-error" id="err-returnProductDescription"><%= Co.errReturnProductDesc %></div>
                  </div>
                  
                  <div class="co-field">
                    <label class="co-field__label" for="originalOrderNumber">
                      <%= Co.originalOrderLabel %> <span class="co-required">*</span>
                      </label>
                    <div class="co-input-icon-wrap">
                      <i class="co-input-icon ri-hashtag"></i>
                      <input type="text" class="co-input" id="originalOrderNumber" name="originalOrderNumber"
                             placeholder="<%= Co.phOriginalOrder %>" autocomplete="off">
                    </div>
                    <div class="co-field-hint" id="co-original-order-ok" aria-live="polite"></div>
                    <div class="co-field-error" id="err-originalOrderNumber"><%= Co.errOriginalOrder %></div>
                    </div>
                  <input type="hidden" name="originalOrderItemCount" id="originalOrderItemCount" value="">

                  <div class="co-field">
                    <label class="co-field__label" for="returnReason">
                      <%= Co.returnReasonLabel %> <span class="co-required">*</span>
                    </label>
                    <input type="text" class="co-input" id="returnReason" name="returnReason"
                           placeholder="<%= Co.phReturnReason %>">
                    <div class="co-field-error" id="err-returnReason"><%= Co.errReturnReason %></div>
                  </div>

                  <div class="co-field">
                    <label class="co-field__label" for="returnNotes">
                      <%= Co.returnNotesOpt %> <span class="co-optional"><%= Co.optionalTag %></span>
                      </label>
                    <textarea class="co-textarea" id="returnNotes" name="returnNotes"
                              rows="2" placeholder="<%= Co.phReturnNotes %>"></textarea>
                  </div>
                  
                  <!-- Partial Return (only when original order has multiple items) -->
                  <div id="co-partial-return-block" class="co-partial-return-block" style="display:none;">
                  <div class="co-toggle-grid" style="margin-top:0.5rem;grid-template-columns:1fr;">
                    <button type="button" class="co-toggle-card" id="co-partial-return-toggle"
                            onclick="coTogglePartialReturn()">
                      <div class="co-toggle-card__icon"><i class="ri-git-branch-line"></i></div>
                      <div class="co-toggle-card__content">
                        <p class="co-toggle-card__title"><%= Co.partialReturnTitle %></p>
                        <p class="co-toggle-card__sub"><%= Co.partialReturnSub %></p>
                    </div>
                      <div class="co-toggle-card__check"><i class="ri-check-line"></i></div>
                    </button>
                    </div>
                  <input type="hidden" name="isPartialReturn" id="isPartialReturn-input" value="">

                  <div class="co-collapsible" id="co-partial-return-wrap">
                    <div class="co-field" style="margin-top:0.75rem;">
                      <label class="co-field__label" for="partialReturnItemCount">
                        <%= Co.itemsToReturn %> <span class="co-required">*</span>
                      </label>
                      <div class="co-counter">
                        <button type="button" class="co-counter__btn"
                                onclick="coAdjustCounter('partialReturnItemCount','co-pr-display', -1)">
                          <i class="ri-subtract-line"></i>
                        </button>
                        <div class="co-counter__display" id="co-pr-display">1</div>
                        <button type="button" class="co-counter__btn co-counter__btn--plus"
                                onclick="coAdjustCounter('partialReturnItemCount','co-pr-display', 1)">
                          <i class="ri-add-line"></i>
                        </button>
                  </div>
                      <input type="hidden" name="partialReturnItemCount" id="partialReturnItemCount" value="1">
                </div>
              </div>
                  </div><!-- /#co-partial-return-block -->
                </div><!-- /#co-section-return -->

                <!-- Business pickup / return-to-business (Deliver, Exchange, Return) -->
                <div class="co-collapsible" id="co-business-pickup-wrap" style="display:none;">
                  <div class="co-field" style="margin-top:1rem;">
                    <label class="co-field__label" for="selectedPickupAddressId">
                      <span id="co-business-pickup-label-text"><%= Co.businessPickupLabel || Co.selectPickupLabel || 'Business pickup address' %></span><span id="co-business-pickup-required" class="co-required" style="display:none;">*</span>
                    </label>
                    <% if (_coPickupAddrs.length) { %>
                    <select class="co-input" id="selectedPickupAddressId" name="selectedPickupAddressId" dir="auto">
                      <option value=""><%= Co.selectPickupPlaceholder || 'Select pickup address...' %></option>
                      <% _coPickupAddrs.forEach(function (a) {
                        var aid = a.addressId || '';
                      %>
                      <option value="<%= aid %>"<% if (a.isDefault) { %> data-co-default="1"<% } %>><%=
                        (a.addressName || 'Address') + (a.city ? ' — ' + a.city : '')
                      %></option>
                      <% }); %>
                    </select>
                    <div class="co-field-error" id="err-selectedPickup"><%= Co.errBusinessPickup || Co.errSelectPickup || Cj.errSelectPickup || 'Please select a business pickup address.' %></div>
                    <% } else { %>
                    <p class="co-field-hint co-field-hint--show co-field-hint--muted" id="co-business-pickup-missing">
                      <%= Co.businessPickupNoAddress || Co.expressNoPickupAddress || 'Add a business pickup address in Settings.' %>
                    </p>
                    <% } %>
                  </div>
                </div>

              </div><!-- /#co-delivery-details -->
            </div><!-- /#co-step-1 -->

            <!-- ═══ STEP 2: CUSTOMER DETAILS ═══════════════════════════ -->
            <div class="step-panel" id="co-step-2">

              <!-- Contact Information -->
              <div class="co-group-heading">
                <div class="co-group-heading__icon"><i class="ri-user-3-line"></i></div>
                <h3 class="co-group-heading__title"><%= Co.contactInfoHeading %></h3>
                </div>

              <div class="co-field-row">
                <div class="co-field">
                  <label class="co-field__label" for="fullName">
                    <%= Co.fullName %> <span class="co-required">*</span>
                  </label>
                  <div class="co-input-icon-wrap">
                    <i class="co-input-icon ri-user-line"></i>
                    <input type="text" class="co-input" id="fullName" name="fullName"
                           placeholder="<%= Co.phEnterFullName %>" dir="auto">
                  </div>
                  <div class="co-field-error" id="err-fullName"><%= Co.errFullName %></div>
                    </div>
                <div class="co-field">
                  <label class="co-field__label" for="phoneNumber">
                    <%= Co.phone %> <span class="co-required">*</span>
                  </label>
                  <div class="co-input-icon-wrap">
                    <i class="co-input-icon ri-phone-line"></i>
                    <input type="tel" class="co-input" id="phoneNumber" name="phoneNumber"
                           placeholder="+20 10X XXX XXXX" dir="ltr">
                  </div>
                  <div class="co-field-error" id="err-phoneNumber"><%= Co.errPhone %></div>
                  </div>
                    </div>

              <div class="co-field">
                <label class="co-field__label" for="otherPhoneNumber">
                  <%= Co.altPhone %> <span class="co-optional"><%= Co.optionalTag %></span>
                      </label>
                <div class="co-input-icon-wrap">
                  <i class="co-input-icon ri-phone-line"></i>
                  <input type="tel" class="co-input" id="otherPhoneNumber" name="otherPhoneNumber"
                         placeholder="<%= Co.phOptionalPhone %>" dir="ltr">
                    </div>
                  </div>
                  
              <!-- Delivery Location -->
              <div class="co-group-heading" style="margin-top:1.5rem;">
                <div class="co-group-heading__icon"><i class="ri-map-pin-line"></i></div>
                <h3 class="co-group-heading__title"><%= Co.deliveryLocationHeading %></h3>
                    </div>

              <div class="co-field">
                <label class="co-field__label">
                  <%= Co.governorateAreaLabel %> <span class="co-required">*</span>
                </label>
                <button type="button" class="co-area-btn" id="selectAreaBtn">
                  <i class="ri-map-pin-2-line"></i>
                  <span class="co-area-btn__label" id="selectedAreaDisplay"><%= Co.selectAreaPlaceholder %></span>
                  <i class="co-area-btn__chevron ri-arrow-right-s-line"></i>
                </button>
                <input type="hidden" id="government-value" name="government" value="">
                <input type="hidden" id="zone-value" name="zone" value="">
                <div class="co-field-error" id="err-zone"><%= Co.errSelectArea %></div>
              </div>

              <div class="co-field">
                <label class="co-field__label" for="address">
                  <%= Co.streetAddress %> <span class="co-required">*</span>
                </label>
                <textarea class="co-textarea" id="address" name="address"
                          rows="3" placeholder="<%= Co.phStreet %>" dir="auto"></textarea>
                <div class="co-field-error" id="err-address"><%= Co.errAddress %></div>
                  </div>
                  
              <button type="button" class="co-check-card" id="co-work-addr-toggle"
                      onclick="coToggleWorkAddress()">
                <div class="co-check-card__box"><i class="ri-check-line"></i></div>
                <span class="co-check-card__text">
                  <i class="ri-building-2-line"></i> <%= Co.deliverToWork %>
                </span>
              </button>
              <input type="hidden" name="deliverToWorkAddress" id="deliverToWorkAddress-input" value="">

            </div><!-- /#co-step-2 -->

            <!-- ═══ STEP 3: ADDITIONAL OPTIONS ══════════════════════════ -->
            <div class="step-panel" id="co-step-3">

              <div class="co-toggle-grid">
                <!-- Can open package -->
                <button type="button" class="co-toggle-card" id="co-open-pkg-toggle"
                        onclick="coToggleCard(this, 'previewPermission', 'co-open-pkg-toggle')">
                  <div class="co-toggle-card__icon"><i class="ri-box-3-line"></i></div>
                  <div class="co-toggle-card__content">
                    <p class="co-toggle-card__title"><%= Co.customerOpenTitle %></p>
                    <p class="co-toggle-card__sub"><%= Co.allowPackageInspection %></p>
                    </div>
                  <div class="co-toggle-card__check"><i class="ri-check-line"></i></div>
                </button>

                <!-- Referral code -->
                <div class="co-field">
                  <label class="co-field__label" for="referralNumber">
                    <i class="ri-price-tag-3-line" style="color:var(--co-orange);font-size:0.85rem;"></i>
                    <%= Co.referralCodeLabel %> <span class="co-optional"><%= Co.optionalTag %></span>
                  </label>
                  <input type="text" class="co-input" id="referralNumber" name="referralNumber"
                         placeholder="<%= Co.phReferral %>" style="height:3.5rem;" dir="auto">
                    </div>
                      </div>
                      
              <input type="hidden" name="previewPermission" id="previewPermission-input" value="">

              <div class="co-field" style="margin-top:0.25rem;">
                <label class="co-field__label" for="Notes">
                  <i class="ri-file-text-line" style="color:var(--co-orange);font-size:0.85rem;"></i>
                  <%= Co.specialInstructions %> <span class="co-optional"><%= Co.optionalTag %></span>
                          </label>
                <textarea class="co-textarea" id="Notes" name="Notes"
                          rows="4" placeholder="<%= Co.phNotesCourier %>" dir="auto"></textarea>
                      </div>

              <!-- Fee Summary Card -->
              <div class="co-fee-card">
                <div class="co-fee-card__header">
                  <div class="co-fee-card__header-icon"><i class="ri-wallet-3-line"></i></div>
                  <div>
                    <p class="co-fee-card__header-title"><%= Co.feeSummaryTitle %></p>
                    <p class="co-fee-card__header-sub"><%= Co.feeSubBasedArea %></p>
                            </div>
                          </div>
                <div class="co-fee-card__body">
                  <div class="co-fee-row">
                    <span class="co-fee-row__label"><%= Co.feeBase %></span>
                    <span class="co-fee-row__value" id="co-fee-base-val">—</span>
                          </div>
                  <div class="co-fee-row" id="co-fee-express-row" style="display:none;">
                    <span class="co-fee-row__label"><%= Co.expressAddonLine %></span>
                    <span class="co-fee-row__value co-fee-row__value--orange" id="co-fee-express-val">+— EGP</span>
                        </div>
                  <div class="co-fee-total">
                    <div>
                      <p class="co-fee-total__label"><%= Co.grandFeeLabel %></p>
                      <p class="co-fee-total__sub"><%= Co.noHiddenCharges %></p>
                      </div>
                    <div class="co-fee-total__amount-col">
                      <div class="co-fee-total__amount" id="co-fee-total-val">
                        <span id="co-fee-total-num">0</span>
                        <span><%= Co.currencyCode %></span>
                    </div>
                  </div>
                  </div>
                </div>
              </div>

            </div><!-- /#co-step-3 -->

            <!-- ═══ STEP 4: COMPLETE ═════════════════════════════════════ -->
            <div class="step-panel" id="co-step-4">
              <div class="co-success-wrap">
                <div class="co-success-icon-wrap">
                  <div class="co-success-icon">
                    <i class="ri-check-line"></i>
                  </div>
                  <div class="co-success-badge">
                    <i class="ri-sparkling-line"></i>
              </div>
            </div>

                <h2 class="co-success-title"><%= Co.orderPlacedTitle %></h2>
                <p class="co-success-sub"><%= Co.orderPlacedSub %></p>
                <div class="co-success-order-num">
                  <i class="ri-box-3-line"></i>
                  <span id="co-success-order-num">—</span>
              </div>

                <div class="co-success-grid">
              <div>
                    <p class="co-success-detail__label"><%= Co.successLabelOrderType %></p>
                    <p class="co-success-detail__value" id="co-result-type">—</p>
                    </div>
                  <div>
                    <p class="co-success-detail__label"><%= Co.successLabelCustomer %></p>
                    <p class="co-success-detail__value" id="co-result-customer">—</p>
                  </div>
                  <div>
                    <p class="co-success-detail__label"><%= Co.successLabelPhone %></p>
                    <p class="co-success-detail__value" id="co-result-phone">—</p>
                    </div>
                  <div>
                    <p class="co-success-detail__label"><%= Co.successLabelArea %></p>
                    <p class="co-success-detail__value" id="co-result-area">—</p>
                  </div>
                  <div>
                    <p class="co-success-detail__label"><%= Co.successLabelTotalFee %></p>
                    <p class="co-success-detail__value co-success-detail__value--orange" id="co-result-fee">— <%= Co.currencyCode %></p>
                </div>
                  </div>

                <div style="display:flex;gap:0.75rem;flex-wrap:wrap;justify-content:center;">
                  <button type="button" class="co-btn-new-order" id="co-btn-new-order">
                    <i class="ri-add-line"></i> <%= Co.createNewOrder %>
                    </button>
                  <a href="/business/orders" class="co-btn-new-order"
                     style="background:linear-gradient(135deg,#374151,#1F2937); box-shadow:0 4px 14px rgba(0,0,0,0.2); text-decoration:none;">
                    <i class="ri-list-unordered"></i> <%= Co.viewOrdersList %>
                  </a>
                  </div>
                </div>
            </div><!-- /#co-step-4 -->

          </div><!-- /.co-card__body -->
        </form>

        <!-- Navigation Footer -->
        <div class="co-card__footer" id="co-nav-footer">
          <button type="button" class="co-btn-back" id="co-btn-back" disabled>
            <i class="ri-arrow-left-s-line co-btn-back__chev"></i> <%= Cj.labelBack || 'Back' %>
                  </button>
          <button type="button" class="co-btn-next" id="co-btn-next">
            <%= Cj.labelContinue || 'Continue' %> <i class="ri-arrow-right-s-line co-btn-next__chev"></i>
                  </button>
            </div>

      </div><!-- /.co-card -->
    </div><!-- /.co-form-col -->

    <!-- ── Order Summary Sidebar ──────────────────────────────────────── -->
    <div class="co-sidebar-col">
      <div class="co-summary">

        <!-- Header -->
        <div class="co-summary__header">
          <div class="co-summary__header-blob-1"></div>
          <div class="co-summary__header-blob-2"></div>
          <div class="co-summary__eyebrow">
            <i class="ri-sparkling-line"></i> <%= Co.orderSummaryTitle %>
                  </div>
          <p class="co-summary__hint"><%= Co.orderSummaryHint %></p>
              </div>

        <!-- Summary body -->
        <div class="co-summary__body">
          <div class="co-sum-row">
            <div class="co-sum-row__icon"><i class="ri-box-3-line"></i></div>
                    <div>
              <p class="co-sum-row__label"><%= Co.orderTypeLabel %></p>
              <p class="co-sum-row__value co-sum-row__value--empty" id="sum-type">—</p>
                    </div>
                  </div>
          <div class="co-sum-row" id="sum-product-row" style="display:none;">
            <div class="co-sum-row__icon"><i class="ri-file-text-line"></i></div>
            <div style="min-width:0;">
              <p class="co-sum-row__label"><%= Co.sumLabelProduct %></p>
              <p class="co-sum-row__value" id="sum-product" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:9rem;">—</p>
                </div>
                    </div>
          <div class="co-sum-row" id="sum-customer-row" style="display:none;">
            <div class="co-sum-row__icon"><i class="ri-user-line"></i></div>
            <div>
              <p class="co-sum-row__label"><%= Co.successLabelCustomer %></p>
              <p class="co-sum-row__value" id="sum-customer">—</p>
                      </div>
                    </div>
          <div class="co-sum-row" id="sum-phone-row" style="display:none;">
            <div class="co-sum-row__icon"><i class="ri-phone-line"></i></div>
            <div>
              <p class="co-sum-row__label"><%= Co.successLabelPhone %></p>
              <p class="co-sum-row__value" id="sum-phone">—</p>
                  </div>
                    </div>
          <div class="co-sum-row" id="sum-area-row" style="display:none;">
            <div class="co-sum-row__icon"><i class="ri-map-pin-line"></i></div>
            <div>
              <p class="co-sum-row__label"><%= Co.successLabelArea %></p>
              <p class="co-sum-row__value" id="sum-area">—</p>
                    </div>
                  </div>

          <div class="co-sum-divider"></div>

          <div class="co-sum-fee-row" id="sum-fee-delivery-row" style="display:none;">
            <span><%= Co.sumLabelBaseDelivery %></span>
            <span class="co-sum-fee-row__val" id="sum-fee-delivery">—</span>
                  </div>
          <div class="co-sum-fee-row" id="sum-fee-express-row" style="display:none;">
            <span><%= Co.sumLabelExpressAddOn %></span>
            <span class="co-sum-fee-row__val co-sum-fee-row__val--orange" id="sum-fee-express-val">—</span>
              </div>

          <div class="co-sum-fee-total" id="sum-fee-total-row" style="display:none;">
            <span class="co-sum-fee-total__label"><%= Co.sumLabelTotal %></span>
            <span class="co-sum-fee-total__value" id="sum-fee-total">0 <%= Co.currencyCode %></span>
              </div>
            </div>

        <!-- Tip -->
        <div class="co-summary__tip">
          <i class="ri-information-line"></i>
          <p id="co-tip-text"><%= Cj.wizTip1 || Co.shippingInfoSubtitle %></p>
</div>

            </div>
    </div><!-- /.co-sidebar-col -->

  </div><!-- /.co-layout -->

</div><!-- /.co-page -->

<!-- Area Selection Modal -->
<%- include('../partials/area-selection-modal') %>

<%- contentFor('FooterJs') %>
<script>window.__CO_CURRENCY = '<%= Co.currencyCode %>';window.__CO_PICKUP_ADDR_COUNT=<%= _coPickupAddrs.length %>;</script>
<script src="/assets/libs/sweetalert2/sweetalert2.min.js"></script>
<script src="/assets/js/area-selection-modal.js"></script>
<script src="/assets/rJS/business/create-order.js"></script>
