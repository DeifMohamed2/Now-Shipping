<%- contentFor('HeaderCss') %>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/choices.js/public/assets/styles/choices.min.css">
<link rel="stylesheet" href="/assets/css/area-selection-modal.css">

<style>
  :root {
    --primary-color: #F39720;
    --primary-hover: #e08a18;
    --primary-light: #fef4e8;
    --text-dark: #333333;
    --text-medium: #555555;
    --text-light: #777777;
    --border-color: #e0e0e0;
    --success-color: #28a745;
    --card-shadow: 0 4px 12px rgba(0, 0, 0, 0.08);
  }

  body {
    font-family: 'Poppins', sans-serif;
    color: var(--text-dark);
  }

  /* Card Styling */
  .card {
    border: none;
    border-radius: 16px !important;
    box-shadow: var(--card-shadow);
    margin-bottom: 1.5rem;
    overflow: hidden;
  }

  .card-header {
    background-color: #ffffff;
    border-bottom: 1px solid var(--border-color);
    padding: 1.25rem;
    font-weight: 600;
  }

  .card-body {
    padding: 1.5rem;
  }

  /* Form Elements */
  .form-label {
    font-weight: 500;
    margin-bottom: 0.5rem;
    color: var(--text-medium);
  }

  .form-control,
  .form-select {
    border-radius: 10px;
    border: 1px solid var(--border-color);
    padding: 0.65rem 1rem;
    font-size: 0.95rem;
    transition: all 0.3s ease;
  }

  .form-control:focus,
  .form-select:focus {
    border-color: var(--primary-color);
    box-shadow: 0 0 0 0.25rem rgba(243, 151, 32, 0.15);
  }

  .input-group {
    border-radius: 10px;
    overflow: hidden;
  }

  .input-group .btn {
    border-radius: 0;
    background-color: #f8f9fa;
    color: var(--text-medium);
    border: 1px solid var(--border-color);
    font-weight: 500;
  }

  .input-group .btn:hover {
    background-color: #e9ecef;
  }

  /* ── Create order wizard: circle-only triggers (no nav-link / nav-item), caption via <label for> ── */
  .co-wizard {
    --co-w-fill: 0;
    margin: -0.75rem -1.25rem 1rem;
    padding: 0.2rem 0.5rem 0.28rem;
    background: #fff;
    border: 1px solid #e8ecf2;
    border-top: none;
    border-radius: 0 0 14px 14px;
  }

  .co-wizard__list.nav.custom-nav {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0;
    position: relative;
    list-style: none;
    margin: 0;
    padding: 0;
    flex-wrap: nowrap;
  }

  .co-wizard__item {
    flex: 0 0 auto;
    margin: 0;
    padding: 0;
    position: relative;
    z-index: 1;
    list-style: none;
  }

  .co-wizard__stepcell {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.26rem;
    margin: 0;
    padding: 0;
    max-width: 100%;
  }

  .co-wizard__list::before {
    content: '';
    position: absolute;
    left: 1.35rem;
    right: 1.35rem;
    top: calc(0.06rem + 1.25rem);
    height: 2px;
    background: #d5dee8;
    border-radius: 999px;
    z-index: 0;
    pointer-events: none;
  }

  .co-wizard__list::after {
    content: '';
    position: absolute;
    left: 1.35rem;
    right: 1.35rem;
    top: calc(0.06rem + 1.25rem);
    height: 2px;
    background: var(--primary-color);
    border-radius: 999px;
    z-index: 0;
    pointer-events: none;
    transform: scaleX(var(--co-w-fill, 0));
    transform-origin: left center;
    transition: transform 0.4s cubic-bezier(0.33, 1, 0.68, 1);
  }

  html[dir='rtl'] .co-wizard__list::after {
    transform-origin: right center;
  }

  /* Circle-only button — zero padding, no Bootstrap nav-link box */
  .co-wizard__hit.co-wizard__tab {
    appearance: none;
    -webkit-appearance: none;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0;
    padding: 0;
    border: 0;
    border-radius: 50%;
    background: transparent !important;
    box-shadow: none !important;
    color: inherit;
    font: inherit;
    line-height: 0;
    cursor: pointer;
    box-sizing: border-box;
    width: auto;
    height: auto;
  }

  .co-wizard__hit.co-wizard__tab:focus-visible {
    outline: 2px solid var(--primary-color);
    outline-offset: 4px;
  }

  .co-wizard__node {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    border: 2px solid #9bb0c4;
    background: #eef2f6;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0;
    flex-shrink: 0;
    transition: border-color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .co-wizard__ico {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    font-size: 1.1rem;
    line-height: 1;
    color: inherit;
  }

  .co-wizard__ico::before {
    display: block;
    line-height: 1;
  }

  .co-wizard__text {
    display: block;
    font-size: clamp(0.72rem, 1.2vw, 0.86rem);
    font-weight: 600;
    color: #64748b;
    padding: 0 0.1rem;
    max-width: 6.75rem;
    word-wrap: break-word;
    line-height: 1.25;
    text-align: center;
    text-wrap: balance;
    cursor: pointer;
    user-select: none;
    margin: 0;
  }

  .co-wizard__text--static {
    cursor: default;
    pointer-events: none;
  }

  .co-wizard__stepcell:hover .co-wizard__text:not(.co-wizard__text--static) {
    color: #0f172a;
  }

  .co-wizard__hit.co-wizard__tab:not(.active):not(.done):not(.disabled) .co-wizard__node {
    border-color: #9bb0c4;
    background: #eef2f6;
    color: #5c7a95;
  }

  .co-wizard__hit.co-wizard__tab:not(.active):not(.done):not(.disabled) + .co-wizard__text {
    color: #64748b;
    font-weight: 600;
  }

  .co-wizard__hit.co-wizard__tab.done:not(.active) .co-wizard__node {
    border-color: #059669;
    background: linear-gradient(165deg, #34d399 0%, #059669 100%);
    color: #fff;
    box-shadow: 0 2px 10px rgba(5, 150, 105, 0.35);
  }

  .co-wizard__hit.co-wizard__tab.done:not(.active) .co-wizard__ico,
  .co-wizard__hit.co-wizard__tab.done:not(.active) .co-wizard__ico::before {
    color: #fff !important;
  }

  .co-wizard__hit.co-wizard__tab.done:not(.active) + .co-wizard__text:not(.co-wizard__text--static) {
    color: #047857;
    font-weight: 700;
  }

  .co-wizard__hit.co-wizard__tab.active .co-wizard__node {
    border-color: #c2410c;
    background: var(--primary-color);
    color: #fff;
    box-shadow: 0 0 0 3px rgba(243, 151, 32, 0.22), 0 4px 14px rgba(243, 151, 32, 0.45);
    transform: scale(1.04);
  }

  .co-wizard__hit.co-wizard__tab.active .co-wizard__ico,
  .co-wizard__hit.co-wizard__tab.active .co-wizard__ico::before {
    color: #fff !important;
  }

  .co-wizard__hit.co-wizard__tab.active + .co-wizard__text {
    color: #0f172a;
    font-weight: 700;
  }

  .co-wizard__hit.co-wizard__tab.disabled {
    opacity: 1;
    cursor: not-allowed;
    pointer-events: none;
  }

  .co-wizard__hit.co-wizard__tab.disabled .co-wizard__node {
    border-style: dashed;
    border-color: #9bb0c4;
    background: #e8edf2;
    color: #6b8299;
    box-shadow: none;
    transform: none;
  }

  .co-wizard__hit.co-wizard__tab.disabled ~ .co-wizard__text {
    color: #64748b;
    font-weight: 600;
  }

  @media (min-width: 768px) {
    .co-wizard__hit.co-wizard__tab:hover,
    .co-wizard__hit.co-wizard__tab:focus,
    .co-wizard__hit.co-wizard__tab:active {
      background: transparent !important;
      box-shadow: none !important;
    }

    .checkout-tab .co-wizard .co-wizard__hit.co-wizard__tab:hover,
    .checkout-tab .co-wizard .co-wizard__hit.co-wizard__tab:focus,
    .checkout-tab .co-wizard .co-wizard__hit.co-wizard__tab:active {
      background-color: transparent !important;
      background-image: none !important;
    }
  }

  @media (max-width: 767.98px) {
    .co-wizard {
      margin: -0.5rem -0.75rem 0.85rem;
      padding: 0.35rem 0.55rem 0.4rem;
    }

    .co-wizard__list::before,
    .co-wizard__list::after {
      display: none;
    }

    .co-wizard__list.nav.custom-nav {
      flex-direction: column;
      align-items: stretch;
      gap: 0.45rem;
    }

    .co-wizard__item {
      flex: none;
      width: 100%;
    }

    .co-wizard__stepcell {
      flex-direction: row !important;
      align-items: center;
      justify-content: flex-start;
      width: 100%;
      gap: 0;
      padding: 0.65rem 0.85rem;
      border: 1px solid #e2e8f0;
      border-radius: 12px;
      background: #fff;
      box-shadow: 0 1px 2px rgba(15, 23, 42, 0.05);
    }

    .co-wizard__stepcell:hover {
      border-color: #cbd5e1;
      background: #f8fafc;
    }

    .co-wizard__item:has(.co-wizard__hit.disabled) .co-wizard__stepcell:hover {
      border-color: #e2e8f0;
      background: #fff;
    }

    .co-wizard__stepcell:has(.co-wizard__hit.active) {
      border-color: var(--primary-color) !important;
      background: linear-gradient(90deg, #fffbf5 0%, #fff 100%) !important;
      box-shadow: 0 0 0 2px rgba(243, 151, 32, 0.12);
    }

    .co-wizard__node {
      margin: 0 0.75rem 0 0;
      width: 2.65rem;
      height: 2.65rem;
    }

    .co-wizard__ico {
      font-size: 1.18rem;
    }

    .co-wizard__text {
      flex: 1;
      text-align: start;
      font-size: 0.88rem;
      padding: 0;
      max-width: none;
    }

    html[dir='rtl'] .co-wizard__stepcell {
      flex-direction: row-reverse !important;
    }

    html[dir='rtl'] .co-wizard__text {
      text-align: right;
    }

    html[dir='rtl'] .co-wizard__node {
      margin: 0 0 0 0.75rem;
    }
  }

  /* Buttons */
  .btn-primary {
    background-color: var(--primary-color);
    border: none;
    border-radius: 10px;
    padding: 0.65rem 1.5rem;
    font-weight: 500;
    transition: all 0.3s ease;
  }

  .btn-primary:hover {
    background-color: var(--primary-hover);
    transform: translateY(-2px);
  }

  .btn-light {
    background-color: #f8f9fa;
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 0.65rem 1.5rem;
    font-weight: 500;
    color: var(--text-medium);
    transition: all 0.3s ease;
  }

  .btn-light:hover {
    background-color: #e9ecef;
    transform: translateY(-2px);
  }

  /* Order Type Cards */
  .form-check.card-radio {
    padding: 0;
    margin-bottom: 0.5rem;
  }

  .form-check.card-radio .form-check-input {
    display: none;
  }

  .form-check.card-radio .form-check-label {
    display: block;
    padding: 1.25rem;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .form-check.card-radio .form-check-input:checked+.form-check-label {
    border-color: var(--primary-color);
    background-color: var(--primary-light);
    box-shadow: 0 0 0 1px var(--primary-color);
  }

  .form-check.card-radio .form-check-label:hover {
    background-color: var(--primary-light);
  }

  .form-check.card-radio .form-check-label i {
    color: var(--primary-color);
    font-size: 1.25rem;
  }

  /* Hover Effects */
  .hover-effect:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 15px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
  }

  /* Section Headers */
  .section-title {
    font-weight: 600;
    color: var(--text-dark);
    margin-bottom: 0.5rem;
  }

  .section-subtitle {
    color: var(--text-light);
    margin-bottom: 1.5rem;
  }

  /* Fee Display — base (refined in .fee-summary-card below) */
  .fee-display {
    text-align: center;
    position: relative;
  }

  .fee-amount {
    font-size: 2rem;
    font-weight: 700;
    color: var(--primary-color);
  }

  .fee-currency {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-medium);
  }

  .fee-label {
    color: var(--text-light);
    font-size: 0.9rem;
  }
  
  /* Loading styles */
  .loading-spinner {
    display: none;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }
  
  .loading .loading-spinner {
    display: block;
  }
  
  .loading .fee-amount,
  .loading .fee-currency {
    opacity: 0.3;
  }

  /* Completion Screen */
  .completion-icon {
    width: 120px;
    height: 120px;
    margin: 0 auto 1.5rem;
  }

  .completion-title {
    font-weight: 600;
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .completion-message {
    color: var(--text-light);
    margin-bottom: 1.5rem;
  }

  .order-id {
    font-size: 1.25rem;
    font-weight: 600;
  }

  .order-id a {
    color: var(--primary-color);
    text-decoration: underline;
  }

  /* Custom Select Styling */
  .select-container {
    position: relative;
  }

  .select-container select {
    appearance: none;
    -webkit-appearance: none;
    padding-right: 2.5rem;
  }

  .zone-select-wrapper {
    position: relative;
  }

  .zone-select-arrow {
    position: absolute;
    right: 10px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
  }

  .zone-select-arrow i {
    color: var(--text-medium);
  }

  .loading-spinner {
    display: none;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .loading .loading-spinner {
    display: block;
  }

  .loading .fee-amount,
  .loading .fee-currency {
    opacity: 0.3;
  }

  /* ── Option Toggle Cards ─────────────────────────────────────────────── */
  .option-cards-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  /* the <label> IS the card — input is hidden */
  .option-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.9rem 1.25rem;
    border-radius: 10px;
    border: 1.5px solid #e8e8e8;
    background: #ffffff;
    cursor: pointer;
    transition: border-color 0.18s, background 0.18s, box-shadow 0.18s;
    -webkit-user-select: none;
    user-select: none;
    box-sizing: border-box;
    max-width: 26rem;
    width: 100%;
  }

  /* hidden real checkbox */
  .option-card input[type="checkbox"] {
    display: none;
  }

  /* custom checkbox ring */
  .option-card-check {
    flex-shrink: 0;
    width: 1.2rem;
    height: 1.2rem;
    border-radius: 4px;
    border: 2px solid #d0d0d0;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.18s, background 0.18s;
    order: 0;
  }

  .option-card-check svg {
    width: 0.65rem;
    height: 0.65rem;
    stroke: #fff;
    stroke-width: 2.5;
    fill: none;
    opacity: 0;
    transition: opacity 0.15s;
  }

  /* icon slot */
  .option-card-icon {
    flex-shrink: 0;
    order: 1;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 8px;
    background: #f4f6f8;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    color: #888;
    transition: background 0.18s, color 0.18s;
  }

  /* text block */
  .option-card-text {
    flex: 1;
    min-width: 0;
    order: 2;
  }

  .option-card-text strong {
    display: block;
    font-size: 0.93rem;
    font-weight: 600;
    color: #1e293b;
    line-height: 1.3;
  }

  .option-card-text span {
    display: block;
    font-size: 0.78rem;
    color: #94a3b8;
    margin-top: 0.2rem;
    line-height: 1.3;
  }

  /* ── Hover ── */
  .option-card:hover {
    border-color: rgba(243, 151, 32, 0.45);
    background: #fffaf4;
    box-shadow: 0 2px 8px rgba(243, 151, 32, 0.08);
  }

  /* ── Checked state ── */
  .option-card.is-checked {
    border-color: var(--primary-color);
    background: linear-gradient(135deg, #fffbf4 0%, #fff5e6 100%);
    box-shadow: 0 0 0 3px rgba(243, 151, 32, 0.1);
  }

  .option-card.is-checked .option-card-check {
    border-color: var(--primary-color);
    background: var(--primary-color);
  }

  .option-card.is-checked .option-card-check svg {
    opacity: 1;
  }

  .option-card.is-checked .option-card-icon {
    background: rgba(243, 151, 32, 0.12);
    color: var(--primary-color);
  }

  .option-card.is-checked .option-card-text strong {
    color: #92500a;
  }

  /* ── RTL: reverse order so check is on the right ── */
  html[dir='rtl'] .option-card {
    flex-direction: row-reverse;
  }

  html[dir='rtl'] .option-card-text {
    text-align: right;
  }

  /* section label above cards */
  .option-section-label {
    font-size: 0.82rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #94a3b8;
    margin-bottom: 0.6rem;
  }

  /* Express: after 9 PM Cairo = next-day (not same-day) — high-visibility notice */
  .express-after-nine-notice {
    margin-top: 0.65rem;
    margin-bottom: 0.25rem;
    padding: 0.85rem 1rem 0.85rem 1rem;
    border-radius: 8px;
    border: 2px solid rgba(200, 120, 0, 0.55);
    background: linear-gradient(135deg, rgba(255, 193, 7, 0.35) 0%, rgba(255, 248, 220, 0.95) 55%, #fff 100%);
    box-shadow: 0 2px 8px rgba(180, 100, 0, 0.12);
    color: #4a3200;
    font-size: 0.95rem;
    line-height: 1.45;
  }

  .express-after-nine-notice strong {
    color: #2d1f00;
  }

  .express-after-nine-notice .express-after-nine-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #7a4a00;
    background: rgba(255, 152, 0, 0.35);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    margin-bottom: 0.35rem;
  }
  
  .amount-input-section {
    background-color: #f8f9fa;
    border-radius: 10px;
    padding: 1rem;
    margin-top: 1rem;
    border-left: 3px solid var(--primary-color);
  }
  
  .amount-input-section .info-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
  }
  
  .info-badge.info {
    background-color: #d1ecf1;
    color: #0c5460;
  }
  
  .info-badge i {
    font-size: 0.75rem;
    margin-right: 0.25rem;
  }
  
  .fee-summary-card {
    border-radius: 14px;
    overflow: hidden;
    border-color: #e2e8f0 !important;
    box-shadow: 0 4px 24px rgba(15, 23, 42, 0.06) !important;
  }

  .fee-summary-card .fee-summary-header {
    background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
    border-bottom: 1px solid #eef2f7;
    padding: 1rem 1.35rem;
  }

  .fee-summary-card .fee-summary-header h6 {
    color: #0f172a;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .fee-summary-card .fee-header-icon-wrap {
    width: 42px;
    height: 42px;
    border-radius: 12px;
    background: linear-gradient(145deg, rgba(243, 151, 32, 0.18) 0%, rgba(243, 151, 32, 0.06) 100%);
    color: var(--primary-color);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .fee-summary-card .fee-display {
    position: relative;
    min-height: 148px;
    padding: 1.75rem 1.5rem 1.5rem;
    background: linear-gradient(165deg, #f8fafc 0%, #f1f5f9 45%, #ffffff 100%);
    border-radius: 14px;
    border: 1px solid #e2e8f0;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.9);
  }

  .fee-summary-card .fee-display .fee-amount {
    font-size: clamp(2.25rem, 6vw, 3.25rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #1e3a5f;
  }

  .fee-summary-card .fee-display .fee-currency {
    font-size: 1.15rem;
    font-weight: 600;
    color: #64748b;
    vertical-align: 0.15em;
  }

  .fee-summary-card .fee-display .fee-total-caption {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: #94a3b8;
  }

  /* Fee Breakdown Styles */
  .fee-breakdown {
    margin-top: 1rem;
    padding: 1.1rem 1.35rem 1.15rem 1.5rem;
    background: #fafbfc;
    border: 1px solid #e8ecf0;
    border-radius: 12px;
    border-left: 4px solid rgba(243, 151, 32, 0.65);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.85);
  }

  .fee-breakdown-header {
    font-weight: 700;
    color: #334155;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #e8ecf0;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .fee-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.55rem 0;
    border-bottom: 1px solid #eef1f5;
  }

  .fee-row:last-of-type {
    border-bottom: none;
  }

  .fee-row-label {
    color: #475569;
    font-size: 0.92rem;
    text-align: left;
    padding-right: 0.5rem;
  }

  .fee-row-amount {
    font-weight: 600;
    color: #1e293b;
    font-size: 0.92rem;
    white-space: nowrap;
  }

  .fee-row-total {
    font-weight: 800;
    color: var(--primary-color);
    font-size: 1.02rem;
    margin-top: 0.25rem;
    padding-top: 0.75rem;
    border-top: 2px solid rgba(243, 151, 32, 0.35);
  }

  .fee-breakdown-toggle {
    padding: 0.35rem 0.25rem 0 0.35rem;
    margin-top: 0.5rem;
  }

  .fee-breakdown-toggle .form-check-input {
    width: 1.1rem;
    height: 1.1rem;
    margin-top: 0.2rem;
    cursor: pointer;
    border-color: #cbd5e1;
  }

  .fee-breakdown-toggle .form-check-input:checked {
    background-color: var(--primary-color);
    border-color: var(--primary-color);
  }

  .fee-breakdown-toggle .form-check-label {
    cursor: pointer;
    color: #64748b;
    font-size: 0.9rem;
    padding-left: 0.35rem;
    user-select: none;
  }

  .fee-breakdown-hidden {
    display: none;
  }

  @media (max-width: 575.98px) {
    .checkout-tab .card-body {
      padding: 1rem;
    }

    .nav-pills .nav-link {
      padding: 0.75rem 1rem;
      font-size: 0.9rem;
    }
  }

  /* ── RTL overrides ─────────────────────────────────────────────────── */
  html[dir='rtl'] body {
    font-family: 'Cairo', 'Poppins', sans-serif;
  }

  /* Flip left-border accent to right */
  html[dir='rtl'] .amount-input-section {
    border-left: none;
    border-right: 3px solid var(--primary-color);
  }

  html[dir='rtl'] .fee-breakdown {
    border-left: none;
    border-right: 4px solid rgba(243, 151, 32, 0.65);
  }

  /* nav-link icon spacing */
  html[dir='rtl'] .nav-pills .nav-link i {
    margin-right: 0;
    margin-left: 0.5rem;
  }

  /* Input group: flip border radii */
  html[dir='rtl'] .input-group .btn:first-child {
    border-radius: 0 10px 10px 0;
  }
  html[dir='rtl'] .input-group .btn:last-child {
    border-radius: 10px 0 0 10px;
  }
  html[dir='rtl'] .input-group .form-control:not(:first-child):not(:last-child) {
    border-radius: 0;
  }

  /* Select custom arrow: flip to left */
  html[dir='rtl'] .select-container select {
    padding-right: 1rem;
    padding-left: 2.5rem;
  }

  html[dir='rtl'] .zone-select-arrow {
    right: auto;
    left: 10px;
  }

  /* Fee breakdown label alignment */
  html[dir='rtl'] .fee-row-label {
    text-align: right;
    padding-right: 0;
    padding-left: 0.5rem;
  }

  /* Card-radio icon margin */
  html[dir='rtl'] .form-check.card-radio .form-check-label span.fs-16 {
    margin-right: 0;
    margin-left: 0.5rem;
  }

  /* Pickup address section: flip border from start to end */
  html[dir='rtl'] #pickupAddressSelection {
    border-right: 2px solid rgba(243, 151, 32, 0.35) !important;
    border-left: none !important;
    padding-right: 0.75rem;
    padding-left: 0;
    margin-right: 0.5rem;
    margin-left: 0;
  }

  /* fee-breakdown toggle label padding */
  html[dir='rtl'] .fee-breakdown-toggle .form-check-label {
    padding-left: 0;
    padding-right: 0.5rem;
  }

  /* Back/next button icon spacing */
  html[dir='rtl'] .btn-label i.label-icon {
    margin-left: 0;
    margin-right: 0.5rem;
  }

  /* area selection button arrow */
  html[dir='rtl'] #selectAreaBtn {
    text-align: right;
  }

  /* info badge icon margin */
  html[dir='rtl'] .info-badge i {
    margin-right: 0;
    margin-left: 0.25rem;
  }
</style>

<%- contentFor('body') %>
<% var Co = (typeof translation !== 'undefined' && translation.business && translation.business.pages && translation.business.pages.createOrder) ? translation.business.pages.createOrder : {}; %>
<div class="row justify-content-center g-0 g-sm-3">
  <div class="col-12 col-xl-11">
    <div class="card">
      <div class="card-body checkout-tab">
        <form id="createOrderForm">
          <!-- Step navigation: circle-only buttons + <label for> captions (.custom-nav for checkout init.js) -->
          <div class="co-wizard mt-n3 mx-n3 mb-3">
            <ul class="nav co-wizard__list custom-nav" role="tablist">
              <li class="co-wizard__item" role="presentation">
                <div class="co-wizard__stepcell">
                  <button class="co-wizard__hit co-wizard__tab nav-create active" id="pills-bill-address-tab" data-bs-toggle="pill" data-bs-target="#pills-bill-address" type="button" role="tab" aria-controls="pills-bill-address" aria-selected="true">
                    <span class="co-wizard__node" aria-hidden="true"><i class="ri-truck-line co-wizard__ico"></i></span>
                  </button>
                  <label class="co-wizard__text" for="pills-bill-address-tab"><%= Co.stepShipping || 'Shipping Details' %></label>
                </div>
              </li>
              <li class="co-wizard__item" role="presentation">
                <div class="co-wizard__stepcell">
                  <button class="co-wizard__hit co-wizard__tab nav-create" id="pills-bill-info-tab" data-bs-toggle="pill" data-bs-target="#pills-bill-info" type="button" role="tab" aria-controls="pills-bill-info" aria-selected="false">
                    <span class="co-wizard__node" aria-hidden="true"><i class="ri-user-2-line co-wizard__ico"></i></span>
                  </button>
                  <label class="co-wizard__text" for="pills-bill-info-tab"><%= Co.stepCustomer || 'Customer Details' %></label>
                </div>
              </li>
              <li class="co-wizard__item" role="presentation">
                <div class="co-wizard__stepcell">
                  <button class="co-wizard__hit co-wizard__tab nav-create" id="pills-payment-tab" data-bs-toggle="pill" data-bs-target="#pills-payment" type="button" role="tab" aria-controls="pills-payment" aria-selected="false">
                    <span class="co-wizard__node" aria-hidden="true"><i class="ri-bank-card-line co-wizard__ico"></i></span>
                  </button>
                  <label class="co-wizard__text" for="pills-payment-tab"><%= Co.stepAdditional || 'Additional Options' %></label>
                </div>
              </li>
              <li class="co-wizard__item" role="presentation">
                <div class="co-wizard__stepcell">
                  <button class="co-wizard__hit co-wizard__tab nav-create disabled" id="pills-finish-tab" data-bs-toggle="pill" data-bs-target="#pills-finish" type="button" role="tab" aria-controls="pills-finish" aria-selected="false" tabindex="-1">
                    <span class="co-wizard__node" aria-hidden="true"><i class="ri-checkbox-circle-line co-wizard__ico"></i></span>
                  </button>
                  <span class="co-wizard__text co-wizard__text--static"><%= Co.stepComplete || 'Complete' %></span>
                </div>
              </li>
            </ul>
          </div>

          <!-- Tab Content -->
          <div class="tab-content">
            <!-- Shipping Info Tab -->
            <div class="tab-pane fade show active" id="pills-bill-address" role="tabpanel" aria-labelledby="pills-bill-address-tab">
              <div class="mb-4">
                <h5 class="section-title"><%= Co.shippingInfoTitle || 'Shipping Information' %></h5>
                <p class="section-subtitle"><%= Co.shippingInfoSubtitle || 'Select delivery type and provide shipping details' %></p>
              </div>

              <!-- Order Type Section -->
              <div class="card mb-4 hover-effect">
                <div class="card-header">
                  <h6 class="mb-0"><%= Co.orderTypeLabel || 'Order Type' %></h6>
                </div>
                <div class="card-body">
                  <div class="row g-3">
                    <div class="col-lg-4 col-sm-6" >
                      <div class="form-check card-radio">
                        <input id="paymentMethod01" name="orderType" type="radio" class="form-check-input" value="Deliver">
                        <label class="form-check-label" for="paymentMethod01">
                          <span class="fs-16 me-2"><i class="ri-truck-line align-bottom"></i></span>
                          <span class="fs-14 text-wrap"><%= Co.typeDelivery || 'Delivery' %></span>
                        </label>
                      </div>
                    </div>
                    <div class="col-lg-4 col-sm-6">
                      <div class="form-check card-radio">
                        <input id="paymentMethod02" name="orderType" type="radio" class="form-check-input" value="Exchange">
                        <label class="form-check-label" for="paymentMethod02">
                          <span class="fs-16 me-2"><i class="ri-exchange-line align-bottom"></i></span>
                          <span class="fs-14 text-wrap"><%= Co.typeExchange || 'Exchange' %></span>
                        </label>
                      </div>
                    </div>
                    <div class="col-lg-4 col-sm-6">
                      <div class="form-check card-radio" >
                        <input id="paymentMethod03" name="orderType" type="radio" class="form-check-input" value="Return">
                        <label class="form-check-label" for="paymentMethod03">
                          <span class="fs-16 me-2"><i class="ri-arrow-go-back-line align-bottom"></i></span>
                          <span class="fs-14 text-wrap"><%= Co.typeReturn || 'Return' %></span>
                        </label>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Deliver Section -->
              <div id="deliver-section" class="card mb-4 hover-effect" style="display: none;">
                <div class="card-header">
                  <h6 class="mb-0"><%= Co.deliveryDetailsLabel || 'Delivery Details' %></h6>
                </div>
                <div class="card-body">
                  <div class="mb-4">
                    <label for="delivery-description" class="form-label"><%= Co.productDescLabel || 'Product Description' %></label>
                    <textarea class="form-control" name="productDescription" id="delivery-description" placeholder="<%= Co.productDescPlaceholder || 'Describe the products being delivered' %>" rows="3"></textarea>
                  </div>
                  <div class="mb-4 col-md-4">
                    <label for="shipping-count" class="form-label"><%= Co.itemsCount || 'Number of Items' %></label>
                    <div class="input-group">
                      <button type="button" class="btn" id="decrement-shipping">-</button>
                      <input type="number" name="numberOfItems" class="form-control text-center" id="shipping-count" value="1" min="1">
                      <button type="button" class="btn" id="increment-shipping">+</button>
                    </div>
                  </div>
                  
                  <!-- Shipping speed option card -->
                  <div class="mb-4">
                    <p class="option-section-label"><%= Co.shippingSpeedLabel || 'Shipping Speed' %></p>
                    <div class="option-cards-group">
                      <label class="option-card" id="express-card" for="express-shipping-checkbox">
                        <input type="checkbox" name="isExpressShipping" id="express-shipping-checkbox" value="on">
                        <span class="option-card-check">
                          <svg viewBox="0 0 12 10"><polyline points="1,5 4.5,8.5 11,1"/></svg>
                        </span>
                        <span class="option-card-icon"><i class="ri-flashlight-line"></i></span>
                        <span class="option-card-text">
                          <strong><%= Co.expressShippingLabel || 'Express Shipping' %></strong>
                          <span id="express-shipping-subtitle"
                                data-default="<%= Co.expressShippingSub || 'Same day delivery service' %>"
                                data-after9="<%= Co.expressNextDaySub || 'Next day delivery — orders after 9:00 PM (Cairo) are not same-day' %>">
                            <%= Co.expressShippingSub || 'Same day delivery service' %>
                          </span>
                        </span>
                      </label>
                    </div>

                    <div id="express-after-nine-notice" class="express-after-nine-notice d-none mt-2" role="status" aria-live="polite">
                      <div class="express-after-nine-badge"><%= Co.expressAfterNineBadge || 'After 9:00 PM (Cairo)' %></div>
                      <strong><%= Co.expressAfterNineText || 'Next-day delivery' %></strong> — <%= Co.expressAfterNineText || 'Express orders placed now are' %> <strong><%= Co.expressAfterNineNot || 'not' %></strong> <%= Co.expressAfterNineSched || 'same-day; they are scheduled for' %> <strong><%= Co.expressAfterNineDay || 'delivery the next calendar day' %></strong>.
                    </div>

                    <div id="pickupAddressSelection" class="mt-3" style="display: none;">
                      <label class="form-label mb-2"><%= Co.selectPickupLabel || 'Select Pickup Address' %> <span class="text-danger">*</span></label>
                      <select class="form-select" id="selectedPickupAddressId" name="selectedPickupAddressId">
                        <option value=""><%= Co.selectPickupPlaceholder || 'Select pickup address...' %></option>
                        <% if (userData && userData.pickUpAddresses && userData.pickUpAddresses.length > 0) { %>
                          <% userData.pickUpAddresses.forEach(address => { %>
                            <option value="<%= address.addressId %>" <%= address.isDefault ? 'selected' : '' %>>
                              <%= address.addressName || 'Address' %>
                              <% if (address.isDefault) { %> (<%= Co.addressDefault || 'Default' %>) <% } %>
                              - <%= address.zone %>, <%= address.city %>
                            </option>
                          <% }); %>
                        <% } else if (userData && userData.pickUpAdress) { %>
                          <option value="default" selected>
                            Main Address - <%= userData.pickUpAdress.zone || '' %>, <%= userData.pickUpAdress.city || '' %>
                          </option>
                        <% } %>
                      </select>
                      <div class="mt-2">
                        <a href="/business/settings#address" class="btn btn-sm btn-outline-primary" target="_blank">
                          <i class="ri-add-line me-1"></i> <%= Co.addNewAddress || 'Add New Address' %>
                        </a>
                      </div>
                    </div>
                  </div>

                  <!-- Payment collection option card -->
                  <div class="mb-3" id="cash-on-delivery-section" style="display: none;">
                    <p class="option-section-label"><%= Co.paymentCollectionLabel || 'Payment Collection' %></p>
                    <div class="option-cards-group">
                      <label class="option-card" id="cod-card" for="cash-on-delivery-checkbox">
                        <input type="checkbox" name="COD" id="cash-on-delivery-checkbox" value="on">
                        <span class="option-card-check">
                          <svg viewBox="0 0 12 10"><polyline points="1,5 4.5,8.5 11,1"/></svg>
                        </span>
                        <span class="option-card-icon"><i class="ri-money-dollar-circle-line"></i></span>
                        <span class="option-card-text">
                          <strong><%= Co.codLabel || 'Cash on Delivery (COD)' %></strong>
                          <span><%= Co.codSub || 'Collect payment upon delivery' %></span>
                        </span>
                      </label>
                    </div>
                  </div>
                  
                  <!-- Amount Input Section (Full Width Below) -->
                  <div class="amount-input-section" id="cash-on-delivery-amount" style="display: none;">
                    <div class="info-badge info">
                      <i class="ri-information-line"></i>
                      <%= Co.amountCollectInfo || 'This is the actual full amount that will be collected from the customer' %>
                    </div>
                    <label for="cash-on-delivery-input" class="form-label"><%= Co.amountCollectLabel || 'Amount to Collect' %></label>
                    <div class="input-group">
                      <span class="input-group-text">EGP</span>
                      <input type="number" name="amountCOD" class="form-control" id="cash-on-delivery-input" placeholder="<%= Co.amountPlaceholder || 'Enter amount' %>">
                    </div>
                  </div>
                </div>
              </div>

              <!-- Exchange Section -->
              <div id="exchange-section" class="card mb-4 hover-effect" style="display: none;">
                <div class="card-header">
                  <h6 class="mb-0"><%= Co.exchangeDetailsLabel || 'Exchange Details' %></h6>
                </div>
                <div class="card-body">
                  <div class="mb-4">
                    <label for="exchange-current-product" class="form-label"><%= Co.currentProductLabel || 'Current Product Description' %></label>
                    <textarea class="form-control" name="currentPD" id="exchange-current-product" placeholder="<%= Co.currentProductPlaceholder || 'Describe the products being returned' %>" rows="3"></textarea>
                  </div>
                  <div class="mb-4 col-md-4">
                    <label for="exchange-current-count" class="form-label"><%= Co.currentItemsLabel || 'Number of Current Items' %></label>
                    <div class="input-group">
                      <button type="button" class="btn" id="decrement-current">-</button>
                      <input type="number" name="numberOfItemsCurrentPD" class="form-control text-center" id="exchange-current-count" value="1" min="1">
                      <button type="button" class="btn" id="increment-current">+</button>
                    </div>
                  </div>
                  <div class="mb-4">
                    <label for="exchange-new-product" class="form-label"><%= Co.newProductLabel || 'New Product Description' %></label>
                    <textarea class="form-control" name="newPD" id="exchange-new-product" placeholder="<%= Co.newProductPlaceholder || 'Describe the replacement products' %>" rows="3"></textarea>
                  </div>
                  <div class="mb-4 col-md-4">
                    <label for="exchange-new-count" class="form-label"><%= Co.newItemsLabel || 'Number of New Items' %></label>
                    <div class="input-group">
                      <button type="button" class="btn" id="decrement-new">-</button>
                      <input type="number" name="numberOfItemsNewPD" class="form-control text-center" id="exchange-new-count" value="1" min="1">
                      <button type="button" class="btn" id="increment-new">+</button>
                    </div>
                  </div>
                  <div class="mb-3" id="cash-difference-section" style="display: none;">
                    <p class="option-section-label"><%= Co.paymentCollectionLabel || 'Payment Collection' %></p>
                    <div class="option-cards-group">
                      <label class="option-card" id="cash-diff-card" for="cash-difference-checkbox">
                        <input type="checkbox" name="CashDifference" id="cash-difference-checkbox" value="on">
                        <span class="option-card-check">
                          <svg viewBox="0 0 12 10"><polyline points="1,5 4.5,8.5 11,1"/></svg>
                        </span>
                        <span class="option-card-icon"><i class="ri-exchange-dollar-line"></i></span>
                        <span class="option-card-text">
                          <strong><%= Co.cashDiffLabel || 'Cash Difference (CD)' %></strong>
                          <span><%= Co.cashDiffSub || 'Collect additional payment' %></span>
                        </span>
                      </label>
                    </div>
                  </div>
                  
                  <!-- Amount Input Section (Full Width Below) -->
                  <div class="amount-input-section" id="cash-difference-amount" style="display: none;">
                    <div class="info-badge info">
                      <i class="ri-information-line"></i>
                      <%= Co.amountCollectInfo || 'This is the actual full amount that will be collected from the customer' %>
                    </div>
                    <label for="cash-difference-input" class="form-label"><%= Co.cashDiffAmountLabel || 'Difference Amount' %></label>
                    <div class="input-group">
                      <span class="input-group-text">EGP</span>
                      <input type="number" name="amountCashDifference" class="form-control" id="cash-difference-input" placeholder="<%= Co.cashDiffAmountPlaceholder || 'Enter difference amount' %>">
                    </div>
                  </div>
                </div>
              </div>

              <!-- Return Section -->
              <div id="return-section" class="card mb-4 hover-effect" style="display: none;">
                <div class="card-header">
                  <h6 class="mb-0"><%= Co.returnDetailsLabel || 'Return Details' %></h6>
                </div>
                <div class="card-body">
                  <div class="alert alert-info mb-4">
                    <i class="ri-information-line me-2"></i>
                    <strong><%= Co.returnInfoAlert || 'Return Process:' %></strong> <%= Co.returnInfoText || 'Create a return order for an existing delivered order. The original order will be automatically linked when the return is picked up.' %>
                  </div>
                  
                  <div class="mb-4">
                    <label for="original-order-number" class="form-label"><%= Co.originalOrderLabel || 'Original Order Number' %> *</label>
                    <input type="text" class="form-control" name="originalOrderNumber" id="original-order-number" placeholder="<%= Co.originalOrderPlaceholder || 'Enter the order number of the delivered order to return' %>" required>
                    <div class="form-text">
                      <%= Co.originalOrderHelp || 'Enter the order number of the completed order that needs to be returned.' %>
                    </div>
                    <div id="original-order-preview" class="alert alert-success mt-2" style="display: none;">
                      <h6 id="original-order-found-title"><%= Co.originalOrderFound || 'Original Order Found:' %></h6>
                      <div id="original-order-details"></div>
                    </div>
                  </div>

                  <!-- Partial Return Section -->
                  <div id="partial-return-section" class="card mb-4" style="display: none;">
                    <div class="card-header">
                      <h6 class="mb-0"><%= Co.returnTypeLabel || 'Return Type Selection' %></h6>
                    </div>
                    <div class="card-body">
                      <div class="alert alert-info mb-3">
                        <i class="ri-information-line me-2"></i>
                        <strong><%= Co.multipleItemsAlert || 'Multiple Items Detected:' %></strong> <%= Co.multipleItemsText || 'This order contains multiple items. Choose whether to return all items or just specific ones.' %>
                      </div>
                      
                      <div class="mb-3">
                        <div class="form-check">
                          <input class="form-check-input" type="radio" name="returnType" id="full-return" value="full" checked>
                          <label class="form-check-label" for="full-return">
                            <strong><%= Co.fullReturnLabel || 'Full Return' %></strong> - <%= Co.fullReturnSub || 'Return all items from the original order' %>
                          </label>
                        </div>
                        <div class="form-check">
                          <input class="form-check-input" type="radio" name="returnType" id="partial-return" value="partial">
                          <label class="form-check-label" for="partial-return">
                            <strong><%= Co.partialReturnLabel || 'Partial Return' %></strong> - <%= Co.partialReturnSub || 'Return only specific items' %>
                          </label>
                        </div>
                      </div>

                      <!-- Partial Return Details -->
                      <div id="partial-return-details" style="display: none;">
                        <div class="row g-3">
                          <div class="col-md-6">
                            <label for="partial-return-count" class="form-label"><%= Co.partialItemsLabel || 'Number of Items to Return' %></label>
                            <div class="input-group">
                              <button type="button" class="btn" id="decrement-partial">-</button>
                              <input type="number" name="partialReturnItemCount" class="form-control text-center" id="partial-return-count" value="1" min="1">
                              <button type="button" class="btn" id="increment-partial">+</button>
                            </div>
                            <div class="form-text"><%= Co.partialMaxLabel || 'Maximum:' %> <span id="max-items"></span> <%= Co.partialItemsUnit || 'items' %></div>
                          </div>
                          <div class="col-md-6">
                            <label for="remaining-count" class="form-label"><%= Co.remainingLabel || 'Items Remaining with Customer' %></label>
                            <div class="form-control text-center" id="remaining-count" style="background-color: #f8f9fa;">0</div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                  
                  <!-- Standard Return Fields (hidden for partial returns) -->
                  <div id="standard-return-fields">
                    <div class="mb-4">
                      <label for="return-description" class="form-label"><%= Co.returnDescLabel || 'Product Description' %></label>
                      <textarea class="form-control" name="productDescription" id="return-description" placeholder="<%= Co.returnDescPlaceholder || 'Describe the products being returned' %>" rows="3"></textarea>
                    </div>
                    <div class="mb-4 col-md-4" id="standard-return-number-of-items">
                      <label for="return-count" class="form-label"><%= Co.itemsCount || 'Number of Items' %></label>
                      <div class="input-group">
                        <button type="button" class="btn" id="decrement-return">-</button>
