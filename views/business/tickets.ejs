<%- contentFor('HeaderCss') %>
<link href="/assets/libs/sweetalert2/sweetalert2.min.css" rel="stylesheet" />
<link rel="stylesheet" href="/assets/rCSS/tickets-new.css">

<%- contentFor('body') %>
<% var Tt = (typeof translation !== 'undefined' && translation.business && translation.business.pages && translation.business.pages.tickets) ? translation.business.pages.tickets : {}; %>
<div class="tickets-page">
  <div class="container-fluid tickets-page__inner py-2">
    <!-- Header Section -->
    <div class="row mb-3">
      <div class="col-12">
        <div class="tickets-page__masthead d-flex flex-wrap align-items-center justify-content-between gap-2">
          <div>
            <h1 class="tickets-page__title mb-1">
              <i class="ri-customer-service-2-line tickets-page__title-icon" aria-hidden="true"></i>
              <%= Tt.mastheadTitle || 'Support tickets' %>
            </h1>
            <p class="tickets-page__lead text-muted mb-0"><%= Tt.mastheadLead || 'Message the team about orders, delivery, billing, or account help.' %></p>
          </div>
          <button type="button" class="btn btn-tickets-primary tickets-page__cta" id="createTicketBtn">
            <i class="ri-add-line me-1" aria-hidden="true"></i><%= Tt.newTicket || 'New ticket' %>
          </button>
        </div>
      </div>
    </div>

    <div class="row g-3">
      <!-- Ticket List Sidebar -->
      <div class="col-lg-4">
        <div class="card tickets-panel h-100 border-0">
          <div class="tickets-panel__head card-header border-0">
            <div class="d-flex align-items-center justify-content-between">
              <h2 class="tickets-panel__title mb-0">
                <i class="ri-ticket-2-line me-2" aria-hidden="true"></i><%= Tt.myTickets || 'My tickets' %>
              </h2>
              <span class="badge tickets-count-badge" id="ticketCount">0</span>
            </div>
          </div>
          <div class="card-body p-0 d-flex flex-column tickets-panel__body">
            <!-- Enhanced Filters -->
            <div class="p-3 border-bottom bg-light">
              <div class="input-group mb-3">
                <span class="input-group-text bg-white border-end-0">
                  <i class="ri-search-line text-muted"></i>
                </span>
                <input type="text" class="form-control border-start-0" id="searchTickets" placeholder="<%= Tt.searchPlaceholder || 'Search tickets…' %>">
              </div>
              <div class="mb-0">
                <label class="form-label small fw-semibold mb-1"><%= Tt.filterType || 'Type' %></label>
                <select class="form-select form-select-sm" id="filterType">
                  <option value="all"><%= Tt.filterAllTypes || 'All types' %></option>
                  <option value="order_issue"><%= Tt.typeOrder || 'Order Issue' %></option>
                  <option value="delivery_issue"><%= Tt.typeDelivery || 'Delivery Issue' %></option>
                  <option value="payment_issue"><%= Tt.typeBilling || 'Billing' %></option>
                  <option value="return_request"><%= Tt.typeOther || 'Return Request' %></option>
                  <option value="technical_support"><%= Tt.typeAccount || 'Technical Support' %></option>
                  <option value="general_inquiry"><%= Tt.typeOther || 'General Inquiry' %></option>
                  <option value="other"><%= Tt.typeOther || 'Other' %></option>
                </select>
              </div>
            </div>
            <!-- Status filters -->
            <div class="tickets-filter-bar border-bottom" role="toolbar" aria-label="Filter by status">
              <button type="button" class="tickets-filter-pill active filter-tab" data-status="all">
                <i class="ri-list-check" aria-hidden="true"></i> <%= Tt.filterAll || 'All' %>
              </button>
              <button type="button" class="tickets-filter-pill filter-tab" data-status="new">
                <i class="ri-add-circle-line" aria-hidden="true"></i> <%= Tt.statusNew || 'New' %>
              </button>
              <button type="button" class="tickets-filter-pill filter-tab" data-status="open">
                <i class="ri-mail-open-line" aria-hidden="true"></i> <%= Tt.statusOpen || 'Open' %>
              </button>
              <button type="button" class="tickets-filter-pill filter-tab" data-status="pending">
                <i class="ri-time-line" aria-hidden="true"></i> <%= Tt.statusPending || 'Pending' %>
              </button>
              <button type="button" class="tickets-filter-pill filter-tab" data-status="resolved">
                <i class="ri-check-line" aria-hidden="true"></i> <%= Tt.statusResolved || 'Resolved' %>
              </button>
            </div>
            <!-- Ticket List -->
            <div id="ticketList" class="flex-grow-1 overflow-auto" style="max-height: 100%;"></div>
          </div>
        </div>
      </div>

      <!-- Chat -->
      <div class="col-lg-8">
        <div class="card tickets-chat-card border-0 h-100">
          <!-- Empty State -->
          <div id="emptyState" class="tickets-empty h-100 d-flex flex-column align-items-center justify-content-center p-4 p-md-5">
            <div class="tickets-empty__icon mb-3" aria-hidden="true">
              <i class="ri-message-3-line"></i>
            </div>
            <h2 class="tickets-empty__title mb-2"><%= Tt.noTicketSelected || 'No ticket selected' %></h2>
            <p class="tickets-empty__text text-muted text-center mb-0"><%= Tt.chooseTicket || 'Choose a ticket from the list or open a new one.' %></p>
          </div>

          <div id="chatContainer" class="h-100 d-flex flex-column hidden">
            <div class="tickets-chat-head card-header border-0">
              <div class="d-flex justify-content-between align-items-start gap-2">
                <div class="flex-grow-1 min-w-0">
                  <h2 id="chatTitle" class="tickets-chat-head__title mb-1">Ticket #…</h2>
                  <div id="chatInfo" class="tickets-chat-head__meta small"></div>
                </div>
                <div class="d-flex gap-2 align-items-start flex-shrink-0">
                  <button type="button" class="btn btn-sm btn-tickets-ghost" id="rateTicketBtn" title="Rate this ticket">
                    <i class="ri-star-line me-1" aria-hidden="true"></i>Rate
                  </button>
                </div>
              </div>
            </div>
            
            <!-- Messages Area -->
            <div id="chatMessages" class="flex-grow-1 overflow-auto p-4"></div>
            
            <div class="tickets-composer card-footer border-0 bg-white">
              <div id="attachmentPreview" class="mb-2"></div>
              <div class="input-group">
                <button type="button" class="btn btn-tickets-attach" id="attachImageBtn" title="Attach image">
                  <i class="ri-image-add-line" aria-hidden="true"></i>
                </button>
                <input type="file" id="imageInput" accept="image/*" class="visually-hidden">
                <textarea id="messageInput" class="form-control tickets-composer__input" placeholder="<%= Tt.sendPlaceholder || 'Write a message…' %>" rows="2"></textarea>
                <button type="button" class="btn btn-tickets-primary px-3" id="sendBtn">
                  <i class="ri-send-plane-fill" aria-hidden="true"></i> <%= Tt.send || 'Send' %>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

<!-- Create Ticket Modal -->
<div class="modal fade" id="createTicketModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content tickets-modal">
      <div class="modal-header tickets-modal__header border-0">
        <h5 class="modal-title tickets-modal__title mb-0">
          <i class="ri-add-circle-line me-2" aria-hidden="true"></i>New ticket
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4">
        <form id="createTicketForm">
          <div class="mb-3">
            <label class="form-label fw-semibold">
              Subject <span class="text-danger">*</span>
            </label>
            <input type="text" class="form-control" id="ticketSubject" placeholder="Brief description of your issue..." required>
            <small class="text-muted">Be specific and concise</small>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">
              Type <span class="text-danger">*</span>
            </label>
            <select class="form-select" id="ticketType" required>
              <option value=""><%= Tt.ticketSelectType || 'Select ticket type…' %></option>
              <option value="order_issue"><%= Tt.typeOrder || 'Order Issue' %></option>
              <option value="delivery_issue"><%= Tt.typeDelivery || 'Delivery Issue' %></option>
              <option value="payment_issue"><%= Tt.typeBilling || 'Billing' %></option>
              <option value="return_request"><%= Tt.typeOther || 'Return Request' %></option>
              <option value="technical_support"><%= Tt.typeAccount || 'Technical Support' %></option>
              <option value="general_inquiry"><%= Tt.typeOther || 'General Inquiry' %></option>
              <option value="other"><%= Tt.typeOther || 'Other' %></option>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Related Order (Optional)</label>
            <div class="input-group">
              <span class="input-group-text">
                <i class="ri-shopping-bag-line"></i>
              </span>
              <input type="text" class="form-control" id="relatedOrder" placeholder="Enter order number...">
            </div>
            <small class="text-muted">If this ticket is related to a specific order</small>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">
              Description <span class="text-danger">*</span>
            </label>
            <textarea class="form-control" id="ticketDescription" rows="6" placeholder="Please provide detailed information about your issue..." required></textarea>
            <small class="text-muted">Include all relevant details to help us assist you better</small>
          </div>
        </form>
      </div>
      <div class="modal-footer border-top">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
          <i class="ri-close-line me-1"></i>Cancel
        </button>
        <button type="button" class="btn btn-tickets-primary" id="submitTicketBtn">
          <i class="ri-send-plane-fill me-1" aria-hidden="true"></i>Create ticket
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Rate Ticket Modal -->
<div class="modal fade" id="rateTicketModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content tickets-modal">
      <div class="modal-header tickets-modal__header border-0">
        <h5 class="modal-title tickets-modal__title mb-0">
          <i class="ri-star-line me-2" aria-hidden="true"></i>Rate support
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4">
        <div class="text-center mb-4">
          <div class="rating-stars mb-3" id="ratingStars">
            <i class="ri-star-line star" data-rating="1"></i>
            <i class="ri-star-line star" data-rating="2"></i>
            <i class="ri-star-line star" data-rating="3"></i>
            <i class="ri-star-line star" data-rating="4"></i>
            <i class="ri-star-line star" data-rating="5"></i>
          </div>
          <p class="text-muted" id="ratingText">Click to rate</p>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Comments (Optional)</label>
          <textarea class="form-control" id="ratingComment" rows="3" placeholder="Tell us about your experience..."></textarea>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-tickets-primary" id="submitRatingBtn">Submit rating</button>
      </div>
    </div>
  </div>
</div>
</div>

<%- contentFor('FooterJs') %>
<script src="/assets/libs/sweetalert2/sweetalert2.min.js"></script>
<script src="/socket.io/socket.io.js"></script>
<% var Tj = (typeof translation !== 'undefined' && translation.business && translation.business.js && translation.business.js.tickets) ? translation.business.js.tickets : {}; %>
<script>
  window.__NS_BUSINESS_I18N = window.__NS_BUSINESS_I18N || {};
  window.__NS_BUSINESS_I18N.tickets = {
    noTicketsFound: "<%= Tj.noTicketsFound || 'No tickets found' %>",
    noTicketSelected: "<%= Tj.noTicketSelected || 'No ticket selected' %>",
    newBadge: "<%= Tj.newBadge || 'New' %>",
    orderLabel: "<%= Tj.orderLabel || 'Order' %>",
    sendPlaceholder: "<%= Tj.sendPlaceholder || 'Type your message...' %>",
    ticketClosedPlaceholder: "<%= Tj.ticketClosedPlaceholder || 'This ticket is {status}. You cannot send messages.' %>",
    supportTyping: "<%= Tj.supportTyping || 'Support team is typing...' %>",
    fillRequired: "<%= Tj.fillRequired || 'Please fill in all required fields' %>",
    ticketCreated: "<%= Tj.ticketCreated || 'Ticket created successfully' %>",
    createFailed: "<%= Tj.createFailed || 'Failed to create ticket' %>",
    cannotSendClosed: "<%= Tj.cannotSendClosed || 'Cannot send messages to closed or resolved tickets' %>",
    invalidImageFile: "<%= Tj.invalidImageFile || 'Please select a valid image file' %>",
    uploadFailed: "<%= Tj.uploadFailed || 'Failed to upload image. Please try again.' %>",
    errorSending: "<%= Tj.errorSending || 'Failed to send message.' %>",
    errorLoading: "<%= Tj.errorLoading || 'Error loading tickets' %>",
    justNow: "<%= Tj.justNow || 'Just now' %>",
    minutesAgo: "<%= Tj.minutesAgo || 'm ago' %>",
    hoursAgo: "<%= Tj.hoursAgo || 'h ago' %>",
    daysAgo: "<%= Tj.daysAgo || 'd ago' %>",
    ratingPoor: "<%= Tj.ratingPoor || 'Poor' %>",
    ratingFair: "<%= Tj.ratingFair || 'Fair' %>",
    ratingGood: "<%= Tj.ratingGood || 'Good' %>",
    ratingVeryGood: "<%= Tj.ratingVeryGood || 'Very Good' %>",
    ratingExcellent: "<%= Tj.ratingExcellent || 'Excellent' %>",
    clickToRate: "<%= Tj.clickToRate || 'Click to rate' %>",
    selectRating: "<%= Tj.selectRating || 'Please select a rating' %>",
    thankYouFeedback: "<%= Tj.thankYouFeedback || 'Thank you for your feedback!' %>",
    ratingFailed: "<%= Tj.ratingFailed || 'Failed to submit rating' %>",
    locale: "<%= typeof currentLang !== 'undefined' && currentLang === 'ar' ? 'ar-EG' : 'en-US' %>"
  };
</script>
<script src="/assets/rJS/tickets-business.js"></script>