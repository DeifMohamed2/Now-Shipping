<%- contentFor('FooterJs') %>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>



<!-- Custom JS -->
<script>
  function pdT() {
    return (window.__NS_BUSINESS_I18N && window.__NS_BUSINESS_I18N.pickupDetails) || {};
  }

  function SearchData() {
    const searchInput = document.getElementById('search-input').value;
    fetchOrders(searchInput);
  }

  document.addEventListener('DOMContentLoaded', function() {
    const t = pdT();
    const driverRating = parseInt(document.getElementById('driverRating').value, 10);
    const pickupRating = parseInt(document.getElementById('pickupRating').value, 10);
    const isDriverRated = driverRating > 0;
    const isPickupRated = pickupRating > 0;
    const isPickupComplete = !!(window.__NS_PICKUP_DETAILS__ && window.__NS_PICKUP_DETAILS__.isPickupComplete);
    const driverRater = raterJs({
      starSize: 22,
      rating: driverRating,
      element: document.querySelector("#driver-rater"),
      readOnly: isDriverRated || !isPickupComplete,
      rateCallback: function(rate, done) {
        if (!isDriverRated && isPickupComplete) {
          this.setRating(rate);
          document.getElementById('driverRating').value = rate;
          done();
        } else {
          done();
        }
      }
    });

    const serviceRater = raterJs({
      starSize: 22,
      rating: pickupRating,
      element: document.querySelector("#service-rater"),
      readOnly: isPickupRated || !isPickupComplete,
      rateCallback: function(rate, done) {
        if (!isPickupRated && isPickupComplete) {
          this.setRating(rate);
          document.getElementById('pickupRating').value = rate;
          done();
        } else {
          done();
        }
      }
    });
  });

  async function submitRating() {
    const t = pdT();
    const driverRating = parseInt(document.getElementById('driverRating').value, 10);
    const pickupRating = parseInt(document.getElementById('pickupRating').value, 10);
    const pickupNumber = '<%= pickup.pickupNumber %>';
    const isPickupComplete = !!(window.__NS_PICKUP_DETAILS__ && window.__NS_PICKUP_DETAILS__.isPickupComplete);
    if (!isPickupComplete) {
      Swal.fire({
        icon: 'error',
        title: t.swalNotFinalTitle,
        text: t.swalNotFinalText,
      });
      return;
    }
    if (driverRating === 0 || pickupRating === 0) {
      Swal.fire({
        icon: 'error',
        title: t.swalRateRequiredTitle,
        text: t.swalRateRequiredText,
      });
      return;
    }

    try {
      const response = await fetch(`/business/pickup-details/${pickupNumber}/rate-pickup`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          driverRating,
          pickupRating,
        }),
      });
      const data = await response.json();
      if (response.ok) {
        Swal.fire({
          icon: 'success',
          title: t.swalSuccessTitle,
          text: data.message,
        });
      } else {
        Swal.fire({
          icon: 'error',
          title: t.swalErrorTitle,
          text: data.error || t.unknownError,
        });
      }
    } catch (error) {
      console.error('Error submitting rating:', error);
    }
  }

  async function fetchOrders(search = "") {
    const t = pdT();
    try {
      const tableBody = document.getElementById("TBody");
      const NoResult = document.querySelector(".noresult");

      tableBody.innerHTML = `
        <tr>
          <td colspan="5" class="text-center">
            <div class="spinner-border text-primary" role="status">
              <span class="visually-hidden">${t.visuallyHiddenLoading}</span>
            </div>
          </td>
        </tr>
      `;

      const response = await fetch(`/business/pickup-details/<%= pickup.pickupNumber %>/get-pickedup-orders?search=${search}`);
      const pickup = await response.json();
      if (response.ok) {
        tableBody.innerHTML = "";
        NoResult.style.display = "none";
        if (pickup.ordersPickedUp.length === 0) {
          NoResult.style.display = "block";
          return;
        }
        populateOrdersTable(pickup.ordersPickedUp);
      } else {
        Swal.fire({
          icon: 'error',
          title: t.swalErrorTitle,
          text: `${t.swalFetchErrorPrefix} ${pickup.error || t.unknownError}`,
        });
      }
    } catch (error) {
      console.error("Error fetching orders:", error);
    }
  }

  function mapOrderType(raw) {
    const t = pdT();
    const key = String(raw || '').toLowerCase().replace(/\s+/g, '');
    const map = {
      deliver: t.typeDeliver,
      delivery: t.typeDeliver,
      return: t.typeReturn,
      exchange: t.typeExchange,
    };
    return map[key] || raw || t.notAvailable;
  }

  function populateOrdersTable(orders) {
    const t = pdT();
    const tableBody = document.getElementById("TBody");
    tableBody.innerHTML = "";
    orders.forEach(order => {
      const row = document.createElement("tr");
      const statusInfo = getOrderStatusInfo(order.orderStatus);
      const amt = order.orderShipping && order.orderShipping.amount != null ? order.orderShipping.amount : 0;
      row.innerHTML = `
        <td><a href="/business/order-details/${order.orderNumber}" class="fw-medium link-primary fs-15">${order.orderNumber}</a></td>
        <td>${mapOrderType(order.orderShipping && order.orderShipping.orderType)}</td>
        <td><span class="badge ${statusInfo.badge} fs-13">${statusInfo.text}</span></td>
        <td>${(order.orderCustomer && order.orderCustomer.zone) || t.notAvailable}</td>
        <td>${amt} ${t.currencyCode}</td>
      `;
      tableBody.appendChild(row);
    });
  }

  function getOrderStatusInfo(status) {
    const t = pdT();
    const statusMap = {
      new: { badge: 'bg-info', text: t.orderStatusNew },
      pendingPickup: { badge: 'bg-info', text: t.orderStatusPendingPickup },
      pickedUp: { badge: 'bg-primary', text: t.orderStatusPickedUp },
      inStock: { badge: 'bg-success', text: t.orderStatusInStock },
      inProgress: { badge: 'bg-warning', text: t.orderStatusInProgress },
      headingToCustomer: { badge: 'bg-info', text: t.orderStatusHeadingToCustomer },
      headingToYou: { badge: 'bg-info', text: t.orderStatusHeadingToYou },
      completed: { badge: 'bg-success', text: t.orderStatusCompleted },
      canceled: { badge: 'bg-danger', text: t.orderStatusCanceled },
      rejected: { badge: 'bg-danger', text: t.orderStatusRejected },
      returned: { badge: 'bg-warning', text: t.orderStatusReturned },
      terminated: { badge: 'bg-danger', text: t.orderStatusTerminated },
    };
    return statusMap[status] || { badge: 'bg-secondary', text: t.orderStatusUnknown };
  }

  function getPickupStatusInfo(status) {
    const t = pdT();
    const statusMap = {
      new: { badge: 'bg-info', text: t.pickupStatusNew },
      pendingPickup: { badge: 'bg-info', text: t.pickupStatusPendingPickup },
      driverAssigned: { badge: 'bg-primary', text: t.pickupStatusDriverAssigned },
      pickedUp: { badge: 'bg-primary', text: t.pickupStatusPickedUp },
      inStock: { badge: 'bg-success', text: t.pickupStatusInStock },
      inProgress: { badge: 'bg-warning', text: t.pickupStatusInProgress },
      completed: { badge: 'bg-success', text: t.pickupStatusCompleted },
      canceled: { badge: 'bg-danger', text: t.pickupStatusCanceled },
      rejected: { badge: 'bg-danger', text: t.pickupStatusRejected },
      returned: { badge: 'bg-warning', text: t.pickupStatusReturned },
      terminated: { badge: 'bg-danger', text: t.pickupStatusTerminated },
    };
    return statusMap[status] || { badge: 'bg-secondary', text: t.pickupStatusUnknown };
  }

  document.addEventListener('DOMContentLoaded', function() {
    const pickupStatus = document.getElementById('pickupStatus');
    const pickupStatusInfo = getPickupStatusInfo('<%= pickup.picikupStatus %>');
    pickupStatus.innerHTML = `<span class="badge ${pickupStatusInfo.badge}">${pickupStatusInfo.text}</span>`;
  });

  document.addEventListener("DOMContentLoaded", () => fetchOrders());

  async function cancelPickup(pickupId) {
    const t = pdT();
    Swal.fire({
      title: t.cancelConfirmTitle,
      text: t.cancelConfirmText,
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#3085d6',
      cancelButtonColor: '#d33',
      confirmButtonText: t.cancelConfirmYes,
      cancelButtonText: t.cancelConfirmNo,
    })
    .then(async (result) => {
      if (result.isConfirmed) {
        const response = await fetch(
          `/business/pickup/cancel-pickup/${pickupId}`,
          {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
            },
          }
        );

        let data = {};
        try {
          data = await response.json();
        } catch (_) {
          data = {};
        }

        if (response.ok) {
          Swal.fire({
            title: t.cancelSuccessTitle,
            text: data.message || t.cancelSuccessText,
            icon: 'success',
            confirmButtonText: t.ok,
          }).then(() => {
            window.location.href = '/business/pickups';
          });
        } else {
          Swal.fire({
            title: t.cancelFailedTitle,
            text: data.error || t.cancelFailedText,
            icon: 'error',
            confirmButtonText: t.ok,
          });
        }
      }
    })
    .catch((error) => {
      console.error('Error:', error);
      Swal.fire({
        title: t.cancelErrorTitle,
        text: t.cancelErrorText,
        icon: 'error',
        confirmButtonText: t.ok,
      });
    });
  }

  // ─── Edit / Delete handlers for details page ────────────────────────────────

  async function openEditPickupDetails() {
    const t = pdT();
    const pickupId   = '<%= pickup._id %>';
    const pickupNumber = '<%= pickup.pickupNumber %>';

    // Build a simple modal with the editable fields
    const pickup = {
      numberOfOrders : <%= pickup.numberOfOrders %>,
      phoneNumber    : '<%= (pickup.phoneNumber || '').replace(/'/g, "\\'") %>',
      isFragileItems : <%= pickup.isFragileItems ? 'true' : 'false' %>,
      isLargeItems   : <%= pickup.isLargeItems   ? 'true' : 'false' %>,
      pickupNotes    : '<%= (pickup.pickupNotes || '').replace(/'/g, "\\'").replace(/\n/g, ' ') %>',
      pickupDate     : '<%= pickup.pickupDate ? new Date(pickup.pickupDate).toISOString().split('T')[0] : '' %>',
      pickupAddressId: '<%= pickup.pickupAddressId || '' %>',
    };

    const fragileLabel = t.badgeFragile || 'Fragile';
    const largeLabel   = t.badgeLarge   || 'Large';

    const { value: formValues, isConfirmed } = await Swal.fire({
      title: t.editPickup || 'Edit pickup',
      html: `
        <div class="text-start">
          <div class="mb-3">
            <label class="form-label fw-semibold">${t.numberOfOrders || 'Number of orders'}</label>
            <input id="swal-numberOfOrders" type="number" min="1" class="form-control swal2-input w-100" value="${pickup.numberOfOrders}">
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">${t.addressContactPhone || 'Contact phone'}</label>
            <input id="swal-phone" type="text" class="form-control swal2-input w-100" value="${pickup.phoneNumber}">
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">${t.pickupDate || 'Pickup date'}</label>
            <input id="swal-date" type="date" class="form-control swal2-input w-100" value="${pickup.pickupDate}">
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">${t.pickupNotes || 'Notes'}</label>
            <textarea id="swal-notes" class="form-control swal2-textarea w-100" rows="2">${pickup.pickupNotes}</textarea>
          </div>
          <div class="mb-3 d-flex gap-4">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="swal-fragile" ${pickup.isFragileItems ? 'checked' : ''}>
              <label class="form-check-label" for="swal-fragile">${fragileLabel}</label>
            </div>
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="swal-large" ${pickup.isLargeItems ? 'checked' : ''}>
              <label class="form-check-label" for="swal-large">${largeLabel}</label>
            </div>
          </div>
        </div>`,
      showCancelButton: true,
      confirmButtonText: t.submitRating ? (t.editPickup || 'Save') : 'Save',
      cancelButtonText: t.cancelConfirmNo || 'Cancel',
      confirmButtonColor: '#0d6efd',
      focusConfirm: false,
      preConfirm: () => ({
        numberOfOrders: document.getElementById('swal-numberOfOrders').value,
        phoneNumber:    document.getElementById('swal-phone').value,
        pickupDate:     document.getElementById('swal-date').value,
        pickupNotes:    document.getElementById('swal-notes').value,
        isFragileItems: document.getElementById('swal-fragile').checked ? 'true' : 'false',
        isLargeItems:   document.getElementById('swal-large').checked   ? 'true' : 'false',
        pickupAddressId: pickup.pickupAddressId,
      }),
    });

    if (!isConfirmed || !formValues) return;

    try {
      const res = await fetch(`/business/pickup/update-pickup/${pickupId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formValues),
      });
      const data = await res.json().catch(() => ({}));
      if (res.ok) {
        await Swal.fire({ icon: 'success', title: t.editSuccessTitle || 'Updated', text: t.editSuccessText || '', timer: 2000, showConfirmButton: false });
        window.location.reload();
      } else {
        Swal.fire({ icon: 'error', title: t.editFailedTitle || 'Error', text: data.error || t.editFailedText || '' });
      }
    } catch (err) {
      console.error('openEditPickupDetails error:', err);
      Swal.fire({ icon: 'error', title: t.editFailedTitle || 'Error', text: err.message });
    }
  }

  async function deletePickupDetails(pickupId) {
    const t = pdT();
    const result = await Swal.fire({
      title: t.confirmDeleteTitle || 'Delete this pickup?',
      text: t.confirmDeleteText || 'This action cannot be undone.',
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#d33',
      cancelButtonColor: '#6c757d',
      confirmButtonText: t.confirmDeleteYes || 'Yes, delete',
      cancelButtonText: t.confirmDeleteNo  || 'Keep',
    });
    if (!result.isConfirmed) return;
    try {
      const res = await fetch(`/business/pickup/delete-pickup/${pickupId}`, { method: 'DELETE' });
      const data = await res.json().catch(() => ({}));
      if (res.ok) {
        await Swal.fire({ icon: 'success', title: t.deleteSuccessTitle || 'Deleted', text: t.deleteSuccessText || '', timer: 2000, showConfirmButton: false });
        window.location.href = '/business/pickups';
      } else {
        Swal.fire({ icon: 'error', title: t.deleteFailedTitle || 'Error', text: data.error || t.deleteFailedText || '' });
      }
    } catch (err) {
      console.error('deletePickupDetails error:', err);
      Swal.fire({ icon: 'error', title: t.deleteFailedTitle || 'Error', text: err.message });
    }
  }
</script>

