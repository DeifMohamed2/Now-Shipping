async function openEditPickup(pickupId, pickupNumber) {
  const I = __pickupI18n();
  // Switch modal to edit mode
  const modal = document.getElementById('showModal');
  const modalTitle = document.getElementById('pickup-modal-title');
  const submitBtn = document.getElementById('add-btn');
  const idField = document.getElementById('id-field');
  if (modalTitle) modalTitle.textContent = I.modalEditTitle || 'Edit pickup';
  if (submitBtn) submitBtn.textContent = I.editPickup || 'Save changes';
  if (idField) idField.value = pickupId;

  try {
    const res = await fetch(`/business/pickup-details/${pickupNumber}?json=1`, {
      headers: { 'Accept': 'application/json' }
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Failed to load pickup');
    const p = data.pickup || data;
    const fp = window._pickupFlatpickr;

    // Prefill fields
    const numEl = document.getElementById('numberOfOrders');
    const phoneEl = document.getElementById('contact-info');
    const fragileEl = document.getElementById('isFragileItems');
    const largeEl = document.getElementById('isLargeItems');
    const notesEl = document.getElementById('pickupNotes');
    const addrSel = document.getElementById('pickup-address-select');

    if (numEl) numEl.value = p.numberOfOrders || '';
    if (phoneEl) phoneEl.value = p.phoneNumber || '';
    if (fragileEl) fragileEl.checked = !!p.isFragileItems;
    if (largeEl) largeEl.checked = !!p.isLargeItems;
    if (notesEl) notesEl.value = p.pickupNotes || '';
    if (addrSel && p.pickupAddressId) addrSel.value = p.pickupAddressId;

    if (fp && p.pickupDate) {
      fp.setDate(new Date(p.pickupDate), true);
      fp.config.minDate = null; // allow existing past/today date for edit
    }

    const bsModal = bootstrap.Modal.getOrCreateInstance(modal);
    bsModal.show();
  } catch (err) {
    console.error('openEditPickup error:', err);
    Swal.fire({ icon: 'error', title: I.editFailedTitle || 'Error', text: err.message });
  }
}

async function confirmDeletePickup(pickupId) {
  const I = __pickupI18n();
  const result = await Swal.fire({
    title: I.confirmDeleteTitle || 'Delete this pickup?',
    text: I.confirmDeleteText || 'This action cannot be undone.',
    icon: 'warning',
    showCancelButton: true,
    confirmButtonColor: '#d33',
    cancelButtonColor: '#6c757d',
    confirmButtonText: I.confirmDeleteYes || 'Yes, delete',
    cancelButtonText: I.confirmDeleteNo || 'Keep',
  });
  if (!result.isConfirmed) return;
  try {
    const res = await fetch(`/business/pickup/delete-pickup/${pickupId}`, { method: 'DELETE' });
    const data = await res.json();
    if (res.ok) {
      await Swal.fire({ icon: 'success', title: I.deleteSuccessTitle || 'Deleted', text: I.deleteSuccessText || '', timer: 2000, showConfirmButton: false });
      fetchPickups(currentTabType, currentPage);
    } else {
      Swal.fire({ icon: 'error', title: I.deleteFailedTitle || 'Delete failed', text: data.error || I.deleteFailedText || '' });
    }
  } catch (err) {
    console.error('confirmDeletePickup error:', err);
    Swal.fire({ icon: 'error', title: I.deleteFailedTitle || 'Error', text: err.message });
  }
}

async function confirmCancelPickupList(pickupId) {
  const I = __pickupI18n();
  const result = await Swal.fire({
    title: I.cancelConfirmTitle || 'Cancel this pickup?',
    text: I.cancelConfirmText || 'The pickup will be marked as cancelled.',
    icon: 'warning',
    showCancelButton: true,
    confirmButtonColor: '#3085d6',
    cancelButtonColor: '#d33',
    confirmButtonText: I.cancelConfirmYes || 'Yes, cancel pickup',
    cancelButtonText: I.cancelConfirmNo || 'Keep pickup',
  });
  if (!result.isConfirmed) return;
  try {
    const res = await fetch(`/business/pickup/cancel-pickup/${pickupId}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
    });
    const data = await res.json();
    if (res.ok) {
      await Swal.fire({ icon: 'success', title: I.cancelSuccessTitle || 'Cancelled', text: I.cancelSuccessText || '', timer: 2000, showConfirmButton: false });
      fetchPickups(currentTabType, currentPage);
    } else {
      Swal.fire({ icon: 'error', title: I.cancelFailedTitle || 'Cannot cancel', text: data.error || I.cancelFailedText || '' });
    }
  } catch (err) {
    console.error('confirmCancelPickupList error:', err);
    Swal.fire({ icon: 'error', title: I.cancelFailedTitle || 'Error', text: err.message });
  }
}

