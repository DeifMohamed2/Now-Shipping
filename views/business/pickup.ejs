<style>
  /* Fix for dropdown menus in tables */
  .dropdown-fix .dropdown-menu {
    position: fixed !important;
    z-index: 1050 !important;
  }

  html[dir='rtl'] #orderList .pickups-table-wrap .dropdown-fix .dropdown-menu {
    text-align: right;
  }

  /* Keep wide tables inside the card — scroll here, not the whole page */
  #orderList.card {
    min-width: 0;
    max-width: 100%;
    overflow-x: hidden;
  }

  #orderList > .card-body {
    min-width: 0;
  }

  #orderList .card-body.pt-0 > div {
    min-width: 0;
    max-width: 100%;
  }

  #orderList .pickups-table-wrap {
    width: 100%;
    max-width: 100%;
    min-width: 0;
    min-height: 280px;
    max-height: 70vh;
    overflow-x: auto;
    overflow-y: auto;
    position: relative;
    -webkit-overflow-scrolling: touch;
  }

  /* Cancel Velzon .table-card negative margins if class is present */
  #orderList .pickups-table-wrap.table-responsive {
    margin-left: 0;
    margin-right: 0;
  }

  .btn-close {
    filter: brightness(0) invert(1);
  }

  .form-control:focus,
  .form-check-input:focus {
    border-color: #F39720;
    box-shadow: 0 0 0 0.25rem rgba(76, 175, 80, 0.25);
  }

  .form-label {
    font-weight: 500;
    color: #333;
  }

  .readonly-field {
    background-color: #f8f9fa;
    border-left: none;
    border-inline-start: 4px solid #F39720;
  }

  .feature-box {
    transition: all 0.3s ease;
    border: 1px solid #dee2e6;
    border-radius: 8px;
  }

  .feature-box:hover {
    background-color: #f0f9f0 !important;
    border-color: #F39720;
  }

  .feature-box .form-check-input:checked {
    background-color: #F39720;
    border-color: #F39720;
  }

  .btn-success {
    background-color: #F39720;
    border-color: #F39720;
  }

  .btn-success:hover {
    background-color: #F39720;
    border-color: #F39720;
  }

  .order-warning {
    display: none;
    color: #ff9800;
    font-size: 0.875rem;
    margin-top: 0.25rem;
  }

  .flatpickr-input {
    background-color: white !important;
  }

  .contact-info-note {
    font-size: 0.8rem;
    color: #666;
    margin-top: 0.25rem;
  }

  .required-asterisk {
    color: #dc3545;
    margin-inline-start: 2px;
  }

  html[dir='rtl'] .pickup-modal .form-check-label.d-flex {
    flex-direction: row-reverse;
    text-align: right;
  }

  html[dir='rtl'] .pickup-modal .feature-box .form-check {
    text-align: right;
  }

  html[dir='rtl'] .pickup-modal .contact-info-note,
  html[dir='rtl'] .pickup-modal .contact-info-note a {
    text-align: right;
  }

  /* Velzon .search-box assumes LTR icon placement */
  html[dir='rtl'] #orderList .search-box .form-control {
    padding-left: var(--bs-border-radius-lg, 0.5rem);
    padding-right: 40px;
  }
  html[dir='rtl'] #orderList .search-box .search-icon {
    left: auto;
    right: 13px;
  }
    
    .noresult {
      padding: 2rem;
      text-align: center;
    }
    
    /* Additional styling to match your design */
    .form-check {
      min-height: 1.5rem;
    }
    
    .form-check-input {
      width: 1em;
      height: 1em;
      margin-top: 0.25em;
      vertical-align: top;
    }

.pagination-wrap { padding-top: 10px; }
</style>
<div class="row g-3">
  <div class="col-12">
    <div class="card" id="orderList">
      <div class="card-header border-0">
        <div class="row align-items-center gy-3">
          <div class="col-sm">
            <h5 class="card-title mb-0"><%= Pip.listHeading || Pip.title || 'Pickups' %></h5>
          </div>
          <div class="col-sm-auto">
            <div class="d-flex gap-1 flex-wrap">
              <button type="button" class="btn btn-success add-btn" data-bs-toggle="modal" id="create-btn" data-bs-target="#showModal"><i class="ri-add-line align-bottom me-1"></i> <%= Pip.createPickup || 'Create pickup' %></button>
