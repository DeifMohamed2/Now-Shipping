  function getPickupStatusDetails(status) {
    const I = __pickupI18n();
    let badgeClass = '';
    let statusText = '';

    if (status === 'new') {
      badgeClass = 'bg-primary-subtle text-primary';
      statusText = I.statusNew || 'New';
    } else if (status === 'driverAssigned') {
      badgeClass = 'bg-secondary-subtle text-secondary';
      statusText = I.statusDriverAssigned || 'Driver assigned';
    } else if (status === 'pickedUp') {
      badgeClass = 'bg-info-subtle text-info';
      statusText = I.statusPickedUp || 'Picked up';
    } else if (status === 'inStock') {
      badgeClass = 'bg-warning-subtle text-warning';
      statusText = I.statusInStock || 'In stock';
    } else if (status === 'inProgress') {
      badgeClass = 'bg-success-subtle text-success';
      statusText = I.statusInProgress || 'In progress';
    } else if (status === 'completed') {
      badgeClass = 'bg-success-subtle text-success';
      statusText = I.statusCompleted || 'Completed';
    } else if (status === 'canceled') {
      badgeClass = 'bg-danger-subtle text-danger';
      statusText = I.statusCanceled || 'Canceled';
    } else if (status === 'rejected') {
      badgeClass = 'bg-danger-subtle text-danger';
      statusText = I.statusRejected || 'Declined by driver';
    } else if (status === 'returned') {
      badgeClass = 'bg-danger-subtle text-danger';
      statusText = I.statusReturned || 'Returned';
    } else if (status === 'terminated') {
      badgeClass = 'bg-danger-subtle text-danger';
      statusText = I.statusTerminated || 'Terminated';
    } else {
      statusText = I.statusUnknown || 'Unknown';
    }

    return { badgeClass, statusText };
  }

