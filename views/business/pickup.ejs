      if (selectedOption && selectedOption.textContent) {
        pickupLocationInput.value = selectedOption.textContent.replace(defSuffix, '').trim();
      }
      
      // Update phone number based on selected address
      if (selectedOption && selectedOption.value && selectedOption.value !== '') {
        const addressId = selectedOption.value === 'default' ? null : selectedOption.value;
