                      <div>
                      <strong><%= Pip.fragileTitle || 'Fragile items' %></strong>
                      <div class="small text-muted"><%= Pip.fragileSub || '' %></div>
                      </div>
                    </label>
                    </div>
                  </div>
                  </div>
                  <div class="col-md-6 mb-3">
                  <div class="feature-box p-3 bg-light h-100">
                    <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="isLargeItems" id="large-item" value="true">
                    <label class="form-check-label d-flex align-items-center pickup-feature-label" for="large-item">
                      <i class="ri-truck-line me-2 text-primary"></i>
                      <div>
                      <strong><%= Pip.largeTitle || 'Large items' %></strong>
                      <div class="small text-muted"><%= Pip.largeSub || '' %></div>
                      </div>
