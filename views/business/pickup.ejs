                <select class="form-control" data-choices data-choices-search-false name="choices-single-default" id="idStatus">
                  <option value=""><%= Pip.filterStatus || 'Status' %></option>
                  <option value="all" selected><%= Pip.filterAll || 'All' %></option>
                  <option value="Pending"><%= Pip.tabPending || 'Pending' %></option>
                  <option value="Inprogress"><%= Pip.tabInProgress || 'In Progress' %></option>
                  <option value="Cancelled"><%= Pip.tabCancelled || 'Cancelled' %></option>
                  <option value="Pickups"><%= Pip.tabAll || 'Pickups' %></option>
                  <option value="Returns"><%= Pip.tabReturns || 'Returns' %></option>
                  <option value="Delivered"><%= Pip.tabCompleted || 'Delivered' %></option>
                </select>
              </div>
            </div>
            <!--end col-->
            <div class="col-xxl-2 col-sm-4">
              <div>
                <select class="form-control" data-choices data-choices-search-false name="choices-single-default" id="idPayment">
                  <option value=""><%= Pip.filterPayment || 'Payment' %></option>
                  <option value="all" selected><%= Pip.paymentAll || 'All' %></option>
                  <option value="Mastercard"><%= Pip.paymentMastercard || 'Mastercard' %></option>
                  <option value="Paypal"><%= Pip.paymentPaypal || 'PayPal' %></option>
                  <option value="Visa"><%= Pip.paymentVisa || 'Visa' %></option>
                  <option value="COD"><%= Pip.paymentCOD || 'COD' %></option>
                </select>
              </div>
            </div>
            <!--end col-->
            <div class="col-xxl-1 col-sm-4">
              <div>
                <button type="button" class="btn btn-primary w-100" onclick="SearchData();"> <i class="ri-equalizer-fill me-1 align-bottom"></i>
                  <%= Pip.filterFilters || 'Filters' %>
                </button>
              </div>
            </div>
            <!--end col-->
          </div>
          <!--end row-->
        </form>
      </div>
      <div class="card-body pt-0">
        <div>
            <ul class="nav nav-tabs nav-tabs-custom nav-success mb-3" role="tablist">
            <li class="nav-item">
              <button class="btn btn-link nav-link active All py-3" data-bs-toggle="tab" id="All" role="tab" aria-selected="true" onClick="filterPickups('Upcoming')">
