    // Form submission — handles both CREATE and EDIT based on #id-field
    const createPickupForm = document.querySelector('.tablelist-form');
    createPickupForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const I = __pickupI18n();
      const formData = new FormData(createPickupForm);
      const data = Object.fromEntries(formData.entries());
      const pickupId = (document.getElementById('id-field') || {}).value || '';
      const isEdit = !!pickupId;

      try {
        const url = isEdit
