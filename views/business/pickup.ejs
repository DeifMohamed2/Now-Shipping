        } else if (selectedOption.value === 'default' && userPickupAddresses && userPickupAddresses.length > 0) {
          // Use default address phone
          const defaultAddress = userPickupAddresses.find(addr => addr.isDefault) || userPickupAddresses[0];
          if (defaultAddress && defaultAddress.pickupPhone && contactInfoInput) {
            contactInfoInput.value = defaultAddress.pickupPhone;
