<% 
  var PipPage = (typeof translation !== 'undefined' && translation.business && translation.business.pages && translation.business.pages.pickup) ? translation.business.pages.pickup : {};
  var PipJs = (typeof translation !== 'undefined' && translation.business && translation.business.js && translation.business.js.pickup) ? translation.business.js.pickup : {};
