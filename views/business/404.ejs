<%- contentFor('HeaderCss') %>
<style>
  .error-404-wrap {
    min-height: calc(100vh - 160px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
  }

  .error-404-card {
    border: none;
    border-radius: 24px;
    box-shadow: 0 8px 40px rgba(15, 23, 42, 0.10);
    overflow: hidden;
    max-width: 520px;
    width: 100%;
  }

  .error-404-card .card-body {
    padding: 3rem 2.5rem 2.5rem;
    text-align: center;
  }

  .error-404-icon-wrap {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(243,151,32,0.15) 0%, rgba(243,151,32,0.05) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.75rem;
    border: 2px solid rgba(243,151,32,0.2);
  }

  .error-404-icon-wrap i {
    font-size: 2.75rem;
    color: #F39720;
  }

  .error-404-code {
    font-size: clamp(4rem, 15vw, 7rem);
    font-weight: 900;
    line-height: 1;
    background: linear-gradient(135deg, #F39720 0%, #e08a18 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
    letter-spacing: -0.04em;
  }

  .error-404-title {
    font-size: 1.45rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 0.75rem;
  }

  .error-404-sub {
    color: #64748b;
    font-size: 0.97rem;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .error-404-url-badge {
    display: inline-block;
    background: #f1f5f9;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 0.4rem 0.85rem;
    font-size: 0.8rem;
    font-family: monospace;
    color: #475569;
    margin-bottom: 2rem;
    word-break: break-all;
    max-width: 100%;
  }

  .error-404-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .error-404-actions .btn {
    border-radius: 12px;
    padding: 0.65rem 1.5rem;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.25s ease;
  }

  .error-404-actions .btn-primary {
    background-color: #F39720;
    border: none;
    color: #fff;
  }

  .error-404-actions .btn-primary:hover {
    background-color: #e08a18;
    transform: translateY(-2px);
    box-shadow: 0 4px 14px rgba(243,151,32,0.35);
  }

  .error-404-actions .btn-outline-secondary {
    border-color: #cbd5e1;
    color: #475569;
  }

  .error-404-actions .btn-outline-secondary:hover {
    background: #f8fafc;
    border-color: #94a3b8;
    transform: translateY(-2px);
  }

  /* RTL */
  html[dir='rtl'] .error-404-card .card-body {
    font-family: 'Cairo', 'Tajawal', sans-serif;
  }
</style>

<%- contentFor('body') %>
<div class="error-404-wrap">
  <div class="error-404-card card">
    <div class="card-body">
      <!-- Icon -->
      <div class="error-404-icon-wrap">
        <i class="ri-road-map-line"></i>
      </div>

      <!-- 404 number -->
      <div class="error-404-code">404</div>

      <!-- Message -->
      <h2 class="error-404-title">
        <%= (typeof translation !== 'undefined' && translation.business && translation.business.pages && translation.business.pages.notFound) ? (translation.business.pages.notFound.title || 'Page not found') : 'Page not found' %>
      </h2>
      <p class="error-404-sub">
        <%= (typeof translation !== 'undefined' && translation.business && translation.business.pages && translation.business.pages.notFound) ? (translation.business.pages.notFound.subtitle || 'The page you are looking for doesn\'t exist or has been moved.') : "The page you are looking for doesn't exist or has been moved." %>
      </p>

      <!-- URL hint -->
      <% if (typeof requestedUrl !== 'undefined' && requestedUrl) { %>
      <div class="error-404-url-badge"><%= requestedUrl %></div>
      <% } %>

      <!-- Actions -->
      <div class="error-404-actions">
        <a href="/business/dashboard" class="btn btn-primary">
          <i class="ri-home-5-line me-1"></i>
          <%= (typeof translation !== 'undefined' && translation.business && translation.business.pages && translation.business.pages.notFound) ? (translation.business.pages.notFound.btnHome || 'Go to Dashboard') : 'Go to Dashboard' %>
        </a>
        <button onclick="history.back()" class="btn btn-outline-secondary">
          <i class="ri-arrow-go-back-line me-1"></i>
          <%= (typeof translation !== 'undefined' && translation.business && translation.business.pages && translation.business.pages.notFound) ? (translation.business.pages.notFound.btnBack || 'Go back') : 'Go back' %>
        </button>
      </div>
    </div>
  </div>
</div>
