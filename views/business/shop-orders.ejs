<%- contentFor('HeaderCss') %>
<% if ((typeof direction !== 'undefined' && direction === 'rtl') || (typeof currentLang !== 'undefined' && currentLang === 'ar')) { %>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet">
<% } %>
<link href="/assets/libs/sweetalert2/sweetalert2.min.css" rel="stylesheet" type="text/css" />
<link rel="stylesheet" href="/assets/rCSS/business.css">
<% if ((typeof direction !== 'undefined' && direction === 'rtl') || (typeof currentLang !== 'undefined' && currentLang === 'ar')) { %>
<style>
  .shop-orders-page .card, .shop-orders-page .table { font-family: 'Tajawal', 'Cairo', sans-serif; }
  html[dir="rtl"] .shop-orders-stat-label { text-transform: none; letter-spacing: normal; }
</style>
<% } %>

<%- contentFor('body') %>
<% var So = (typeof translation !== 'undefined' && translation.business && translation.business.pages && translation.business.pages.shopOrders) ? translation.business.pages.shopOrders : {}; %>
<% var soLocale = So.locale || ((typeof currentLang !== 'undefined' && currentLang === 'ar') ? 'ar-EG' : 'en-US'); %>
<% var soCurrency = So.currency || 'EGP'; %>
<div class="shop-orders-page">
<div class="row g-2">
  <div class="col-12 d-flex justify-content-end">
    <a href="/business/shop" class="btn btn-primary">
      <i class="ri-shopping-bag-line align-middle me-1"></i> <%= So.continueShopping || 'Continue Shopping' %>
    </a>
  </div>
</div>

<!-- Stats Cards -->
<div class="row mb-3 g-3">
  <div class="col-12 col-sm-6 col-xl-3">
    <div class="card card-animate">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <p class="shop-orders-stat-label text-uppercase fw-medium text-muted mb-0"><%= So.activeOrders || 'Active Orders' %></p>
          </div>
          <div class="flex-shrink-0">
            <h5 class="text-primary mb-0" id="activeCount">0</h5>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-12 col-sm-6 col-xl-3">
    <div class="card card-animate">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <p class="shop-orders-stat-label text-uppercase fw-medium text-muted mb-0"><%= So.inTransit || 'In Transit' %></p>
          </div>
          <div class="flex-shrink-0">
            <h5 class="text-info mb-0" id="inTransitCount">0</h5>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-12 col-sm-6 col-xl-3">
    <div class="card card-animate">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <p class="shop-orders-stat-label text-uppercase fw-medium text-muted mb-0"><%= So.statDelivered || 'Delivered' %></p>
          </div>
          <div class="flex-shrink-0">
            <h5 class="text-success mb-0" id="deliveredCount">0</h5>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-12 col-sm-6 col-xl-3">
    <div class="card card-animate">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-grow-1">
            <p class="shop-orders-stat-label text-uppercase fw-medium text-muted mb-0"><%= So.statTotalSpent || 'Total Spent' %></p>
          </div>
          <div class="flex-shrink-0">
            <h5 class="text-warning mb-0 ltr-embed" id="totalSpent"><%= soCurrency %> 0</h5>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Filters -->
<div class="row mb-3">
  <div class="col-12">
    <div class="card">
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-4">
            <label class="form-label"><%= So.filterByStatus || 'Filter by Status' %></label>
            <select class="form-select" id="statusFilter">
              <option value=""><%= So.allStatus || 'All Status' %></option>
              <option value="pending"><%= So.filterPending || 'Pending' %></option>
              <option value="confirmed"><%= So.filterConfirmed || 'Confirmed' %></option>
              <option value="processing"><%= So.filterProcessing || 'Processing' %></option>
              <option value="ready"><%= So.filterReady || 'Ready' %></option>
              <option value="assigned"><%= So.filterAssigned || 'Assigned to Courier' %></option>
              <option value="picked_up"><%= So.filterPickedUp || 'Picked Up' %></option>
              <option value="in_transit"><%= So.filterInTransit || 'In Transit' %></option>
              <option value="delivered"><%= So.filterDelivered || 'Delivered' %></option>
              <option value="cancelled"><%= So.filterCancelled || 'Cancelled' %></option>
            </select>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Orders List -->
<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th><%= So.colOrderNum || 'Order #' %></th>
                <th><%= So.colDate || 'Date' %></th>
                <th><%= So.colItems || 'Items' %></th>
                <th><%= So.colTotal || 'Total' %></th>
                <th><%= So.colStatus || 'Status' %></th>
                <th><%= So.colCourier || 'Courier' %></th>
                <th><%= So.colActions || 'Actions' %></th>
              </tr>
            </thead>
            <tbody id="ordersTableBody">
              <tr>
                <td colspan="7" class="text-center">
                  <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden"><%= So.visuallyHiddenLoading || 'Loading…' %></span>
                  </div>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Order Details Modal -->
<div class="modal fade" id="orderModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><%= So.modalTitle || 'Order Details' %></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" id="orderDetailsBody">
        <!-- Order details will be loaded here -->
      </div>
    </div>
  </div>
</div>

</div>

<%- contentFor('FooterJs') %>
<script src="/assets/libs/sweetalert2/sweetalert2.min.js"></script>
<script>
  var __NS_SO_I18N = {
    noOrdersFound: "<%= So.noOrders || 'No orders found' %>",
    loading: "<%= So.loading || 'Loading…' %>",
    currency: "<%= soCurrency %>",
    colOrderNum: "<%= So.colOrderNum || 'Order #' %>",
    colDate: "<%= So.colDate || 'Date' %>",
    colStatus: "<%= So.colStatus || 'Status' %>",
    na: "<%= So.na || 'N/A' %>",
    failedLoadOrders: "<%= So.failedLoadOrders || 'Failed to load orders' %>",
    failedLoadDetails: "<%= So.failedLoadDetails || 'Failed to load order details' %>",
    failedCancelOrder: "<%= So.failedCancelOrder || 'Failed to cancel order' %>",
    titleQuickView: "<%= So.titleQuickView || 'Quick view' %>",
    titleFullDetails: "<%= So.titleFullDetails || 'Full details' %>",
    titleCancelOrder: "<%= So.titleCancelOrder || 'Cancel order' %>",
    titleTrackOrder: "<%= So.titleTrackOrder || 'Track order' %>",
    statusPending: "<%= So.filterPending || 'Pending' %>",
    statusConfirmed: "<%= So.filterConfirmed || 'Confirmed' %>",
    statusProcessing: "<%= So.filterProcessing || 'Processing' %>",
    statusReady: "<%= So.filterReady || 'Ready' %>",
    statusAssigned: "<%= So.filterAssigned || 'Assigned' %>",
    statusPickedUp: "<%= So.filterPickedUp || 'Picked Up' %>",
    statusInTransit: "<%= So.filterInTransit || 'In Transit' %>",
    statusDelivered: "<%= So.filterDelivered || 'Delivered' %>",
    statusCancelled: "<%= So.filterCancelled || 'Cancelled' %>",
    statusReturned: "<%= So.filterReturned || 'Returned' %>",
    colItems: "<%= So.colItems || 'items' %>",
    notAssigned: "<%= So.notAssigned || 'Not assigned' %>",
    orderInfoTitle: "<%= So.orderInfoTitle || 'Order Information' %>",
    deliveryInfoTitle: "<%= So.deliveryInfoTitle || 'Delivery Information' %>",
    orderItems: "<%= So.orderItemsTitle || 'Order Items' %>",
    trackingHistory: "<%= So.trackingHistory || 'Tracking History' %>",
    colProduct: "<%= So.colProduct || 'Product' %>",
    colQty: "<%= So.colQty || 'Quantity' %>",
    colPrice: "<%= So.colPrice || 'Price' %>",
    colSubtotal: "<%= So.colSubtotal || 'Subtotal' %>",
    subtotalLabel: "<%= So.subtotalLabel || 'Subtotal:' %>",
    discountLabel: "<%= So.discountLabel || 'Discount:' %>",
    taxLabel: "<%= So.taxLabel || 'Tax:' %>",
    deliveryFeeLabel: "<%= So.deliveryFeeLabel || 'Delivery Fee:' %>",
    totalLabel: "<%= So.totalLabel || 'Total:' %>",
    cancelTitle: "<%= So.cancelTitle || 'Cancel Order' %>",
    cancelReasonLabel: "<%= So.cancelReasonLabel || 'Reason for cancellation' %>",
    cancelReasonPlaceholder: "<%= So.cancelReasonPlaceholder || 'Please provide a reason...' %>",
    cancelConfirmBtn: "<%= So.cancelConfirmBtn || 'Yes, cancel it' %>",
    cancelDismissBtn: "<%= So.cancelDismissBtn || 'No, keep it' %>",
    cancelReasonRequired: "<%= So.cancelReasonRequired || 'You need to provide a reason!' %>",
    successTitle: "<%= So.successTitle || 'Success!' %>",
    errorTitle: "<%= So.errorTitle || 'Error!' %>",
    infoTitle: "<%= So.infoTitle || 'Info' %>",
    trackingComingSoon: "<%= So.trackingComingSoon || 'Tracking functionality coming soon!' %>",
    unknownProduct: "<%= So.unknownProduct || 'Unknown Product' %>",
    noItemsFound: "<%= So.noItemsFound || 'No items found' %>",
    discountText: "<%= So.discountText || 'Discount' %>",
    notesLabel: "<%= So.notesLabel || 'Notes:' %>",
    locationLabel: "<%= So.locationLabel || 'Location:' %>",
    unknownTime: "<%= So.unknownTime || 'Unknown time' %>",
    locale: "<%= soLocale %>"
  };
  let ordersData = [];

  document.addEventListener('DOMContentLoaded', function() {
    loadOrders();

    // Event listeners
    document.getElementById('statusFilter').addEventListener('change', loadOrders);
  });

  async function loadOrders() {
    const status = document.getElementById('statusFilter').value;

    const params = new URLSearchParams();
    if (status) params.append('status', status);

    try {
      const response = await fetch(`/business/api/shop/orders?${params}`);
      
      if (!response.ok) {
        const errorData = await response.json();
        throw new Error(errorData.error || `HTTP error! status: ${response.status}`);
      }
      
      const orders = await response.json();
      console.log('Orders loaded:', orders.length);
      ordersData = orders;
      renderOrders(orders);
      updateStats(orders);
    } catch (error) {
      console.error('Error loading orders:', error);
      showError(__NS_SO_I18N.failedLoadOrders + ': ' + error.message);
    }
  }

  function renderOrders(orders) {
    const tbody = document.getElementById('ordersTableBody');

    if (orders.length === 0) {
      tbody.innerHTML = '<tr><td colspan="7" class="text-center py-4">' + __NS_SO_I18N.noOrdersFound + '</td></tr>';
      return;
    }

    tbody.innerHTML = orders.map(order => {
      const statusBadge = getStatusBadge(order.status);

      return `
      <tr>
        <td>
          <a href="javascript:void(0)" onclick="viewOrder('${order._id}')" class="fw-medium link-primary">
            ${order.orderNumber}
          </a>
        </td>
        <td>
          <div>
            <div>${new Date(order.createdAt).toLocaleDateString(__NS_SO_I18N.locale, { year: 'numeric', month: 'short', day: 'numeric' })}</div>
            <small class="text-muted">${new Date(order.createdAt).toLocaleTimeString(__NS_SO_I18N.locale, { hour: '2-digit', minute: '2-digit' })}</small>
          </div>
        </td>
        <td>
          <span class="badge badge-soft-info">${order.items.length} ${__NS_SO_I18N.colItems}</span>
        </td>
        <td>
          <strong class="ltr-embed">${__NS_SO_I18N.currency} ${order.totalAmount.toFixed(2)}</strong>
        </td>
        <td>${statusBadge}</td>
        <td>
          ${order.courierName ? `
            <div>
              <i class="ri-user-line me-1"></i>${order.courierName}
              <br><small class="text-muted">${order.courierPhone}</small>
            </div>
          ` : `<span class="text-muted">${__NS_SO_I18N.notAssigned}</span>`}
        </td>
        <td>
          <div class="hstack gap-1">
            <button class="btn btn-sm btn-soft-primary" onclick="viewOrder('${order._id}')" title="${__NS_SO_I18N.titleQuickView}">
              <i class="ri-eye-line"></i>
            </button>
            <a href="/business/shop/orders/${order._id}" class="btn btn-sm btn-soft-info" title="${__NS_SO_I18N.titleFullDetails}">
              <i class="ri-external-link-line"></i>
            </a>
            ${['pending', 'confirmed'].includes(order.status) ? `
              <button class="btn btn-sm btn-soft-danger" onclick="cancelOrder('${order._id}')" title="${__NS_SO_I18N.titleCancelOrder}">
                <i class="ri-close-circle-line"></i>
              </button>
            ` : ''}
            ${order.status === 'in_transit' ? `
              <button class="btn btn-sm btn-soft-success" onclick="trackOrder('${order._id}')" title="${__NS_SO_I18N.titleTrackOrder}">
                <i class="ri-map-pin-line"></i>
              </button>
            ` : ''}
          </div>
        </td>
      </tr>
    `;
    }).join('');
  }

  function getStatusBadge(status) {
    const statusConfig = {
      pending: {
        color: 'warning',
        text: __NS_SO_I18N.statusPending,
        icon: 'ri-time-line'
      },
      confirmed: {
        color: 'info',
        text: __NS_SO_I18N.statusConfirmed,
        icon: 'ri-checkbox-circle-line'
      },
      processing: {
        color: 'primary',
        text: __NS_SO_I18N.statusProcessing,
        icon: 'ri-loader-4-line'
      },
      ready: {
        color: 'secondary',
        text: __NS_SO_I18N.statusReady,
        icon: 'ri-check-double-line'
      },
      assigned: {
        color: 'info',
        text: __NS_SO_I18N.statusAssigned,
        icon: 'ri-user-follow-line'
      },
      picked_up: {
        color: 'info',
        text: __NS_SO_I18N.statusPickedUp,
        icon: 'ri-hand-coin-line'
      },
      in_transit: {
        color: 'primary',
        text: __NS_SO_I18N.statusInTransit,
        icon: 'ri-truck-line'
      },
      delivered: {
        color: 'success',
        text: __NS_SO_I18N.statusDelivered,
        icon: 'ri-check-line'
      },
      cancelled: {
        color: 'danger',
        text: __NS_SO_I18N.statusCancelled,
        icon: 'ri-close-line'
      },
      returned: {
        color: 'warning',
        text: __NS_SO_I18N.statusReturned,
        icon: 'ri-arrow-go-back-line'
      }
    };

    const config = statusConfig[status] || {
      color: 'secondary',
      text: status,
      icon: 'ri-information-line'
    };
    return `<span class="badge bg-${config.color}"><i class="${config.icon} me-1"></i>${config.text}</span>`;
  }

  function updateStats(orders) {
    const stats = {
      active: 0,
      inTransit: 0,
      delivered: 0,
      totalSpent: 0
    };

    orders.forEach(order => {
      if (['pending', 'confirmed', 'processing', 'ready'].includes(order.status)) {
        stats.active++;
      }
      if (['assigned', 'picked_up', 'in_transit'].includes(order.status)) {
        stats.inTransit++;
      }
      if (order.status === 'delivered') {
        stats.delivered++;
        stats.totalSpent += order.totalAmount;
      }
    });

    document.getElementById('activeCount').textContent = stats.active;
    document.getElementById('inTransitCount').textContent = stats.inTransit;
    document.getElementById('deliveredCount').textContent = stats.delivered;
    document.getElementById('totalSpent').textContent = `${__NS_SO_I18N.currency} ${stats.totalSpent.toFixed(2)}`;
  }

  async function viewOrder(orderId) {
    try {
      const response = await fetch(`/business/api/shop/orders/${orderId}`);
      
      if (!response.ok) {
        const errorData = await response.json();
        throw new Error(errorData.error || `HTTP error! status: ${response.status}`);
      }
      
      const order = await response.json();

      const detailsHtml = `
      <div class="row mb-4">
        <div class="col-md-6">
          <h6 class="text-muted mb-2">${__NS_SO_I18N.orderInfoTitle}</h6>
          <p><strong>${__NS_SO_I18N.colOrderNum}:</strong> ${order.orderNumber || __NS_SO_I18N.na}</p>
          <p><strong>${__NS_SO_I18N.colStatus}:</strong> ${getStatusBadge(order.status)}</p>
          <p><strong>${__NS_SO_I18N.colDate}:</strong> ${order.createdAt ? new Date(order.createdAt).toLocaleString(__NS_SO_I18N.locale) : __NS_SO_I18N.na}</p>
        </div>
        <div class="col-md-6">
          <h6 class="text-muted mb-2">${__NS_SO_I18N.deliveryInfoTitle}</h6>
          <p>${order.contactInfo?.name || order.orderCustomer?.fullName || __NS_SO_I18N.na}</p>
          <p>${order.contactInfo?.phone || order.orderCustomer?.phoneNumber || __NS_SO_I18N.na}</p>
          <p>${order.orderCustomer?.address || __NS_SO_I18N.na}</p>
          ${order.courierName ? `<p><i class="ri-user-line me-1"></i>${order.courierName} - ${order.courierPhone || __NS_SO_I18N.na}</p>` : ''}
        </div>
      </div>
      
      <h6 class="mb-3">${__NS_SO_I18N.orderItems}</h6>
      <div class="table-responsive mb-4">
        <table class="table table-sm table-bordered">
          <thead class="table-light">
            <tr>
              <th>${__NS_SO_I18N.colProduct}</th>
              <th>${__NS_SO_I18N.colQty}</th>
              <th>${__NS_SO_I18N.colPrice}</th>
              <th>${__NS_SO_I18N.colSubtotal}</th>
            </tr>
          </thead>
          <tbody>
            ${order.items && order.items.length > 0 ? order.items.map(item => `
              <tr>
                <td>
                  <div class="d-flex align-items-center">
                    ${item.product && item.product.images && item.product.images[0] ? 
                      `<img src="${item.product.images[0]}" alt="${item.productName || __NS_SO_I18N.unknownProduct}" 
                           style="width: 40px; height: 40px; object-fit: cover;" class="rounded me-2">` : ''}
                    <div>
                      <strong>${item.productName || __NS_SO_I18N.unknownProduct}</strong>
                      ${item.discount > 0 ? `<br><small class="text-success">${__NS_SO_I18N.discountText}: ${item.discount}%</small>` : ''}
                    </div>
                  </div>
                </td>
                <td>${item.quantity || 0}</td>
                <td class="ltr-embed">${__NS_SO_I18N.currency} ${(item.unitPrice || 0).toFixed(2)}</td>
                <td class="ltr-embed">${__NS_SO_I18N.currency} ${(item.subtotal || 0).toFixed(2)}</td>
              </tr>
            `).join('') : `<tr><td colspan="4" class="text-center">${__NS_SO_I18N.noItemsFound}</td></tr>`}
          </tbody>
          <tfoot>
            <tr>
              <td colspan="3" class="text-end"><strong>${__NS_SO_I18N.subtotalLabel}</strong></td>
              <td class="ltr-embed"><strong>${__NS_SO_I18N.currency} ${(order.subtotal || 0).toFixed(2)}</strong></td>
            </tr>
            ${(order.discount || 0) > 0 ? `
            <tr>
              <td colspan="3" class="text-end">${__NS_SO_I18N.discountLabel}</td>
              <td class="ltr-embed">- ${__NS_SO_I18N.currency} ${(order.discount || 0).toFixed(2)}</td>
            </tr>
            ` : ''}
            ${(order.tax || 0) > 0 ? `
            <tr>
              <td colspan="3" class="text-end">${__NS_SO_I18N.taxLabel}</td>
              <td class="ltr-embed">${__NS_SO_I18N.currency} ${(order.tax || 0).toFixed(2)}</td>
            </tr>
            ` : ''}
            <tr>
              <td colspan="3" class="text-end">${__NS_SO_I18N.deliveryFeeLabel}</td>
              <td class="ltr-embed">${__NS_SO_I18N.currency} ${(order.deliveryFee || 0).toFixed(2)}</td>
            </tr>
            <tr class="table-active">
              <td colspan="3" class="text-end"><strong>${__NS_SO_I18N.totalLabel}</strong></td>
              <td class="ltr-embed"><strong>${__NS_SO_I18N.currency} ${(order.totalAmount || 0).toFixed(2)}</strong></td>
            </tr>
          </tfoot>
        </table>
      </div>
      
      ${order.trackingHistory && order.trackingHistory.length > 0 ? `
        <h6 class="mb-3">${__NS_SO_I18N.trackingHistory}</h6>
        <div class="timeline-container">
          ${order.trackingHistory.map((track, index) => `
            <div class="timeline-item ${index === 0 ? 'timeline-item-active' : ''}">
              <div class="timeline-marker ${index === 0 ? 'timeline-marker-active' : ''}">
                <i class="ri-check-line"></i>
              </div>
              <div class="timeline-content">
                <div class="timeline-header">
                  <h6 class="timeline-title mb-1">${track.description || ''}</h6>
                  <span class="timeline-time">
                    <i class="ri-time-line me-1"></i>${track.timestamp ? new Date(track.timestamp).toLocaleString(__NS_SO_I18N.locale) : __NS_SO_I18N.unknownTime}
                  </span>
                </div>
                ${track.location ? `
                  <div class="timeline-location mt-2">
                    <i class="ri-map-pin-line me-1 text-primary"></i>
                    <span class="text-muted">${__NS_SO_I18N.locationLabel} ${track.location.lat}, ${track.location.lng}</span>
                  </div>
                ` : ''}
                ${track.notes ? `
                  <div class="timeline-notes mt-2">
                    <small class="text-muted">${track.notes}</small>
                  </div>
                ` : ''}
              </div>
            </div>
          `).join('')}
        </div>
      ` : ''}
      
      ${order.notes ? `
        <div class="alert alert-info mt-3">
          <strong>${__NS_SO_I18N.notesLabel}</strong> ${order.notes}
        </div>
      ` : ''}
    `;

      document.getElementById('orderDetailsBody').innerHTML = detailsHtml;
      new bootstrap.Modal(document.getElementById('orderModal')).show();
    } catch (error) {
      console.error('Error loading order details:', error);
      showError(__NS_SO_I18N.failedLoadDetails);
    }
  }

  async function cancelOrder(orderId) {
    const {
      value: reason
    } = await Swal.fire({
      title: __NS_SO_I18N.cancelTitle,
      input: 'textarea',
      inputLabel: __NS_SO_I18N.cancelReasonLabel,
      inputPlaceholder: __NS_SO_I18N.cancelReasonPlaceholder,
      showCancelButton: true,
      confirmButtonColor: '#d33',
      confirmButtonText: __NS_SO_I18N.cancelConfirmBtn,
      cancelButtonText: __NS_SO_I18N.cancelDismissBtn,
      inputValidator: (value) => {
        if (!value) {
          return __NS_SO_I18N.cancelReasonRequired;
        }
      }
    });

    if (reason) {
      try {
        const response = await fetch(`/business/api/shop/orders/${orderId}/cancel`, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            reason
          })
        });

        const result = await response.json();

        if (response.ok) {
          showSuccess(result.message);
          loadOrders();
        } else {
          showError(result.error);
        }
      } catch (error) {
        console.error('Error cancelling order:', error);
        showError(__NS_SO_I18N.failedCancelOrder);
      }
    }
  }

  function trackOrder(orderId) {
    // This would integrate with a tracking map or similar
    showInfo(__NS_SO_I18N.trackingComingSoon);
  }

  function showSuccess(message) {
    Swal.fire({
      icon: 'success',
      title: __NS_SO_I18N.successTitle,
      text: message,
      timer: 2000,
      showConfirmButton: false
    });
  }

  function showError(message) {
    Swal.fire({
      icon: 'error',
      title: __NS_SO_I18N.errorTitle,
      text: message
    });
  }

  function showInfo(message) {
    Swal.fire({
      icon: 'info',
      title: __NS_SO_I18N.infoTitle,
      text: message
    });
  }
</script>

