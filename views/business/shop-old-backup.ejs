        <div class="product-card" data-category="stickers">
          <img src="/assets/images/fragile-sticker.jpg" alt="<%= Sob.prodFragileSticker %>" class="product-image" >
          <div class="product-info">
            <h5 class="product-title"><%= Sob.prodFragileSticker || 'Fragile sticker' %></h5>
            <div class="product-pack"><%= Sob.packOf || 'Pack of' %> 50</div>
          </div>
          <div class="price-tag ltr-embed">
            <%= Sob.currency || 'EGP' %> 50
          </div>
          <div>
            <button class="add-btn" data-product="<%= Sob.prodFragileSticker || 'Fragile sticker' %>" data-price="50" data-category="stickers" data-pack="50">
              <i class="bi bi-plus-lg"></i>
              <%= Sob.add || 'Add' %>
            </button>
          </div>
        </div>

        <div class="product-card" data-category="stickers">
          <img src="/assets/images/security-sticker.jpg" alt="<%= Sob.prodSecuritySticker %>" class="product-image" >
          <div class="product-info">
            <h5 class="product-title"><%= Sob.prodSecuritySticker || 'Security sticker' %></h5>
            <div class="product-pack"><%= Sob.packOf || 'Pack of' %> 50</div>
          </div>
          <div class="price-tag ltr-embed">
            <%= Sob.currency || 'EGP' %> 25
          </div>
          <div>
            <button class="add-btn" data-product="<%= Sob.prodSecuritySticker || 'Security sticker' %>" data-price="25" data-category="stickers" data-pack="50">
              <i class="bi bi-plus-lg"></i>
              <%= Sob.add || 'Add' %>
            </button>
          </div>
        </div>

        <div class="product-card" data-category="stickers">
          <img src="/assets/images/smart-sticker.jpg" alt="<%= Sob.prodSmartSticker %>" class="product-image" >
          <div class="product-info">
            <h5 class="product-title"><%= Sob.prodSmartSticker || 'Smart sticker' %></h5>
            <div class="product-pack"><%= Sob.packOf || 'Pack of' %> 10</div>
          </div>
          <div class="price-tag ltr-embed">
            <%= Sob.currency || 'EGP' %> 50
          </div>
          <div>
            <button class="add-btn" data-product="<%= Sob.prodSmartSticker || 'Smart sticker' %>" data-price="50" data-category="stickers" data-pack="10">
              <i class="bi bi-plus-lg"></i>
              <%= Sob.add || 'Add' %>
            </button>
          </div>
        </div>

        <!-- LABELS -->
        <div class="category-header"><%= Sob.catLabels || 'Labels' %></div>
        
        <div class="product-card" data-category="labels">
          <img src="/assets/images/thermal-label.jpg" alt="<%= Sob.prodThermalLabels %>" class="product-image" >
          <div class="product-info">
            <h5 class="product-title"><%= Sob.prodThermalLabels || 'Thermal adhesive labels' %></h5>
            <div class="product-size"><%= Sob.prodThermalSub || 'Barcode roll label' %></div>
            <div class="product-pack"><%= Sob.prodThermalPack || '500 per roll' %></div>
          </div>
          <div class="price-tag ltr-embed">
            <%= Sob.currency || 'EGP' %> 350
          </div>
          <div>
            <button class="add-btn" data-product="<%= Sob.prodThermalLabels || 'Thermal adhesive labels' %>" data-price="350" data-category="labels" data-pack="1">
              <i class="bi bi-plus-lg"></i>
              <%= Sob.add || 'Add' %>
            </button>
          </div>
        </div>

        <!-- TAPES -->
        <div class="category-header"><%= Sob.catPlasterTape || 'Packaging tape' %></div>
        
        <div class="product-card" data-category="tapes">
          <img src="/assets/images/plaster-tape.jpg" alt="<%= Sob.prodTapeCarton %>" class="product-image" >
          <div class="product-info">
            <h5 class="product-title"><%= Sob.prodTapeCarton || 'Carton sealing tape' %></h5>
            <div class="product-size"><%= Sob.prodTapeSize || '' %></div>
            <div class="product-size"><%= Sob.prodTapeThick || '' %></div>
          </div>
          <div class="price-tag ltr-embed">
            <%= Sob.currency || 'EGP' %> 15
          </div>
          <div>
            <button class="add-btn" data-product="<%= Sob.prodTapeCarton || 'Carton sealing tape' %>" data-price="15" data-category="tapes" data-pack="1">
              <i class="bi bi-plus-lg"></i>
              <%= Sob.add || 'Add' %>
            </button>
