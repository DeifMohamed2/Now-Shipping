  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script src="/assets/rJS/business/order-details.js"></script>
<script>
  (function () {
    var __OD = (window.__NS_BUSINESS_I18N && window.__NS_BUSINESS_I18N.orderDetails) ? window.__NS_BUSINESS_I18N.orderDetails : {};

    document.addEventListener('DOMContentLoaded', function () {
      document.querySelectorAll('form[data-ajax]').forEach(function (form) {
        form.addEventListener('submit', async function (e) {
          e.preventDefault();
          try {
            const resp = await fetch(form.action, {
              method: form.method || 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(Object.fromEntries(new FormData(form))),
            });
            const data = await resp.json().catch(function () { return {}; });
            if (resp.ok) {
              Swal.fire({
                icon: 'success',
                title: __OD.ajaxSuccess || 'Success',
                text: data.message || __OD.ajaxCompleted || 'Action completed successfully',
                timer: 1800,
                showConfirmButton: false,
              });
              setTimeout(function () { window.location.reload(); }, 900);
            } else {
              Swal.fire({
                icon: 'error',
                title: __OD.ajaxError || 'Error',
                text: data.error || data.message || __OD.ajaxSomethingWrong || 'Something went wrong',
              });
            }
          } catch (err) {
            Swal.fire({ icon: 'error', title: __OD.ajaxError || 'Error', text: __OD.networkError || 'Network error' });
          }
        });
      });
    });

    window.deleteOrderFromDetails = async function (orderNumber) {
      const result = await Swal.fire({
        title: __OD.deleteConfirmTitle || 'Delete order?',
        text: __OD.deleteConfirmText || 'This will permanently remove the order. You cannot undo this.',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#dc3545',
        cancelButtonColor: '#6c757d',
        confirmButtonText: __OD.deleteConfirmYes || 'Yes, delete it',
        cancelButtonText: __OD.deleteConfirmNo || 'Cancel',
      });
      if (!result.isConfirmed) return;
      try {
        const response = await fetch('/business/orders/delete-order/' + orderNumber, {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
        });
        const data = await response.json().catch(function () { return {}; });
        if (response.ok) {
          await Swal.fire({
            icon: 'success',
            title: __OD.deleteDoneTitle || 'Deleted',
            text: data.message || __OD.deleteSuccessText || 'Order deleted successfully.',
            timer: 2000,
            showConfirmButton: false,
          });
          window.location.href = '/business/orders';
        } else {
          Swal.fire({
            icon: 'error',
            title: __OD.cannotDeleteTitle || 'Cannot delete',
            text: data.error || __OD.deleteErrorText || 'This order cannot be deleted.',
          });
        }
      } catch (err) {
        console.error('deleteOrderFromDetails error:', err);
        Swal.fire({ icon: 'error', title: __OD.ajaxError || 'Error', text: __OD.networkError || 'Network error' });
      }
    };

    window.markOrderAsReturned = async function (orderId) {
      try {
        const result = await Swal.fire({
          title: __OD.markReturnedTitle || 'Mark as returned?',
          text: __OD.markReturnedText || '',
          icon: 'question',
          showCancelButton: true,
          confirmButtonColor: '#198754',
          cancelButtonColor: '#6c757d',
          confirmButtonText: __OD.markReturnedConfirm || 'Yes',
          cancelButtonText: __OD.markReturnedCancel || 'Cancel',
        });

        if (!result.isConfirmed) return;

        const response = await fetch('/business/orders/' + orderId + '/mark-returned', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
        });

        const data = await response.json().catch(function () { return {}; });

        if (response.ok) {
          await Swal.fire({
            icon: 'success',
            title: __OD.markReturnedSuccessTitle || 'Done',
            text: data.message || __OD.markReturnedSuccessText || '',
            timer: 3000,
          });
          window.location.reload();
        } else {
          Swal.fire({
            icon: 'error',
            title: __OD.ajaxError || 'Error',
            text: data.error || __OD.markReturnedFailText || '',
          });
        }
      } catch (error) {
        console.error('Error marking order as returned:', error);
        Swal.fire({
          icon: 'error',
          title: __OD.ajaxError || 'Error',
          text: __OD.unexpectedError || '',
        });
      }
    };
  })();
</script>
<!-- App js -->