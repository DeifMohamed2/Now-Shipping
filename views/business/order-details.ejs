<%- contentFor('HeaderCss') %>
<% if ((typeof direction !== 'undefined' && direction === 'rtl') || (typeof currentLang !== 'undefined' && currentLang === 'ar')) { %>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet">
<% } %>
<link rel="stylesheet" href="/assets/rCSS/business.css">
<style>
  .order-details-page { font-synthesis: none; }
  html[dir='rtl'] .order-details-page {
    font-family: 'Tajawal', 'Cairo', sans-serif;
  }
  html[dir='rtl'] .order-details-page .card-header .d-sm-flex,
  html[dir='rtl'] .order-details-page .card-header .d-flex {
    flex-direction: row-reverse;
    text-align: right;
  }
  html[dir='rtl'] .order-details-page .accordion-button {
    text-align: right;
  }
  html[dir='rtl'] .order-details-page .accordion-button::after {
    margin-left: 0;
    margin-right: auto;
  }
  html[dir='rtl'] .order-details-page .od-return-steps,
  html[dir='rtl'] .order-details-page .od-return-steps ol {
    text-align: right;
  }
  .order-details-page .ltr-embed { direction: ltr; unicode-bidi: embed; display: inline-block; text-align: left; }
  html[dir='rtl'] .order-details-page .table-responsive .table th,
  html[dir='rtl'] .order-details-page .table-responsive .table td {
    text-align: right;
  }
</style>
<%- contentFor('body') %>
<% var Od = (typeof translation !== 'undefined' && translation.business && translation.business.pages && translation.business.pages.orderDetails) ? translation.business.pages.orderDetails : {}; %>
<% var odLocale = Od.locale || ((typeof currentLang !== 'undefined' && currentLang === 'ar') ? 'ar-EG' : 'en-US'); %>
<% var odDateFmt = { weekday: 'short', day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit', hour12: true }; %>
<% var odDateShort = { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit', hour12: true }; %>
<% function odOrderTypeLabel(t) { if (!t) return ''; var m = { Send: Od.otSend, Return: Od.otReturn, Exchange: Od.otExchange }; return m[t] || t; } %>
<% function odAmountTypeLabel(t) { if (t === 'COD') return Od.atCOD || t; if (t === 'CD') return Od.atCD || t; return t || ''; } %>

<% if (order) { %>
<% 
  const canCancelOrderResolved = typeof canCancelOrder !== 'undefined' ? !!canCancelOrder : false;
  const canChangeAddressResolved = typeof canChangeAddress !== 'undefined' ? !!canChangeAddress : false;
  const canDeleteOrderResolved = typeof canDeleteOrder !== 'undefined' ? !!canDeleteOrder : false;
  const wa = (typeof waitingActionFlags !== 'undefined' && waitingActionFlags) ? waitingActionFlags : {};
  const returnFlowCancelLabelStatuses = ['pickedUp','inStock','inProgress','returnToWarehouse','returnAtWarehouse','rescheduled','waitingAction','returnInitiated','returnAssigned','returnPickedUp','returnToBusiness','inReturnStock','returnLinked','rejected'];
  const cancelButtonLabel = returnFlowCancelLabelStatuses.includes(order.orderStatus) ? (Od.requestReturn || 'Request return') : (Od.cancelOrder || 'Cancel order');
  const odCanceledAt = order.orderStages && order.orderStages.canceled && order.orderStages.canceled.completedAt ? new Date(order.orderStages.canceled.completedAt) : null;
  function odStageBeforeCancel(t) {
    if (!odCanceledAt || !t) return true;
    return new Date(t).getTime() <= odCanceledAt.getTime();
  }
  const odTrackingBiz = order.smartFlyerBarcode || order.referralNumber || '';
  const odAmountDisplayBiz = (order.orderShipping.amount != null && order.orderShipping.amount !== '') ? (String(order.orderShipping.amount) + ' EGP') : (order.orderShipping.amountType === 'NA' ? (Od.naAmount || 'N/A') : '—');
%>

<div class="order-details-page row g-3">

  <div class="col-12 col-xl-9">
      <div class="col-12">
<% const isRescheduled = order.orderStatus === 'rescheduled'; %>
<% if (order.orderStatus === 'waitingAction' || isRescheduled) { %>
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body bg-warning-subtle rounded">
    <div class="d-flex align-items-center gap-3">
      <div class="flex-shrink-0">
        <i class="ri-alert-line fs-3 text-warning" aria-hidden="true"></i>
      </div>
      <div class="flex-grow-1">
        <h5 class="card-title mb-2 text-dark"><%= isRescheduled ? (Od.retryScheduled || 'Retry Scheduled') : (Od.actionRequired || 'Action Required') %></h5>
        <div class="d-flex align-items-center mb-1">
        </div>
        <% if (order.UnavailableReason) { %>
        <div class="alert alert-light border-0 py-2 px-3 mt-2 mb-0">
          <p class="card-text mb-0 text-dark"><strong><%= Od.additionalInformation || 'Additional Information:' %></strong></p>
          <ul class="mb-0">
            <% if (order.UnavailableReason.includes('customer_not_available')) { %>
              <li class="text-dark">
              <strong><%= Od.customerNotAvailableTitle || 'Customer not available' %>:</strong> <%= Od.customerNotAvailableBody || '' %> <span><%= Od.attemptLabel || 'Attempt' %>: <span class="ltr-embed"><%= order.Attemps %></span></span>
              </li>
            <% } %>
            <% order.UnavailableReason.forEach(function(reason) { %>
              <% if (reason !== 'customer_not_available') { %>
              <li class="text-dark"><%= reason %></li>
              <% } %>
            <% }); %>
          </ul>
        </div>
        <% } else { %>
           <p class="card-text mb-0 text-muted fst-italic"><%= Od.noAdditionalNotes || 'No additional notes provided for this order.' %></p>
        <% } %>
        <div class="mt-3 d-flex flex-wrap gap-2">
          <% if (wa.canRetryTomorrow) { %>
          <form method="post" action="/business/orders/<%= order._id %>/retry-tomorrow" data-ajax>
            <button type="submit" class="btn btn-sm btn-primary"><%= Od.retryTomorrow || 'Retry tomorrow' %></button>
          </form>
          <% } %>
          <% if (wa.canRetryScheduled) { %>
          <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#scheduleRetryModal"><%= Od.scheduleRetry || 'Schedule retry' %></button>
          <% } %>
          <% if (wa.canReturnToWarehouseFromWaiting) { %>
          <form method="post" action="/business/orders/<%= order._id %>/return-to-warehouse" data-ajax>
            <button type="submit" class="btn btn-sm btn-warning"><%= Od.returnToWarehouse || 'Return to warehouse' %></button>
          </form>
          <% } %>
          <% if (wa.canCancelFromWaiting) { %>
          <form method="post" action="/business/orders/<%= order._id %>/cancel-from-waiting" onsubmit="return confirm(<%= JSON.stringify(Od.confirmCancelFromWaiting || Od.confirmCancelOrder || 'Return this order from waiting action?') %>);" data-ajax>
            <button type="submit" class="btn btn-sm btn-danger"><%= Od.cancelFromWaitingAction || cancelButtonLabel %></button>
          </form>
          <% } %>
        </div>
        <% if (order.scheduledRetryAt) { %>
          <div class="mt-2">
            <% if (order.orderStatus === 'rescheduled') { %>
            <div class="alert alert-success d-flex align-items-center gap-2 py-2 px-3 mb-0">
              <i class="ri-time-line fs-5 flex-shrink-0" aria-hidden="true"></i>
              <div>
                <%= Od.retryScheduledFor || 'Retry scheduled for:' %> <strong class="ltr-embed"><%= new Date(order.scheduledRetryAt).toLocaleString(odLocale, odDateFmt) %></strong>
              </div>
            </div>
            <% } else { %>
            <div class="alert alert-secondary d-flex align-items-center gap-2 py-2 px-3 mb-0">
              <i class="ri-time-line fs-5 flex-shrink-0" aria-hidden="true"></i>
              <div>
                <%= Od.tentativeRetryAt || 'Tentative retry time (not confirmed — use Retry tomorrow or Schedule retry):' %> <strong class="ltr-embed"><%= new Date(order.scheduledRetryAt).toLocaleString(odLocale, odDateFmt) %></strong>
              </div>
            </div>
            <% } %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
<% } %>

<!-- Schedule Retry Modal -->
<div class="modal fade" id="scheduleRetryModal" tabindex="-1" aria-labelledby="scheduleRetryLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="scheduleRetryLabel"><%= Od.scheduleRetryTitle || 'Schedule retry' %></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="<%= Od.modalCloseAria || 'Close' %>"></button>
      </div>
      <form method="post" action="/business/orders/<%= order._id %>/retry-scheduled" data-ajax>
        <div class="modal-body">
          <label for="retryDate" class="form-label"><%= Od.retryDateLabel || 'Retry date' %></label>
          <input type="datetime-local" id="retryDate" name="date" class="form-control" required />
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><%= Od.closeModal || 'Close' %></button>
          <button type="submit" class="btn btn-primary"><%= Od.scheduleSubmit || 'Schedule' %></button>
        </div>
      </form>
    </div>
  </div>
 </div>
      </div>
    <div class="card">
      <div class="card-header">
        <div class="d-sm-flex align-items-center">
          <h5 class="card-title flex-grow-1 mb-0"><%= Od.orderStatusHeading || 'Order status' %> — <span style="color: #007bff;"><strong class="ltr-embed"><%= order.orderNumber %></strong></span></h5>
          <div class="flex-shrink-0 mt-2 mt-sm-0 d-flex flex-wrap gap-1 justify-content-sm-end">
            <% if (canChangeAddressResolved) { %>
            <a href="/business/edit-order/<%= order.orderNumber %>" class="btn btn-soft-info material-shadow-none btn-sm mt-2 mt-sm-0"><i class="ri-map-pin-line align-middle ms-1 me-1" aria-hidden="true"></i><%= Od.changeAddress || 'Change address' %></a>
            <% } else { %>
            <button type="button" class="btn btn-soft-secondary material-shadow-none btn-sm mt-2 mt-sm-0" disabled
              title="<%= Od.addressEditLockedTitle || 'Address cannot be changed' %>"
              aria-label="<%= Od.addressEditLockedTitle || 'Address cannot be changed' %>">
              <i class="ri-lock-line align-middle ms-1 me-1" aria-hidden="true"></i><%= Od.addressEditLockedShort || 'Address locked' %>
            </button>
            <% } %>
            <% if (order.orderStatus === 'completed' && order.orderShipping.orderType !== 'Return') { %>
            <a href="/business/create-order" class="btn btn-soft-warning material-shadow-none btn-sm mt-2 mt-sm-0"><i class="ri-arrow-go-back-line align-middle ms-1 me-1" aria-hidden="true"></i><%= Od.createReturnOrder || 'Create return order' %></a>
            <% } %>
            <% if (order.orderStatus === 'returnLinked') { %>
            <button type="button" class="btn btn-soft-success material-shadow-none btn-sm mt-2 mt-sm-0" onclick="markOrderAsReturned('<%= order._id %>')"><i class="ri-check-double-line align-middle ms-1 me-1" aria-hidden="true"></i><%= Od.markAsReturned || 'Mark as returned' %></button>
            <% } %>
            <% if (canCancelOrderResolved) { %>
            <button type="button" class="btn btn-soft-danger material-shadow-none btn-sm mt-2 mt-sm-0"
              onclick="cancelOrder('<%= order._id %>', <%= returnFlowCancelLabelStatuses.includes(order.orderStatus) ? 'true' : 'false' %>)">
              <i class="mdi mdi-archive-remove-outline align-middle ms-1 me-1" aria-hidden="true"></i> <%= cancelButtonLabel %>
            </button>
            <% } %>
            <% if (canDeleteOrderResolved) { %>
            <button type="button" class="btn btn-danger material-shadow-none btn-sm mt-2 mt-sm-0"
              onclick="deleteOrderFromDetails('<%= order.orderNumber %>')">
              <i class="ri-delete-bin-2-line align-middle ms-1 me-1" aria-hidden="true"></i><%= Od.deleteOrder || 'Delete Order' %>
            </button>
            <% } %>
          </div>
        </div>
      </div>
      <div class="card-body">
        <div class="profile-timeline">
          <div class="accordion accordion-flush" id="accordionFlushExample">
            <!-- order Placed -->
            <div class="accordion-item border-0">
              <div class="accordion-header" id="headingOne">
                <a class="accordion-button p-2 shadow-none" data-bs-toggle="collapse" href="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-success rounded-circle material-shadow">
                        <i class="ri-shopping-bag-line"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-0 fw-semibold"><%= Od.stagePlaced || 'Order Placed' %> - <span class="fw-normal"><%= new Date(order.orderDate).toLocaleString(odLocale, odDateFmt) %></span></h6>
                    </div>
                  </div>
                </a>
              </div>
              <!-- <div id="collapseOne" class="accordion-collapse collapse show" aria-labelledby="headingOne" data-bs-parent="#accordionExample">
                <div class="accordion-body ms-2 ps-5 pt-0">
                  <h6 class="mb-1">An order has been placed.</h6>
                  <p class="text-muted">Wed, 15 Dec 2021 - 05:34PM</p>

                  <h6 class="mb-1">Seller has processed your order.</h6>
                  <p class="text-muted mb-0">Thu, 16 Dec 2021 - 5:48AM</p>
                </div>
              </div> -->
            </div>
            <!-- order Packed (only for non-return orders) -->
            <% if (order.orderShipping.orderType !== 'Return') { %>
            <div class="accordion-item border-0">
              <div class="accordion-header" id="headingTwo">
                <a class="accordion-button p-2 shadow-none" data-bs-toggle="collapse" href="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">

                  <% if (order.orderStages.packed.isCompleted && odStageBeforeCancel(order.orderStages.packed.completedAt)) { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-success rounded-circle material-shadow">
                        <i class="mdi mdi-gift-outline"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stagePacked || 'Packed' %> - <span class="fw-normal"><%= new Date(order.orderStages.packed.completedAt).toLocaleString(odLocale, odDateFmt) %></span></h6>
                    </div>
                  </div>
                  <% } else if (order.orderStages.packed.isCompleted) { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-light text-muted rounded-circle material-shadow border">
                        <i class="mdi mdi-gift-outline"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold text-muted"><%= Od.stagePackedAfterCancel || 'Packed' %> — <span class="fw-normal"><%= new Date(order.orderStages.packed.completedAt).toLocaleString(odLocale, odDateFmt) %></span></h6>
                    </div>
                  </div>
                  <% } else { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-light text-muted rounded-circle material-shadow">
                        <i class="mdi mdi-gift-outline"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stagePacked || 'Packed' %></h6>
                    </div>
                  </div>
                  <% } %>

                </a>
              </div>
              <!-- <div id="collapseTwo" class="accordion-collapse collapse show" aria-labelledby="headingTwo" data-bs-parent="#accordionExample">
                <div class="accordion-body ms-2 ps-5 pt-0">
                  <h6 class="mb-1">Your Item has been picked up by courier partner</h6>
                  <p class="text-muted mb-0">Fri, 17 Dec 2021 - 9:45AM</p>
                </div>
              </div> -->

            </div>
            <% } %>
            <!-- order shipping (only for non-return orders) -->
            <% if (order.orderShipping.orderType !== 'Return') { %>
            <div class="accordion-item border-0">
              <div class="accordion-header" id="headingThree">
                <a class="accordion-button p-2 shadow-none" data-bs-toggle="collapse" href="#collapseThree" aria-expanded="false" aria-controls="collapseThree">

                  <% if (order.orderStages.shipping.isCompleted && odStageBeforeCancel(order.orderStages.shipping.completedAt)) { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-success rounded-circle material-shadow">
                        <i class="ri-truck-line"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stageShipping || 'Shipping' %> — <span class="fw-normal"><%= new Date(order.orderStages.shipping.completedAt).toLocaleString(odLocale, odDateFmt) %></span></h6>
                    </div>
                  </div>
                  <% } else if (order.orderStages.shipping.isCompleted) { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-light text-muted rounded-circle material-shadow border">
                        <i class="ri-truck-line"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold text-muted"><%= Od.stageShippingAfterCancel || 'Shipping' %> — <span class="fw-normal"><%= new Date(order.orderStages.shipping.completedAt).toLocaleString(odLocale, odDateFmt) %></span></h6>
                    </div>
                  </div>
                  <% } else { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-light text-muted rounded-circle material-shadow">
                        <i class="ri-truck-line"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stageShipping || 'Shipping' %></h6>
                    </div>
                  </div>
                  <% } %>

                </a>
              </div>
              <!-- <div id="collapseThree" class="accordion-collapse collapse show" aria-labelledby="headingThree" data-bs-parent="#accordionExample">
              <div class="accordion-body ms-2 ps-5 pt-0">
                <h6 class="fs-14">RQK Logistics - MFDS1400457854</h6>
                <h6 class="mb-1">Your item has been shipped.</h6>
                <p class="text-muted mb-0">Sat, 18 Dec 2021 - 4.54PM</p>
              </div>
              </div> -->
            </div>
            <% } %>
            <!-- order In Progress (only for non-return orders) -->
            <% if (order.orderShipping.orderType !== 'Return') { %>
            <div class="accordion-item border-0">
              <div class="accordion-header" id="headingFour">
                <a class="accordion-button p-2 shadow-none" data-bs-toggle="collapse" href="#collapseFour" aria-expanded="false" aria-controls="collapseFour">
                  <% if (order.orderStages.inProgress.isCompleted && odStageBeforeCancel(order.orderStages.inProgress.completedAt)) { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-warning rounded-circle material-shadow">
                        <i class="ri-time-line"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stageInProgress || 'In progress' %> — <span class="fw-normal"><%= new Date(order.orderStages.inProgress.completedAt).toLocaleString(odLocale, odDateFmt) %></span></h6>
                    </div>
                  </div>
                  <% } else if (order.orderStages.inProgress.isCompleted) { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-light text-muted rounded-circle material-shadow border">
                        <i class="ri-time-line"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold text-muted"><%= Od.stageInProgressAfterCancel || 'In progress' %> — <span class="fw-normal"><%= new Date(order.orderStages.inProgress.completedAt).toLocaleString(odLocale, odDateFmt) %></span></h6>
                    </div>
                  </div>
                  <% } else { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-light text-muted rounded-circle material-shadow">
                        <i class="ri-time-line"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stageInProgress || 'In progress' %></h6>
                    </div>
                  </div>
                  <% } %>
                </a>
              </div>
            </div>
            <% } %>
            <!-- order out forDelivery (only for non-return orders) -->
            <% if (order.orderShipping.orderType !== 'Return') { %>
            <div class="accordion-item border-0">
              <div class="accordion-header" id="headingFive">
                <a class="accordion-button p-2 shadow-none" data-bs-toggle="collapse" href="#collapseFive" aria-expanded="false" aria-controls="collapseFive">
                  <% if (order.orderStages.outForDelivery.isCompleted && odStageBeforeCancel(order.orderStages.outForDelivery.completedAt)) { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-success rounded-circle material-shadow">
                        <i class="ri-takeaway-fill"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stageOutForDelivery || 'Out for delivery' %> — <span class="fw-normal"><%= new Date(order.orderStages.outForDelivery.completedAt).toLocaleString(odLocale, odDateFmt) %></span></h6>
                    </div>
                  </div>
                  <% } else if (order.orderStages.outForDelivery.isCompleted) { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-light text-muted rounded-circle material-shadow border">
                        <i class="ri-takeaway-fill"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold text-muted"><%= Od.stageOutForDeliveryAfterCancel || 'Out for delivery' %> — <span class="fw-normal"><%= new Date(order.orderStages.outForDelivery.completedAt).toLocaleString(odLocale, odDateFmt) %></span></h6>
                    </div>
                  </div>
                  <% } else { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-light text-muted rounded-circle material-shadow">
                        <i class="ri-takeaway-fill"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stageOutForDelivery || 'Out for delivery' %></h6>
                    </div>
                  </div>
                  <% } %>
                </a>
              </div>
            </div>
            <% } %>
            <!-- Exchange: Exchange Pickup stage -->
            <% if (order.orderShipping.orderType === 'Exchange') { %>
            <div class="accordion-item border-0">
              <div class="accordion-header">
                <a class="accordion-button p-2 shadow-none collapsed" data-bs-toggle="collapse" href="#collapseExchangePickup" aria-expanded="false">
                  <% if (order.orderStages.exchangePickup && order.orderStages.exchangePickup.isCompleted) { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-success rounded-circle material-shadow">
                        <i class="ri-exchange-2-line"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stageExchangeAtCustomer || 'Exchange at customer' %> — <span class="fw-normal"><%= new Date(order.orderStages.exchangePickup.completedAt).toLocaleString(odLocale, odDateFmt) %></span></h6>
                      <p class="text-muted mb-0 fs-12"><%= Od.stageExchangePickupSub || '' %></p>
                    </div>
                  </div>
                  <% } else { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-light text-muted rounded-circle material-shadow">
                        <i class="ri-exchange-2-line"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stageExchangeAtCustomer || 'Exchange at customer' %></h6>
                    </div>
                  </div>
                  <% } %>
                </a>
              </div>
            </div>
            <!-- Exchange: original item in return stock -->
            <% const exReturnStockDone = ['inReturnStock','returnToBusiness','completed'].includes(order.orderStatus); %>
            <div class="accordion-item border-0">
              <div class="accordion-header">
                <a class="accordion-button p-2 shadow-none collapsed" data-bs-toggle="collapse" href="#collapseExchangeReturnStock" aria-expanded="false">
                  <% if (exReturnStockDone) { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-success rounded-circle material-shadow">
                        <i class="ri-archive-line"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stageOriginalReturnStock || '' %></h6>
                      <p class="text-muted mb-0 fs-12"><%= Od.stageOriginalReturnStockSub || '' %></p>
                    </div>
                  </div>
                  <% } else { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-light text-muted rounded-circle material-shadow">
                        <i class="ri-archive-line"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stageOriginalReturnStock || '' %></h6>
                    </div>
                  </div>
                  <% } %>
                </a>
              </div>
            </div>
            <!-- Exchange: return courier to business -->
            <% const exReturnLegDone = order.orderStatus === 'completed' && order.orderStages.returnCompleted && order.orderStages.returnCompleted.isCompleted; %>
            <div class="accordion-item border-0">
              <div class="accordion-header">
                <a class="accordion-button p-2 shadow-none collapsed" data-bs-toggle="collapse" href="#collapseExchangeReturnBusiness" aria-expanded="false">
                  <% if (exReturnLegDone) { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-success rounded-circle material-shadow">
                        <i class="ri-store-2-line"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stageOriginalReturnedBusiness || '' %> — <span class="fw-normal"><%= order.orderStages.returnCompleted.completedAt ? new Date(order.orderStages.returnCompleted.completedAt).toLocaleString(odLocale, odDateFmt) : '' %></span></h6>
                      <p class="text-muted mb-0 fs-12"><%= Od.stageOriginalReturnedBusinessSub || '' %></p>
                    </div>
                  </div>
                  <% } else { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-light text-muted rounded-circle material-shadow">
                        <i class="ri-store-2-line"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stageOriginalReturnedBusiness || '' %></h6>
                    </div>
                  </div>
                  <% } %>
                </a>
              </div>
            </div>
            <% } %>
            <!-- order Delivered (only for non-return orders) -->
            <% if (order.orderShipping.orderType !== 'Return') { %>
            <div class="accordion-item border-0">
              <div class="accordion-header" id="headingSix">
                <a class="accordion-button p-2 shadow-none" data-bs-toggle="collapse" href="#collapseSix" aria-expanded="false" aria-controls="collapseSix">
                  <% if (order.orderStages.delivered.isCompleted && odStageBeforeCancel(order.orderStages.delivered.completedAt)) { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-success rounded-circle material-shadow">
                        <i class="mdi mdi-package-variant"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stageDelivered || 'Delivered' %> - <span class="fw-normal"><%= new Date(order.orderStages.delivered.completedAt).toLocaleString(odLocale, odDateFmt) %></span></h6>
                    </div>
                  </div>
                  <% } else if (order.orderStages.delivered.isCompleted) { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-light text-muted rounded-circle material-shadow border">
                        <i class="mdi mdi-package-variant"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold text-muted"><%= Od.stageDeliveredAfterCancel || 'Delivered' %> — <span class="fw-normal"><%= new Date(order.orderStages.delivered.completedAt).toLocaleString(odLocale, odDateFmt) %></span></h6>
                    </div>
                  </div>
                  <% } else { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-light text-muted rounded-circle material-shadow">
                        <i class="mdi mdi-package-variant"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stageDelivered || 'Delivered' %></h6>
                    </div>
                  </div>
                  <% } %>
                </a>
              </div>
            </div>
            <% } %>

            <!-- Canceled Stage (only show if order is canceled) -->
            <% if (order.orderStatus === 'canceled') { %>
            <div class="accordion-item border-0">
              <div class="accordion-header" id="headingCanceled">
                <a class="accordion-button p-2 shadow-none" data-bs-toggle="collapse" href="#collapseCanceled" aria-expanded="false" aria-controls="collapseCanceled">
                  <% if (order.orderStages.canceled && order.orderStages.canceled.isCompleted) { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-danger rounded-circle material-shadow">
                        <i class="ri-close-circle-line"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stageOrderCanceled || 'Order canceled' %> — <span class="fw-normal"><%= new Date(order.orderStages.canceled.completedAt).toLocaleString(odLocale, odDateFmt) %></span></h6>
                    </div>
                  </div>
                  <% } else { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-danger rounded-circle material-shadow">
                        <i class="ri-close-circle-line"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stageOrderCanceled || 'Order canceled' %></h6>
                    </div>
                  </div>
                  <% } %>
                </a>
              </div>
            </div>
            <% } %>

            <!-- Return Stages (only show if order is a return) -->
            <% if (order.orderShipping.orderType === 'Return' || order.orderStatus.includes('return')) { %>

            <!-- ── Return Progress Stepper ────────────────────────────────── -->
            <%
              const retSteps = [
                { key: 'returnInitiated',  icon: 'ri-arrow-go-back-line',  label: Od.retStepRequested || 'Requested' },
                { key: 'returnAssigned',   icon: 'ri-user-add-line',       label: Od.retStepCourierAssigned || 'Courier assigned' },
                { key: 'returnPickedUp',   icon: 'ri-truck-line',          label: Od.retStepPickedUpCustomer || 'Picked up from customer' },
                { key: 'returnCompleted',  icon: 'ri-check-double-line',   label: Od.retStepReturnedToYou || 'Returned to you' },
              ];
              const isRetStepDone = (k) => order.orderStages[k] && order.orderStages[k].isCompleted;
              const retActiveKey = ['returnInitiated','returnAssigned','returnPickedUp','returnAtWarehouse','returnToBusiness','returnCompleted']
                .find(k => order.orderStatus === k) || order.orderStatus;
            %>
            <div class="px-2 pb-2 pt-1">
              <div class="d-flex align-items-start justify-content-between position-relative" style="--ret-line-color: #e2e8f0;">
                <!-- connecting line -->
                <div class="od-stepper-line" style="position:absolute;top:16px;inset-inline:12.5%;height:2px;background:#e2e8f0;z-index:0;"></div>
                <% retSteps.forEach(function(rs, ri) {
                     const done = isRetStepDone(rs.key) || (rs.key === 'returnCompleted' && isRetStepDone('returnToBusiness') && order.orderStatus === 'returnCompleted');
                     const active = !done && (order.orderStatus === rs.key || (rs.key === 'returnCompleted' && order.orderStatus === 'returnToBusiness'));
                %>
                <div class="d-flex flex-column align-items-center" style="flex:1;z-index:1;position:relative;">
                  <div class="rounded-circle d-flex align-items-center justify-content-center mb-1 shadow-sm"
                    style="width:32px;height:32px;font-size:0.95rem;transition:all .3s;
                      background:<%= done ? '#28a745' : active ? '#F39720' : '#f1f3f7' %>;
                      color:<%= (done || active) ? '#fff' : '#94a3b8' %>;
                      box-shadow:<%= active ? '0 0 0 4px rgba(243,151,32,.18)' : 'none' %>;
                      border:2px solid <%= done ? '#28a745' : active ? '#F39720' : '#dee2e6' %>;">
                    <% if (done) { %><i class="ri-check-line" style="font-size:1rem;"></i><% } else { %><i class="<%= rs.icon %>"></i><% } %>
                  </div>
                  <span style="font-size:0.67rem;text-align:center;font-weight:<%= active ? '600' : '400' %>;
                    color:<%= done ? '#28a745' : active ? '#F39720' : '#6c757d' %>;line-height:1.2;max-width:72px;">
                    <%= rs.label %>
                  </span>
                </div>
                <% }); %>
              </div>
            </div>

            <!-- ── OTP Info Banner (shown only when courier is assigned but not yet picked up) ── -->
            <% if (order.orderStatus === 'returnAssigned') { %>
            <div class="mx-2 mb-3 p-3 rounded-3 d-flex gap-3 align-items-start"
              style="background:linear-gradient(135deg,#fff8ee 0%,#fff 100%);border:1.5px solid #F39720;">
              <i class="ri-shield-keyhole-line fs-3 flex-shrink-0" style="color:#F39720;line-height:1.2;"></i>
              <div>
                <p class="mb-1 fw-semibold" style="font-size:.9rem;"><%= Od.otpBannerTitle || '' %></p>
                <p class="mb-0 text-muted" style="font-size:.8rem;">
                  <%= Od.otpBannerBody || '' %>
                </p>
                <% if (order.returnOtp && order.returnOtp.issuedAt) { %>
                <span class="badge bg-light text-muted mt-2" style="font-size:.73rem;">
                  <i class="ri-time-line ms-1 me-1" aria-hidden="true"></i><%= Od.otpSentAt || 'Sent at' %> <%= new Date(order.returnOtp.issuedAt).toLocaleString(odLocale, odDateShort) %>
                </span>
                <% } %>
              </div>
            </div>
            <% } %>
            <!-- ───────────────────────────────────────────────────────────── -->

            <!-- Return Initiated -->
            <div class="accordion-item border-0">
              <div class="accordion-header" id="headingReturnInitiated">
                <a class="accordion-button p-2 shadow-none" data-bs-toggle="collapse" href="#collapseReturnInitiated" aria-expanded="false" aria-controls="collapseReturnInitiated">
                  <% if (order.orderStages.returnInitiated && order.orderStages.returnInitiated.isCompleted) { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-warning rounded-circle material-shadow">
                        <i class="ri-arrow-go-back-line"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stageReturnInitiated || 'Return initiated' %> — <span class="fw-normal"><%= new Date(order.orderStages.returnInitiated.completedAt).toLocaleString(odLocale, odDateFmt) %></span></h6>
                    </div>
                  </div>
                  <% } else { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-light text-muted rounded-circle material-shadow">
                        <i class="ri-arrow-go-back-line"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stageReturnInitiated || 'Return initiated' %></h6>
                    </div>
                  </div>
                  <% } %>
                </a>
              </div>
            </div>


            <!-- Return Assigned -->
            <div class="accordion-item border-0">
              <div class="accordion-header" id="headingReturnAssigned">
                <a class="accordion-button p-2 shadow-none" data-bs-toggle="collapse" href="#collapseReturnAssigned" aria-expanded="false" aria-controls="collapseReturnAssigned">
                  <% if (order.orderStages.returnAssigned && order.orderStages.returnAssigned.isCompleted) { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-primary rounded-circle material-shadow">
                        <i class="ri-user-add-line"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stageCourierAssigned || 'Courier Assigned' %> - <span class="fw-normal"><%= new Date(order.orderStages.returnAssigned.completedAt).toLocaleString(odLocale, odDateFmt) %></span></h6>
                      <% if (order.returnOtp && order.returnOtp.issuedAt) { %>
                      <p class="text-muted mb-0" style="font-size:.78rem;"><i class="ri-shield-keyhole-line ms-1 me-1" style="color:#F39720;" aria-hidden="true"></i><%= Od.otpSentToCustomerAt || '' %> <%= new Date(order.returnOtp.issuedAt).toLocaleString(odLocale, odDateShort) %></p>
                      <% } %>
                    </div>
                  </div>
                  <% } else { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-light text-muted rounded-circle material-shadow">
                        <i class="ri-user-add-line"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stageCourierAssigned || 'Courier Assigned' %></h6>
                    </div>
                  </div>
                  <% } %>
                </a>
              </div>
            </div>

            <!-- Return Picked Up -->
            <div class="accordion-item border-0">
              <div class="accordion-header" id="headingReturnPickedUp">
                <a class="accordion-button p-2 shadow-none" data-bs-toggle="collapse" href="#collapseReturnPickedUp" aria-expanded="false" aria-controls="collapseReturnPickedUp">
                  <% if (order.orderStages.returnPickedUp && order.orderStages.returnPickedUp.isCompleted) { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-warning rounded-circle material-shadow">
                        <i class="ri-truck-line"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stageReturnPickedUp || 'Return picked up' %> — <span class="fw-normal"><%= new Date(order.orderStages.returnPickedUp.completedAt).toLocaleString(odLocale, odDateFmt) %></span></h6>
                      <% if (order.returnOtp && order.returnOtp.verifiedAt) { %>
                      <p class="text-muted mb-0" style="font-size:.78rem;"><i class="ri-shield-check-line ms-1 me-1 text-success" aria-hidden="true"></i><%= Od.otpVerifiedPickup || '' %></p>
                      <% } %>
                    </div>
                  </div>
                  <% } else { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-light text-muted rounded-circle material-shadow">
                        <i class="ri-truck-line"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stageReturnPickedUp || 'Return picked up' %></h6>
                    </div>
                  </div>
                  <% } %>
                </a>
              </div>
            </div>

            <!-- Return At Warehouse -->
            <div class="accordion-item border-0">
              <div class="accordion-header" id="headingReturnAtWarehouse">
                <a class="accordion-button p-2 shadow-none" data-bs-toggle="collapse" href="#collapseReturnAtWarehouse" aria-expanded="false" aria-controls="collapseReturnAtWarehouse">
                  <% if (order.orderStages.returnAtWarehouse && order.orderStages.returnAtWarehouse.isCompleted) { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-info rounded-circle material-shadow">
                        <i class="ri-store-2-line"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stageAtWarehouse || 'At warehouse' %> — <span class="fw-normal"><%= new Date(order.orderStages.returnAtWarehouse.completedAt).toLocaleString(odLocale, odDateFmt) %></span></h6>
                    </div>
                  </div>
                  <% } else { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-light text-muted rounded-circle material-shadow">
                        <i class="ri-store-2-line"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stageAtWarehouse || 'At warehouse' %></h6>
                    </div>
                  </div>
                  <% } %>
                </a>
              </div>
            </div>

            <!-- Return To Business -->
            <div class="accordion-item border-0">
              <div class="accordion-header" id="headingReturnToBusiness">
                <a class="accordion-button p-2 shadow-none" data-bs-toggle="collapse" href="#collapseReturnToBusiness" aria-expanded="false" aria-controls="collapseReturnToBusiness">
                  <% if (order.orderStages.returnToBusiness && order.orderStages.returnToBusiness.isCompleted) { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-primary rounded-circle material-shadow">
                        <i class="ri-truck-line"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stageReturningToBusiness || 'Returning to Business' %> — <span class="fw-normal"><%= new Date(order.orderStages.returnToBusiness.completedAt).toLocaleString(odLocale, odDateFmt) %></span></h6>
                    </div>
                  </div>
                  <% } else { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-light text-muted rounded-circle material-shadow">
                        <i class="ri-truck-line"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stageReturningToBusiness || 'Returning to Business' %></h6>
                    </div>
                  </div>
                  <% } %>
                </a>
              </div>
            </div>

            <!-- Return Completed -->
            <div class="accordion-item border-0">
              <div class="accordion-header" id="headingReturnCompleted">
                <a class="accordion-button p-2 shadow-none" data-bs-toggle="collapse" href="#collapseReturnCompleted" aria-expanded="false" aria-controls="collapseReturnCompleted">
                  <% if (order.orderStages.returnCompleted && order.orderStages.returnCompleted.isCompleted) { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-success rounded-circle material-shadow">
                        <i class="ri-check-double-line"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stageReturnCompleted || 'Return completed' %> — <span class="fw-normal"><%= new Date(order.orderStages.returnCompleted.completedAt).toLocaleString(odLocale, odDateFmt) %></span></h6>
                    </div>
                  </div>
                  <% } else { %>
                  <div class="d-flex align-items-center">
                    <div class="flex-shrink-0 avatar-xs">
                      <div class="avatar-title bg-light text-muted rounded-circle material-shadow">
                        <i class="ri-check-double-line"></i>
                      </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                      <h6 class="fs-15 mb-1 fw-semibold"><%= Od.stageReturnCompleted || 'Return completed' %></h6>
                    </div>
                  </div>
                  <% } %>
                </a>
              </div>
            </div>
            <% } %>
          </div>
          <!--end accordion-->
        </div>
      </div>
    </div>
    <!--end card-->
    <div class="card">
      <div class="card-header">
        <div class="d-flex align-items-center">
          <h5 class="card-title flex-grow-1 mb-0"><%= Od.customerDetails || 'Customer details' %></h5>
        </div>
      </div>
      <div class="card-body">
        <ul class="list-unstyled mb-0 vstack gap-3">
          <div class="row">
            <div class="col-md-6">
              <li>
                <div class="d-flex align-items-center">
                  <div class="flex-shrink-0">
                    <div class="avatar-xs">
                      <div class="avatar-title bg-soft-primary text-white rounded-circle">
                        <i class="ri-user-3-line"></i>
                      </div>
                    </div>
                  </div>
                  <div class="flex-grow-1 ms-3">
                    <h6 class="fs-14 mb-1"><%= order.orderCustomer.fullName %></h6>
                    <p class="text-muted mb-0"><%= Od.labelCustomer || 'Customer' %></p>
                  </div>
                </div>
              </li>
            </div>
            <div class="col-md-6">
              <li class="d-flex align-items-center">
                <div class="flex-shrink-0">
                  <div class="avatar-xs">
                    <div class="avatar-title bg-soft-info text-white rounded-circle">
                      <i class="ri-phone-line"></i>
                    </div>
                  </div>
                </div>
                <div class="flex-grow-1 ms-3">
                  <h6 class="fs-14 mb-0"><%= order.orderCustomer.phoneNumber %></h6>
                  <p class="text-muted mb-0"><%= Od.labelContactNumber || 'Contact number' %></p>
                </div>
              </li>
              <% if (order.orderCustomer.otherPhoneNumber) { %>
              <li class="d-flex align-items-center mt-2">
                <div class="flex-shrink-0">
                  <div class="avatar-xs">
                    <div class="avatar-title bg-soft-info text-white rounded-circle">
                      <i class="ri-phone-line"></i>
                    </div>
                  </div>
                </div>
                <div class="flex-grow-1 ms-3">
                  <h6 class="fs-14 mb-0"><%= order.orderCustomer.otherPhoneNumber %></h6>
                  <p class="text-muted mb-0"><%= Od.labelAltContact || 'Alternative contact' %></p>
                </div>
              </li>
              <% } %>
              <% if (order.orderCustomer.deliverToWorkAddress) { %>
              <li class="d-flex align-items-center mt-2">
                <div class="flex-shrink-0">
                  <div class="avatar-xs">
                    <div class="avatar-title bg-soft-warning text-white rounded-circle">
                      <i class="ri-building-line"></i>
                    </div>
                  </div>
                </div>
                <div class="flex-grow-1 ms-3">
                  <span class="badge bg-warning text-dark"><%= Od.workAddressBadge || 'Work address' %></span>
                  <p class="text-muted mb-0"><%= Od.deliveryDestination || 'Delivery destination' %></p>
                </div>
              </li>
              <% } %>
            </div>
          </div>
          <div class="row">
