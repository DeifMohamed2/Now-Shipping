                  badgeClass = 'bg-warning-subtle text-warning';
                  actionText = Od.actionPickupFromCustomer || 'Pickup from customer';
                } else if (history.action === 'delivered_to_warehouse') {
                  badgeClass = 'bg-success-subtle text-success';
                  actionText = Od.actionDeliveredToWarehouse || 'Delivered to warehouse';
                } else if (history.action === 'pickup_from_warehouse') {
