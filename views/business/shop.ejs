<%- contentFor('HeaderCss') %>
<% if ((typeof direction !== 'undefined' && direction === 'rtl') || (typeof currentLang !== 'undefined' && currentLang === 'ar')) { %>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet">
<% } %>
<link href="/assets/libs/sweetalert2/sweetalert2.min.css" rel="stylesheet" type="text/css" />
<link rel="stylesheet" href="/assets/rCSS/business.css">
<link rel="stylesheet" href="/assets/rCSS/shop.css">
<% if ((typeof direction !== 'undefined' && direction === 'rtl') || (typeof currentLang !== 'undefined' && currentLang === 'ar')) { %>
<style>
  .shop-page { font-family: 'Tajawal', 'Cairo', sans-serif; }
</style>
<% } %>
<%- contentFor('body') %>
<% var Sp = (typeof translation !== 'undefined' && translation.business && translation.business.pages && translation.business.pages.shop) ? translation.business.pages.shop : {}; %>
<% var shopCur = Sp.currency || 'EGP'; %>
<% var shopCat = {
  'normal-flyers': Sp.catNormalFlyers,
  'smart-flyers': Sp.catSmartFlyers,
  'boxes': Sp.catBoxes,
  'stickers': Sp.catStickers,
  'labels': Sp.catLabels,
  'tapes': Sp.catTape
};
var shopPickupPresets = [];
if (typeof userData !== 'undefined' && userData) {
  if (userData.pickUpAddresses && userData.pickUpAddresses.length) {
    userData.pickUpAddresses.forEach(function (addr) {
      shopPickupPresets.push({
        id: addr.addressId,
        label: (addr.addressName || 'Address') + ' — ' + (addr.city || '') + (addr.zone ? ' / ' + addr.zone : ''),
        city: addr.city || '',
        zone: addr.zone || '',
        adressDetails: addr.adressDetails || '',
        nearbyLandmark: addr.nearbyLandmark || '',
        pickupPhone: addr.pickupPhone || '',
        isDefault: !!addr.isDefault
      });
    });
  } else if (userData.pickUpAdress && (userData.pickUpAdress.city || userData.pickUpAdress.adressDetails)) {
    shopPickupPresets.push({
      id: 'legacy_primary',
      label: Sp.legacyPickupLabel || 'Primary pickup address',
      city: userData.pickUpAdress.city || '',
      zone: userData.pickUpAdress.zone || '',
      adressDetails: userData.pickUpAdress.adressDetails || '',
      nearbyLandmark: userData.pickUpAdress.nearbyLandmark || '',
      pickupPhone: userData.pickUpAdress.pickupPhone || '',
      isDefault: true
    });
  }
}
var shopUserSnapshot = null;
if (typeof userData !== 'undefined' && userData) {
  shopUserSnapshot = {
    name: userData.name || '',
    phone: userData.phone != null ? String(userData.phone) : '',
    brandInfo: userData.brandInfo || {}
  };
}
%>

<div class="shop-page">
  <div class="shop-layout">
    <section class="shop-catalog products-column" aria-labelledby="shop-heading">
      <header class="shop-catalog__intro">
        <h1 id="shop-heading"><%= Sp.catalogHeading || 'Packaging materials' %></h1>
        <p><%= Sp.catalogIntro || 'Order supplies for fulfillment in one place. Prices and stock update from your catalog.' %></p>
      </header>

      <div class="shop-toolbar">
        <div class="shop-field-grow">
          <label class="visually-hidden" for="searchInput"><%= Sp.searchProductsLabel || 'Search products' %></label>
          <input type="search" id="searchInput" class="shop-input" placeholder="<%= Sp.searchPlaceholder || 'Search by name…' %>" autocomplete="off">
        </div>
        <div class="shop-field-fixed">
          <label class="visually-hidden" for="categoryFilter"><%= Sp.category || 'Category' %></label>
          <select id="categoryFilter" class="shop-select" aria-label="<%= Sp.filterByCategory || 'Filter by category' %>">
            <option value="all"><%= Sp.allCategories || 'All categories' %></option>
            <option value="normal-flyers"><%= Sp.catNormalFlyers || 'Normal flyers' %></option>
            <option value="smart-flyers"><%= Sp.catSmartFlyers || 'Smart flyers' %></option>
            <option value="boxes"><%= Sp.catBoxes || 'Boxes' %></option>
            <option value="stickers"><%= Sp.catStickers || 'Stickers' %></option>
            <option value="labels"><%= Sp.catLabels || 'Labels' %></option>
            <option value="tapes"><%= Sp.catTape || 'Tapes' %></option>
          </select>
        </div>
      </div>

      <div class="shop-pills category-tabs" role="tablist" aria-label="<%= Sp.categoryTabsAria || 'Product categories' %>">
        <button type="button" class="category-tab active" data-category="all" role="tab" aria-selected="true"><%= Sp.tabAll || 'All' %></button>
        <button type="button" class="category-tab" data-category="normal-flyers" role="tab" aria-selected="false"><%= Sp.catNormalFlyers || 'Normal flyers' %></button>
        <button type="button" class="category-tab" data-category="smart-flyers" role="tab" aria-selected="false"><%= Sp.catSmartFlyers || 'Smart flyers' %></button>
        <button type="button" class="category-tab" data-category="boxes" role="tab" aria-selected="false"><%= Sp.catBoxes || 'Boxes' %></button>
        <button type="button" class="category-tab" data-category="stickers" role="tab" aria-selected="false"><%= Sp.catStickers || 'Stickers' %></button>
        <button type="button" class="category-tab" data-category="labels" role="tab" aria-selected="false"><%= Sp.catLabels || 'Labels' %></button>
        <button type="button" class="category-tab" data-category="tapes" role="tab" aria-selected="false"><%= Sp.catTape || 'Tapes' %></button>
      </div>

      <div class="product-grid-header" aria-hidden="true">
        <span>—</span>
        <span><%= Sp.colProductGrid || 'Product' %></span>
        <span><%= Sp.colPriceGrid || 'Price' %></span>
        <span><%= Sp.colStockGrid || 'Stock' %></span>
        <span><%= Sp.colActionGrid || 'Action' %></span>
      </div>

      <% if (products && products.length > 0) { %>
      <% let currentCategory = ''; %>
      <% products.forEach(product => { %>
      <% if (product.category !== currentCategory) { currentCategory = product.category; %>
      <div class="category-header" data-category="<%= product.category %>">
        <span><%= shopCat[product.category] || (product.category || '').replace(/-/g, ' ') %></span>
        <% if (product.isNew) { %><span class="new-badge"><%= Sp.newBadge || 'New' %></span><% } %>
      </div>
      <% } %>

      <div class="product-card" data-category="<%= product.category %>" data-product-id="<%= product._id %>" data-product-name="<%= product.name %>" data-price="<%= product.finalPrice %>" data-stock="<%= product.stock %>" data-unit="<%= product.unit %>">
        <img src="<%= product.images && product.images.length > 0 ? product.images[0] : '/assets/images/product-placeholder.jpg' %>" alt="" class="product-image">
        <div class="product-info">
          <h2 class="product-title"><%= product.name %></h2>
          <% if (product.size) { %><p class="product-size"><%= Sp.size || 'Size:' %> <%= product.size %></p><% } %>
          <% if (product.packQuantity && product.packQuantity > 1) { %><p class="product-pack"><%= Sp.packOf || 'Pack of' %> <%= product.packQuantity %></p><% } %>
        </div>
        <div class="price-tag">
          <% if (product.discount > 0) { %><span class="original-price ltr-embed"><%= shopCur %> <%= product.price.toFixed(2) %></span><% } %>
          <div class="price-amount ltr-embed"><%= shopCur %> <%= product.finalPrice.toFixed(2) %></div>
          <div class="price-unit"><%= (Sp.perUnit || 'per {unit}').replace('{unit}', product.unit || (Sp.unitPiece || 'piece')) %></div>
        </div>
        <div class="product-stock-cell">
          <% if (product.stock === 0) { %>
          <span class="stock-pill stock-pill--out"><%= Sp.outOfStock || 'Out of stock' %></span>
          <% } else if (product.stock <= 5) { %>
          <span class="stock-pill stock-pill--low"><%= product.stock %> <%= product.unit %></span>
          <% } else { %>
          <span class="stock-pill stock-pill--ok"><%= product.stock %> <%= product.unit %></span>
          <% } %>
        </div>
        <div>
          <button type="button" class="add-btn" data-product-id="<%= product._id %>" data-product-name="<%= product.name %>" data-price="<%= product.finalPrice %>" data-category="<%= product.category %>" data-pack="<%= product.packQuantity || 1 %>" <%= product.stock === 0 ? 'disabled' : '' %>>
            <i class="bi bi-cart-plus" aria-hidden="true"></i>
            <%= Sp.addToCart || 'Add' %>
          </button>
        </div>
      </div>
      <% }); %>
      <% } else { %>
      <div class="shop-empty">
        <i class="bi bi-inbox" aria-hidden="true"></i>
        <p><%= Sp.noProducts || 'No products available right now.' %></p>
      </div>
      <% } %>
    </section>

    <aside class="cart-column" aria-label="<%= Sp.ariaOrderSummary || 'Order summary' %>">
      <div class="cart-header">
        <h2 class="mb-0"><%= Sp.cartSummary || 'Summary' %></h2>
        <div class="cart-icon-container">
          <i class="bi bi-bag" aria-hidden="true"></i>
          <span class="cart-badge" id="cartCount">0</span>
        </div>
      </div>

      <div id="cartItems" class="flex-grow-1 overflow-auto">
        <div class="empty-cart" id="emptyCart">
          <i class="bi bi-bag" aria-hidden="true"></i>
          <p><%= Sp.cartEmpty || 'Your cart is empty' %></p>
          <small><%= Sp.cartEmptyHint || 'Add lines from the list to build an order.' %></small>
        </div>
      </div>

      <div class="total-section">
        <div class="row-line"><span><%= Sp.cartSubtotal || 'Subtotal' %></span><span class="ltr-embed" id="subtotalAmount"><%= shopCur %> 0.00</span></div>
        <div class="row-line"><span><%= Sp.cartDelivery || 'Delivery' %></span><span class="ltr-embed" id="deliveryFee"><%= shopCur %> 0.00</span></div>
        <hr>
        <div class="total-row">
          <h5><%= Sp.cartTotal || 'Total' %></h5>
          <h4 class="ltr-embed" id="totalAmount"><%= shopCur %> 0.00</h4>
        </div>
        <button type="button" class="checkout-btn" onclick="proceedToCheckout()">
          <%= Sp.cartCheckout || 'Checkout' %> · <span class="ltr-embed"><%= shopCur %> <span id="displayTotal">0.00</span></span>
        </button>
      </div>
    </aside>
  </div>

  <div class="modal fade shop-delivery-modal" id="shopDeliveryModal" tabindex="-1" aria-labelledby="shopDeliveryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable shop-delivery-modal__dialog">
      <div class="modal-content shop-delivery-modal__content">
        <div class="modal-header shop-delivery-modal__header">
          <h2 class="modal-title h5 mb-0" id="shopDeliveryModalLabel"><%= Sp.deliveryDetailsTitle || 'Delivery details' %></h2>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p class="shop-delivery-modal__intro text-muted small mb-3"><%= Sp.deliveryModalIntro || '' %></p>
          <div id="shopDeliveryValidation" class="alert alert-danger py-2 px-3 small d-none" role="alert"></div>
          <form id="shopDeliveryForm" novalidate>
            <div class="mb-3">
              <label class="form-label fw-medium" for="deliveryPreset"><%= Sp.labelDeliverToPreset || 'Deliver to' %></label>
              <select class="form-select" id="deliveryPreset" name="deliveryPreset">
                <option value="__manual__"><%= Sp.optionManualAddress || 'Different address…' %></option>
                <% shopPickupPresets.forEach(function (p) { %>
                <option value="<%= p.id %>"><%= p.label %></option>
                <% }); %>
              </select>
            </div>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label" for="deliveryFullName"><%= Sp.labelFullName || 'Full name' %> <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="deliveryFullName" name="deliveryFullName" autocomplete="name" placeholder="<%= Sp.phFullName || '' %>">
              </div>
              <div class="col-md-6">
                <label class="form-label" for="deliveryPhone"><%= Sp.labelPhone || 'Phone' %> <span class="text-danger">*</span></label>
                <input type="tel" class="form-control" id="deliveryPhone" name="deliveryPhone" autocomplete="tel" placeholder="<%= Sp.phPhone || '' %>">
              </div>
            </div>
            <div id="shopDeliveryManualFields" class="row g-3">
              <div class="col-md-6">
                <label class="form-label" for="deliveryGovernment"><%= Sp.labelGovernment || 'Governorate' %> <span class="text-danger">*</span></label>
                <select class="form-select" id="deliveryGovernment" name="deliveryGovernment">
                  <option value=""><%= Sp.selectGovernment || 'Select' %></option>
                  <option value="Cairo"><%= Sp.governmentCairo || 'Cairo' %></option>
                  <option value="Giza"><%= Sp.governmentGiza || 'Giza' %></option>
                  <option value="Alexandria"><%= Sp.governmentAlex || 'Alexandria' %></option>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label" for="deliveryZone"><%= Sp.labelZone || 'Zone' %> <span class="text-danger">*</span></label>
                <select class="form-select" id="deliveryZone" name="deliveryZone">
                  <option value=""><%= Sp.selectZone || 'Select zone' %></option>
                </select>
              </div>
              <div class="col-12">
                <label class="form-label" for="deliveryAddress"><%= Sp.labelAddress || 'Address' %> <span class="text-danger">*</span></label>
                <textarea class="form-control" id="deliveryAddress" name="deliveryAddress" rows="3" placeholder="<%= Sp.phAddress || '' %>"></textarea>
              </div>
            </div>
            <div class="row g-3 mt-0">
              <div class="col-12">
                <label class="form-label" for="deliveryNotes"><%= Sp.labelNotesOptional || 'Notes (optional)' %></label>
                <textarea class="form-control" id="deliveryNotes" name="deliveryNotes" rows="2" placeholder="<%= Sp.phNotes || '' %>"></textarea>
              </div>
            </div>
          </form>
        </div>
        <div class="modal-footer shop-delivery-modal__footer">
          <button type="button" class="btn btn-light" data-bs-dismiss="modal"><%= Sp.btnCancel || 'Cancel' %></button>
          <button type="button" class="btn btn-primary shop-delivery-modal__primary" id="btnShopDeliveryContinue"><%= Sp.btnContinue || 'Continue' %></button>
        </div>
      </div>
    </div>
  </div>
</div>

<%- contentFor('FooterJs') %>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  window.__SHOP_I18N = <%- JSON.stringify(Sp && typeof Sp === 'object' ? Sp : {}) %>;
  window.__SHOP_PICKUP_PRESETS__ = <%- JSON.stringify(shopPickupPresets) %>;
  window.__SHOP_USER_SNAPSHOT__ = <%- JSON.stringify(shopUserSnapshot || {}) %>;

  const governmentCategories = {
    'Cairo': ['Cairo', 'Giza', 'Qalyubia'],
    'Alexandria': ['Alexandria', 'Beheira', 'Matrouh'],
    'Delta-Canal': [
      'Dakahlia', 'Sharqia', 'Monufia', 'Gharbia',
      'Kafr el-Sheikh', 'Damietta', 'Port Said', 'Ismailia', 'Suez'
    ],
    'Upper-RedSea': [
      'Fayoum', 'Beni Suef', 'Minya', 'Asyut',
      'Sohag', 'Qena', 'Luxor', 'Aswan', 'Red Sea',
      'North Sinai', 'South Sinai', 'New Valley'
    ]
  };

  /* Must match utils/fees.js orderBaseFees.Deliver (passed as shopDeliverFees from server) */
  const deliveryFees = <%- JSON.stringify(typeof shopDeliverFees !== 'undefined' && shopDeliverFees ? shopDeliverFees : { Cairo: 100, Alexandria: 100, 'Delta-Canal': 100, 'Upper-RedSea': 100 }) %>;

  function calculateDeliveryFee(government) {
    for (const [category, govs] of Object.entries(governmentCategories)) {
      if (govs.includes(government)) {
        return deliveryFees[category] ?? 100;
      }
    }
    return 100;
  }

  function syncCategoryTabs(value) {
    document.querySelectorAll('.category-tab').forEach((t) => {
      const on = t.dataset.category === value;
      t.classList.toggle('active', on);
      t.setAttribute('aria-selected', on ? 'true' : 'false');
    });
  }

  function escapeJsString(s) {
    return String(s ?? '')
      .replace(/\\/g, '\\\\')
      .replace(/'/g, "\\'")
      .replace(/\r?\n/g, ' ');
  }

  document.addEventListener('DOMContentLoaded', () => {
    class CartManager {
      constructor() {
        this.cart = new Map();
        this.deliveryFee = 0;
        this.loadFromStorage();
        this.initEventListeners();
        this.updateUI();
      }

      saveToStorage() {
        const cartData = {
          items: Array.from(this.cart.entries()),
          deliveryFee: this.deliveryFee,
          timestamp: Date.now()
        };
        localStorage.setItem('shopCart', JSON.stringify(cartData));
      }

      loadFromStorage() {
        try {
          const savedCart = localStorage.getItem('shopCart');
          if (savedCart) {
            const cartData = JSON.parse(savedCart);
            if (Date.now() - cartData.timestamp < 24 * 60 * 60 * 1000) {
              this.cart = new Map(cartData.items);
              this.deliveryFee = cartData.deliveryFee || 0;
            } else {
              localStorage.removeItem('shopCart');
            }
          }
        } catch (error) {
          console.log('Error loading cart from storage:', error);
          localStorage.removeItem('shopCart');
        }
      }

      clearStorage() {
        localStorage.removeItem('shopCart');
      }

      initEventListeners() {
        document.querySelectorAll('.add-btn').forEach((btn) => {
          if (!btn.disabled) {
            btn.addEventListener('click', () => {
              const productId = btn.dataset.productId;
              const product = btn.dataset.productName;
              const price = parseFloat(btn.dataset.price);
              const category = btn.dataset.category;
              const pack = btn.dataset.pack;
              const row = btn.closest('.product-card');
              const stock = parseInt(row.dataset.stock, 10);
              const unit = row.dataset.unit || (window.__SHOP_I18N.unitPiece || 'piece');

              if (!isNaN(price)) {
                this.addItem(productId, product, price, category, pack, stock, unit, 1);
              }
            });
          }
        });

        document.getElementById('searchInput').addEventListener('input', this.filterProducts.bind(this));
        document.getElementById('categoryFilter').addEventListener('change', (e) => {
          syncCategoryTabs(e.target.value);
          this.filterProducts();
        });

        document.querySelectorAll('.category-tab').forEach((tab) => {
          tab.addEventListener('click', () => {
            document.getElementById('categoryFilter').value = tab.dataset.category;
            syncCategoryTabs(tab.dataset.category);
            this.filterProducts();
          });
        });
      }

      addItem(productId, product, price, category, pack, stock, unit, quantity = 1) {
        const item = this.cart.get(productId) || {
          name: product,
          qty: 0,
          price: price,
          category: category,
          pack: pack,
          stock: stock,
          unit: unit
        };

        if (item.qty + quantity > stock) {
          const I = window.__SHOP_I18N || {};
          const msg = (I.stockLimitBody || 'Maximum available quantity is {stock}. You already have {qty} in cart.')
            .replace('{stock}', String(stock)).replace('{qty}', String(item.qty));
          Swal.fire({
            icon: 'warning',
            title: I.stockLimitTitle || 'Stock limit',
            text: msg,
            confirmButtonColor: '#E4A24A'
          });
          return;
        }

        item.qty += quantity;
        this.cart.set(productId, item);
        this.saveToStorage();
        this.updateUI();

        const I = window.__SHOP_I18N || {};
        Swal.fire({
          toast: true,
          position: 'top-end',
          icon: 'success',
          title: (I.addedToCart || '{product} added').replace('{product}', product),
          showConfirmButton: false,
          timer: 1500,
          timerProgressBar: true
        });
      }

      removeItem(productId) {
        const item = this.cart.get(productId);
        if (item && item.qty > 1) {
          item.qty--;
          this.cart.set(productId, item);
        } else {
          this.cart.delete(productId);
        }
        this.saveToStorage();
        this.updateUI();
      }

      removeItemCompletely(productId) {
        this.cart.delete(productId);
        this.saveToStorage();
        this.updateUI();
      }

      updateItemQuantity(productId, newQuantity) {
        const item = this.cart.get(productId);
        if (item) {
          if (newQuantity <= 0) {
            this.cart.delete(productId);
          } else if (newQuantity <= item.stock) {
            item.qty = newQuantity;
            this.cart.set(productId, item);
          } else {
            const I = window.__SHOP_I18N || {};
            Swal.fire({
              icon: 'warning',
              title: I.stockLimitTitle || 'Stock limit',
              text: (I.stockLimitMax || 'Maximum available quantity is {stock}').replace('{stock}', String(item.stock)),
              confirmButtonColor: '#E4A24A'
            });
            return;
          }
          this.saveToStorage();
          this.updateUI();
        }
      }

      calculateSubtotal() {
        return Array.from(this.cart.values()).reduce((total, item) => total + (item.qty * item.price), 0);
      }

      updateUI() {
        const cartItems = document.getElementById('cartItems');
        const emptyCart = document.getElementById('emptyCart');
        const cartCount = document.getElementById('cartCount');

        cartItems.innerHTML = '';
        cartItems.appendChild(emptyCart);

        const totalItems = Array.from(this.cart.values()).reduce((count, item) => count + item.qty, 0);
        cartCount.textContent = totalItems;

        if (this.cart.size === 0) {
          emptyCart.style.display = 'flex';
        } else {
          emptyCart.style.display = 'none';

          this.cart.forEach((item, productId) => {
            const cartItem = document.createElement('div');
            cartItem.className = 'cart-item mb-3 p-3';
            const I = window.__SHOP_I18N || {};
            const cur = I.currency || 'EGP';
            const packLbl = I.packOf || 'Pack of';
            const safeName = escapeJsString(item.name);
            const safeUnit = escapeJsString(item.unit || (I.unitPiece || 'piece'));
            const safeCat = escapeJsString(item.category || '');
            cartItem.innerHTML = `
              <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div class="flex-grow-1" style="min-width:140px;">
                  <h5 class="mb-1">${String(item.name).replace(/</g, '&lt;')}</h5>
                  <p class="text-muted mb-1 small ltr-embed">${cur} ${item.price.toFixed(2)} / ${item.unit || (I.unitPiece || 'piece')}</p>
                  <small class="text-muted">${item.pack > 1 ? `${packLbl} ${item.pack}` : '&nbsp;'}</small>
                </div>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                  <div class="quantity-control d-flex align-items-center">
                    <button type="button" class="btn btn-sm text-danger quantity-btn-cart"
                      onclick="cartManager.removeItem('${productId}')" title="${I.titleDecrease || 'Decrease'}">−</button>
                    <input type="number" class="quantity-input-cart"
                      value="${item.qty}" min="1" max="${item.stock}"
                      onchange="cartManager.updateItemQuantity('${productId}', parseInt(this.value, 10))"
                      style="width:52px;text-align:center;">
                    <button type="button" class="btn btn-sm text-success quantity-btn-cart"
                      onclick="cartManager.addItem('${productId}', '${safeName}', ${item.price}, '${safeCat}', '${item.pack}', ${item.stock}, '${safeUnit}', 1)" title="${I.titleIncrease || 'Increase'}">+</button>
                  </div>
                  <div class="text-dark fw-bold small ltr-embed">${cur} ${(item.qty * item.price).toFixed(2)}</div>
                  <button type="button" class="btn btn-sm text-danger" onclick="cartManager.removeItemCompletely('${productId}')" title="${I.titleRemove || 'Remove'}">×</button>
                </div>
              </div>
            `;
            cartItems.appendChild(cartItem);
          });
        }

        const subtotal = this.calculateSubtotal();
        const total = subtotal + this.deliveryFee;
        const cur = (window.__SHOP_I18N && window.__SHOP_I18N.currency) || 'EGP';

        document.getElementById('subtotalAmount').textContent = `${cur} ${subtotal.toFixed(2)}`;
        document.getElementById('deliveryFee').textContent = `${cur} ${this.deliveryFee.toFixed(2)}`;
        document.getElementById('totalAmount').textContent = `${cur} ${total.toFixed(2)}`;
        document.getElementById('displayTotal').textContent = total.toFixed(2);
      }

      filterProducts() {
        const searchInput = document.getElementById('searchInput').value.toLowerCase();
        const categoryFilter = document.getElementById('categoryFilter').value;

        document.querySelectorAll('.product-card').forEach((card) => {
          const titleEl = card.querySelector('.product-title');
          const productName = titleEl ? titleEl.textContent.toLowerCase() : '';
          const productCategory = card.dataset.category;
          const matchesSearch = productName.includes(searchInput);
          const matchesCategory = categoryFilter === 'all' || productCategory === categoryFilter;
          card.classList.toggle('d-none', !(matchesSearch && matchesCategory));
        });

        this.updateCategoryHeaders();
      }

      updateCategoryHeaders() {
        document.querySelectorAll('.category-header').forEach((header) => {
          let hasVisibleProducts = false;
          let current = header.nextElementSibling;
          while (current && !current.classList.contains('category-header')) {
            if (current.classList.contains('product-card') && !current.classList.contains('d-none')) {
              hasVisibleProducts = true;
              break;
            }
            current = current.nextElementSibling;
          }
          header.classList.toggle('d-none', !hasVisibleProducts);
        });
      }
    }

    window.cartManager = new CartManager();
  });

  const zoneOptions = {
    'Cairo': [
      { group: 'Cairo - Downtown & Central', zones: ['Downtown', 'Garden City', 'Zamalek', 'Dokki', 'Mohandessin', 'Agouza', 'Bulaq', 'Azbakeya', 'Abdeen', 'Attaba', 'Ramses', 'Qasr El Nil', 'Talaat Harb', 'Tahrir Square'] },
      { group: 'Cairo - East', zones: ['Nasr City', 'Nasr City - First Zone', 'Nasr City - Second Zone', 'Nasr City - Third Zone', 'Nasr City - Fourth Zone', 'Nasr City - Seventh Zone', 'Nasr City - Eighth Zone', 'Nasr City - Tenth Zone', 'Heliopolis', 'Heliopolis - Korba', 'Heliopolis - Triumph', 'Heliopolis - Cleopatra', 'Heliopolis - Almaza', 'Masr El Gedida', 'El Nozha', 'El Nozha El Gedida', 'El Zeitoun', 'Ain Shams', 'Ain Shams - Ezbet El Nakhl', 'El Marg', 'El Marg El Gedida'] },
      { group: 'Cairo - South & New Cairo', zones: ['Maadi', 'New Cairo', 'Fifth Settlement', 'First Settlement', 'Katameya', 'El Mokattam', 'El Basateen', 'Dar El Salam', 'El Rehab', 'El Tagamoa', 'El Shorouk', 'Badr City', 'Helwan', '15th of May City', 'Hadayek Helwan'] },
      { group: 'Cairo - West', zones: ['Mohandessin', 'Dokki', 'Boulaq El Dakrour', 'Imbaba', 'Agouza', 'Warraq', 'Rod El Farag', 'Shobra', 'Shobra El Kheima'] }
    ],
    'Giza': [
      { group: 'Giza - Central & East', zones: ['Giza Square', 'Dokki', 'Mohandessin', 'Agouza', 'Haram', 'Faisal', 'Imbaba', 'Kit Kat', 'El Manial', 'Boulaq El Dakrour', 'El Saff', 'El Hawamdeya'] },
      { group: 'Giza - West & 6th October', zones: ['Sheikh Zayed', '6th of October', 'Hadayek Al Ahram', 'Al Wahat Road', 'Smart Village', 'Egyptian Media Production City'] }
    ],
    'Alexandria': [
      { group: 'Alexandria - East', zones: ['Sidi Gaber', 'Sporting', 'Camp Caesar', 'Smouha', 'Victoria', 'Bolkly', 'Ibrahimia', 'Laurent', 'Loran'] },
      { group: 'Alexandria - Central & West', zones: ['Bahary', 'Anfushi', 'Manshiya', 'Attarin', 'Gomrok', 'Karmouz', 'Moharam Bek', 'Dekhela', 'Agami', 'Amreya', 'Borg El Arab', 'King Mariout', 'Wardian', 'Bacos'] },
      { group: 'Alexandria - East & Montaza', zones: ['Sidi Bishr', 'Miami', 'Asafra', 'Mandara', 'Montaza', 'Abu Qir', 'El Maamoura', 'El Max', 'Aboukir', 'Semouha', 'Fleming', 'El Zahria', 'Gianaclis'] }
    ]
  };

  function updateShopDeliveryZones() {
    const governmentSelect = document.getElementById('deliveryGovernment');
    const zoneSelect = document.getElementById('deliveryZone');
    if (!governmentSelect || !zoneSelect) return;
    const selectedGovernment = governmentSelect.value;
    const I = window.__SHOP_I18N || {};
    const previousZone = zoneSelect.value;
    zoneSelect.innerHTML = '<option value="">' + (I.selectZone || 'Select zone') + '</option>';
    if (selectedGovernment && zoneOptions[selectedGovernment]) {
      zoneOptions[selectedGovernment].forEach((group) => {
        const optgroup = document.createElement('optgroup');
        optgroup.label = group.group;
        group.zones.forEach((zone) => {
          const option = document.createElement('option');
          option.value = zone;
          option.textContent = zone;
          optgroup.appendChild(option);
        });
        zoneSelect.appendChild(optgroup);
      });
    }
    if (previousZone) {
      ensureZoneOptionExists(zoneSelect, previousZone);
      zoneSelect.value = previousZone;
    }
  }

  const SHOP_MANUAL_PICKUP = '__manual__';

  function getShopDeliveryModal() {
    return document.getElementById('shopDeliveryModal');
  }

  function showShopDeliveryValidation(msg) {
    const el = document.getElementById('shopDeliveryValidation');
    if (!el) return;
    el.textContent = msg || '';
    el.classList.toggle('d-none', !msg);
  }

  function hideShopDeliveryValidation() {
    showShopDeliveryValidation('');
  }

  function ensureZoneOptionExists(zoneSelect, zoneValue) {
    if (!zoneSelect || !zoneValue) return;
    const exists = Array.from(zoneSelect.options).some((o) => o.value === zoneValue);
    if (!exists) {
      const opt = document.createElement('option');
      opt.value = zoneValue;
      opt.textContent = zoneValue;
      zoneSelect.appendChild(opt);
    }
  }

  function toggleShopDeliveryManualFields() {
    const presetEl = document.getElementById('deliveryPreset');
    const wrap = document.getElementById('shopDeliveryManualFields');
    if (!wrap) return;
    const isManual = !presetEl || presetEl.value === SHOP_MANUAL_PICKUP;
    wrap.classList.toggle('d-none', !isManual);
  }

  function applyShopDeliveryPreset() {
    const presetEl = document.getElementById('deliveryPreset');
    const presetId = presetEl ? presetEl.value : SHOP_MANUAL_PICKUP;
    const form = document.getElementById('shopDeliveryForm');
    if (form) form.dataset.selectedPickupId = presetId;

    const govEl = document.getElementById('deliveryGovernment');
    const zoneEl = document.getElementById('deliveryZone');
    const addrEl = document.getElementById('deliveryAddress');

    if (presetId === SHOP_MANUAL_PICKUP) {
      if (govEl) govEl.value = '';
      if (zoneEl) {
        zoneEl.innerHTML = '<option value="">' + ((window.__SHOP_I18N || {}).selectZone || 'Select zone') + '</option>';
      }
      if (addrEl) addrEl.value = '';
      toggleShopDeliveryManualFields();
      return;
    }

    const presets = window.__SHOP_PICKUP_PRESETS__ || [];
    const p = presets.find((x) => x.id === presetId);
    if (!p) {
      toggleShopDeliveryManualFields();
      return;
    }

    const u = window.__SHOP_USER_SNAPSHOT__ || {};
    const brand = u.brandInfo || {};
    const defaultName = (u.name || '').trim() || (brand.contactPersonName || '').trim() || (brand.brandName || '').trim() || '';

    const fullNameEl = document.getElementById('deliveryFullName');
    const phoneEl = document.getElementById('deliveryPhone');

    if (fullNameEl) fullNameEl.value = defaultName;
    if (phoneEl) phoneEl.value = (p.pickupPhone || u.phone || '').trim();

    toggleShopDeliveryManualFields();
  }

  function initShopDeliveryPresetDefault() {
    const presetEl = document.getElementById('deliveryPreset');
    if (!presetEl) return;
    const presets = window.__SHOP_PICKUP_PRESETS__ || [];
    if (presets.length === 0) {
      presetEl.value = SHOP_MANUAL_PICKUP;
      return;
    }
    const def = presets.find((x) => x.isDefault) || presets[0];
    presetEl.value = def.id;
  }

  function validateShopDeliveryForm() {
    const I = window.__SHOP_I18N || {};
    const fullName = (document.getElementById('deliveryFullName')?.value || '').trim();
    const phoneNumber = (document.getElementById('deliveryPhone')?.value || '').trim();
    const notes = (document.getElementById('deliveryNotes')?.value || '').trim();
    const presetEl = document.getElementById('deliveryPreset');
    const pickupAddressId = presetEl ? presetEl.value : SHOP_MANUAL_PICKUP;

    if (!fullName || !phoneNumber) {
      showShopDeliveryValidation(I.deliveryValidationError || I.validationCompleteFields || 'Please complete all required fields');
      return null;
    }

    if (pickupAddressId === SHOP_MANUAL_PICKUP) {
      const government = (document.getElementById('deliveryGovernment')?.value || '').trim();
      const zone = (document.getElementById('deliveryZone')?.value || '').trim();
      const address = (document.getElementById('deliveryAddress')?.value || '').trim();
      if (!government || !zone || !address) {
        showShopDeliveryValidation(I.deliveryValidationError || I.validationCompleteFields || 'Please complete all required fields');
        return null;
      }
      hideShopDeliveryValidation();
      return {
        fullName,
        phoneNumber,
        government,
        zone,
        address,
        notes,
        pickupAddressId: SHOP_MANUAL_PICKUP,
        isSavedPickup: false
      };
    }

    const presets = window.__SHOP_PICKUP_PRESETS__ || [];
    const p = presets.find((x) => x.id === pickupAddressId);
    if (!p) {
      showShopDeliveryValidation(I.deliveryValidationError || I.validationCompleteFields || 'Please complete all required fields');
      return null;
    }

    const government = (p.city || '').trim();
    const zone = (p.zone || '').trim();
    const address = [p.adressDetails, p.nearbyLandmark].filter((x) => x && String(x).trim()).join(' — ').trim() || '—';
    if (!government || !zone) {
      showShopDeliveryValidation(I.deliveryValidationError || I.validationCompleteFields || 'Please complete all required fields');
      return null;
    }

    hideShopDeliveryValidation();
    return {
      fullName,
      phoneNumber,
      government,
      zone,
      address,
      notes,
      pickupAddressId,
      isSavedPickup: true
    };
  }

  function openShopDeliveryModal() {
    hideShopDeliveryValidation();
    initShopDeliveryPresetDefault();
    applyShopDeliveryPreset();
    toggleShopDeliveryManualFields();
    const el = getShopDeliveryModal();
    if (el && typeof bootstrap !== 'undefined') {
      bootstrap.Modal.getOrCreateInstance(el).show();
    }
  }

  async function proceedToCheckout() {
    const I = window.__SHOP_I18N || {};
    const subtotal = cartManager.calculateSubtotal();
    if (subtotal <= 0) {
      Swal.fire({
        title: I.checkoutEmptyTitle || 'Empty cart',
        text: I.checkoutEmptyText || 'Add at least one product before checkout.',
        icon: 'info',
        confirmButtonColor: '#E4A24A',
        confirmButtonText: I.btnOk || 'OK'
      });
      return;
    }

    openShopDeliveryModal();
  }

  async function continueShopCheckoutAfterDelivery() {
    const I = window.__SHOP_I18N || {};
    const formValues = validateShopDeliveryForm();
    if (!formValues) return;

    const modalEl = getShopDeliveryModal();
    if (modalEl && typeof bootstrap !== 'undefined') {
      bootstrap.Modal.getInstance(modalEl)?.hide();
    }

    const subtotal = cartManager.calculateSubtotal();

    const deliveryFee = calculateDeliveryFee(formValues.government);
    cartManager.deliveryFee = deliveryFee;
    cartManager.updateUI();

    const total = subtotal + deliveryFee;
    const cur = I.currency || 'EGP';

    const result = await Swal.fire({
      title: I.confirmOrderTitle || 'Confirm order',
      html: `
        <div class="text-start">
          <div class="d-flex justify-content-between mb-2"><span>${I.rowSubtotal || 'Subtotal'}</span><strong class="ltr-embed">${cur} ${subtotal.toFixed(2)}</strong></div>
          <div class="d-flex justify-content-between mb-2"><span>${I.rowDelivery || 'Delivery'}</span><strong class="ltr-embed">${cur} ${deliveryFee.toFixed(2)}</strong></div>
          <hr>
          <div class="d-flex justify-content-between mb-3"><span class="fw-bold">${I.rowTotal || 'Total'}</span><span class="fw-bold ltr-embed" style="color:#1a1d21;">${cur} ${total.toFixed(2)}</span></div>
          <p class="small text-muted mb-1">${I.deliverTo || 'Deliver to'}</p>
          <p class="mb-1"><strong>${formValues.fullName}</strong></p>
          <p class="mb-1">${formValues.phoneNumber}</p>
          <p class="mb-1">${formValues.address}</p>
          <p class="mb-1">${formValues.zone}, ${formValues.government}</p>
          ${formValues.notes ? `<p class="mt-2 small text-muted"><em>${formValues.notes}</em></p>` : ''}
        </div>
      `,
      icon: 'question',
      showCancelButton: true,
      confirmButtonColor: '#E4A24A',
      cancelButtonColor: '#6c757d',
      confirmButtonText: I.btnPlaceOrder || 'Place order',
      cancelButtonText: I.btnCancel || 'Cancel',
      width: '560px'
    });

    if (!result.isConfirmed) return;

    const items = [];
    cartManager.cart.forEach((item, productId) => {
      items.push({ productId: productId, quantity: item.qty });
    });

    const orderData = {
      items: items,
      fullName: formValues.fullName,
      phoneNumber: formValues.phoneNumber,
      notes: formValues.notes
    };
    if (formValues.isSavedPickup && formValues.pickupAddressId && formValues.pickupAddressId !== SHOP_MANUAL_PICKUP) {
      orderData.pickupAddressId = formValues.pickupAddressId;
    } else {
      orderData.address = formValues.address;
      orderData.government = formValues.government;
      orderData.zone = formValues.zone;
    }

    try {
      const response = await fetch('/business/api/shop/orders', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(orderData)
      });

      const data = await response.json();

      if (response.ok) {
        await Swal.fire({
          title: I.orderPlacedTitle || 'Order placed',
          html: `<p>${I.orderPlacedLine || 'Order number:'} <strong class="ltr-embed">${data.order.orderNumber}</strong></p><p class="small text-muted mb-0">${I.orderPlacedTrackHint || ''}</p>`,
          icon: 'success',
          confirmButtonColor: '#E4A24A'
        });

        cartManager.cart.clear();
        cartManager.deliveryFee = 0;
        cartManager.clearStorage();
        cartManager.updateUI();

        setTimeout(() => {
          window.location.href = '/business/shop/orders';
        }, 1200);
      } else {
        throw new Error(data.error || 'Failed to place order');
      }
    } catch (error) {
      console.error('Error placing order:', error);
      Swal.fire({
        title: I.genericError || 'Error',
        text: error.message || (I.placeOrderFailed || 'Could not place order. Try again.'),
        icon: 'error',
        confirmButtonColor: '#E4A24A'
      });
    }
  }

  document.addEventListener('DOMContentLoaded', function () {
    const btnCont = document.getElementById('btnShopDeliveryContinue');
    if (btnCont) {
      btnCont.addEventListener('click', () => {
        continueShopCheckoutAfterDelivery();
      });
    }
    const presetSel = document.getElementById('deliveryPreset');
    if (presetSel) {
      presetSel.addEventListener('change', applyShopDeliveryPreset);
    }
    const govSel = document.getElementById('deliveryGovernment');
    if (govSel) {
      govSel.addEventListener('change', () => {
        const zoneSelect = document.getElementById('deliveryZone');
        if (zoneSelect) zoneSelect.value = '';
        updateShopDeliveryZones();
      });
    }
  });
</script>
