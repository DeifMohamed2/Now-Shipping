<%- contentFor('HeaderCss') %>
<%-include("../partials/title-meta", { "title" : title }) %>
<link rel="stylesheet" href="/assets/css/rtl-support.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
  @import url('https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&family=Tajawal:wght@400;500;700&display=swap');

  :root {
    --primary: #F39720;
    --dark: #2B71B9;
    --gray-100: #F9FAFB;
    --gray-500: #6B7280;
    --gray-800: #1F2937;
    --success: #10B981;
    --success-bg: #D1FAE5;
    --warn: #D97706;
    --warn-bg: #FEF3C7;
    --error: #DC2626;
    --error-bg: #FEE2E2;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Inter', system-ui, sans-serif;
    background: var(--gray-100);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  [dir="rtl"] body {
    font-family: 'Cairo', 'Tajawal', sans-serif;
  }

  .animated-background {
    position: fixed;
    inset: 0;
    z-index: -1;
    background: var(--gray-100);
    opacity: 0.9;
    overflow: hidden;
  }

  .ev-container {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem 1.25rem 2.5rem;
  }

  .ev-card {
    width: 100%;
    max-width: 440px;
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 10px 40px rgba(43, 113, 185, 0.08), 0 2px 8px rgba(0,0,0,0.04);
    padding: 2.25rem 1.75rem;
    text-align: center;
  }

  [dir="rtl"] .ev-card {
    text-align: center;
  }

  .ev-icon-wrap {
    width: 88px;
    height: 88px;
    margin: 0 auto 1.25rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
  }

  .ev-icon-wrap.success {
    background: var(--success-bg);
    color: var(--success);
  }

  .ev-icon-wrap.warn {
    background: var(--warn-bg);
    color: var(--warn);
  }

  .ev-icon-wrap.error {
    background: var(--error-bg);
    color: var(--error);
  }

  .ev-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--gray-800);
    margin-bottom: 0.65rem;
    line-height: 1.3;
  }

  .ev-subtitle {
    font-size: 0.95rem;
    color: var(--gray-500);
    line-height: 1.55;
    margin-bottom: 1.75rem;
  }

  .ev-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .ev-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .ev-btn:active {
    transform: scale(0.98);
  }

  .ev-btn-primary {
    background: linear-gradient(135deg, var(--dark), #1e5a94);
    color: #fff;
    box-shadow: 0 4px 14px rgba(43, 113, 185, 0.35);
  }

  .ev-btn-primary:hover {
    color: #fff;
    box-shadow: 0 6px 20px rgba(43, 113, 185, 0.4);
  }

  .ev-btn-secondary {
    background: #fff;
    color: var(--dark);
    border: 2px solid #E5E7EB;
  }

  .ev-btn-secondary:hover {
    border-color: var(--dark);
    color: var(--dark);
  }

  .ev-btn-accent {
    background: linear-gradient(135deg, var(--primary), #E8890A);
    color: #fff;
    box-shadow: 0 4px 14px rgba(243, 151, 32, 0.35);
  }

  .ev-btn-accent:hover {
    color: #fff;
  }

  @media (max-width: 480px) {
    .ev-card { padding: 1.75rem 1.25rem; }
    .ev-title { font-size: 1.35rem; }
  }
</style>

<%- contentFor('body') %>
<% const ev = (translation && translation.auth && translation.auth.emailVerified) || {}; %>
<% const st = typeof verificationStatus !== 'undefined' ? verificationStatus : 'invalid'; %>
<% const isOk = st === 'success'; %>
<% const isExpired = st === 'expired'; %>
<% const isError = st === 'error'; %>
<%- include('../partials/navbar', { activePage: '' }) %>

<div class="animated-background"></div>

<div class="ev-container">
  <div class="ev-card">
    <% if (isOk) { %>
      <div class="ev-icon-wrap success">
        <i class="ri-checkbox-circle-fill"></i>
      </div>
      <h1 class="ev-title"><%= ev.successTitle || 'Your email is verified' %></h1>
      <p class="ev-subtitle"><%= ev.successSubtitle || '' %></p>
    <% } else if (isExpired) { %>
      <div class="ev-icon-wrap warn">
        <i class="ri-time-fill"></i>
      </div>
      <h1 class="ev-title"><%= ev.expiredTitle || 'This link has expired' %></h1>
      <p class="ev-subtitle"><%= ev.expiredSubtitle || '' %></p>
    <% } else if (isError) { %>
      <div class="ev-icon-wrap error">
        <i class="ri-error-warning-fill"></i>
      </div>
      <h1 class="ev-title"><%= ev.errorTitle || 'Something went wrong' %></h1>
      <p class="ev-subtitle"><%= ev.errorSubtitle || '' %></p>
    <% } else { %>
      <div class="ev-icon-wrap warn">
        <i class="ri-links-line"></i>
      </div>
      <h1 class="ev-title"><%= ev.invalidTitle || 'This link is not valid' %></h1>
      <p class="ev-subtitle"><%= ev.invalidSubtitle || '' %></p>
    <% } %>

    <div class="ev-actions">
      <% if (sessionContinue && sessionContinue.href) { %>
        <a class="ev-btn ev-btn-primary" href="<%= sessionContinue.href %>">
          <i class="ri-dashboard-line"></i>
          <%= ev.continueDashboard || 'Go to dashboard' %>
        </a>
      <% } %>
      <% const hideSignIn = isOk && sessionContinue && sessionContinue.href; %>
      <% if (!hideSignIn) { %>
        <a class="ev-btn <%= (sessionContinue && sessionContinue.href) ? 'ev-btn-secondary' : 'ev-btn-primary' %>" href="/login<%= currentLang && currentLang !== 'en' ? '?lang=' + encodeURIComponent(currentLang) : '' %>">
          <i class="ri-login-box-line"></i>
          <%= ev.signIn || (translation && translation.auth && translation.auth.login && translation.auth.login.signIn) || 'Sign in' %>
        </a>
      <% } %>
      <a class="ev-btn ev-btn-secondary" href="/<%= currentLang && currentLang !== 'en' ? '?lang=' + encodeURIComponent(currentLang) : '' %>">
        <i class="ri-home-4-line"></i>
        <%= ev.backHome || 'Back to home' %>
      </a>
    </div>
  </div>
</div>
