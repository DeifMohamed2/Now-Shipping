<%- contentFor('HeaderCss') %>
<link rel="stylesheet" href="/assets/css/rtl-support.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
  @import url('https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&family=Tajawal:wght@400;700&display=swap');
  :root {
    --primary: #F39720;
    --secondary: #FDB614;
    --gray-100: #F9FAFB;
    --gray-200: #E5E7EB;
    --gray-500: #6B7280;
    --gray-800: #1F2937;
    --white: #FFFFFF;
  }
  body { font-family: Inter, system-ui, sans-serif; background: var(--gray-100); margin: 0; min-height: 100vh; }
  [dir="rtl"] body { font-family: Cairo, Tajawal, sans-serif; }
  .fp-container { flex: 1; display: flex; align-items: center; justify-content: center; padding: 1.5rem 20px 2rem; min-height: 70vh; }
  .fp-card {
    background: var(--white);
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    width: 100%;
    max-width: 420px;
    padding: 40px;
  }
  .fp-header { text-align: center; margin-bottom: 20px; }
  .fp-title { font-size: 22px; font-weight: 700; color: var(--gray-800); margin: 0 0 8px; }
  .fp-sub { font-size: 14px; color: var(--gray-500); margin: 0; line-height: 1.5; }
  .fp-steps-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    margin-bottom: 24px;
  }
  .fp-steps-bar .seg {
    flex: 1;
    max-width: 72px;
    height: 4px;
    background: var(--gray-200);
    border-radius: 2px;
    margin: 0 4px;
    transition: background 0.2s ease;
  }
  .fp-steps-bar .seg.done,
  .fp-steps-bar .seg.active { background: var(--primary); }
  .fp-step { display: none; }
  .fp-step.is-active { display: block; }
  .fp-step-badge {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 8px;
  }
  .fp-step-title { font-size: 18px; font-weight: 700; color: var(--gray-800); margin: 0 0 8px; }
  .fp-step-desc { font-size: 14px; color: var(--gray-500); margin: 0 0 20px; line-height: 1.5; }
  [dir="rtl"] .fp-step-title,
  [dir="rtl"] .fp-step-desc { text-align: right; }
  .form-group { margin-bottom: 18px; }
  .form-label { display: block; font-size: 14px; font-weight: 500; color: var(--gray-800); margin-bottom: 8px; }
  [dir="rtl"] .form-label { text-align: right; }
  .form-control {
    width: 100%; height: 44px; padding: 0 16px; font-size: 14px;
    border: 1px solid var(--gray-200); border-radius: 8px; box-sizing: border-box;
  }
  [dir="rtl"] .form-control { text-align: right; direction: rtl; }
  .form-control:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(243,151,32,0.12); }
  .btn-primary {
    width: 100%; height: 44px; border: none; border-radius: 8px;
    background: var(--primary); color: #fff; font-size: 14px; font-weight: 600; cursor: pointer;
  }
  .btn-primary:hover { background: var(--secondary); }
  .btn-primary:disabled { opacity: 0.7; cursor: not-allowed; }
  .btn-loading { position: relative; color: transparent !important; }
  .btn-loading::after {
    content: ""; position: absolute; width: 20px; height: 20px; top: 50%; left: 50%; margin: -10px 0 0 -10px;
    border: 2px solid rgba(255,255,255,0.35); border-top-color: #fff; border-radius: 50%; animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .alert { padding: 12px 16px; border-radius: 8px; margin-bottom: 16px; font-size: 14px; display: none; }
  .alert.show { display: block; }
  .alert-success { background: #ECFDF5; color: #065F46; border: 1px solid #A7F3D0; }
  .alert-danger { background: #FEF2F2; color: #B91C1C; border: 1px solid #FECACA; }
  .fp-back { text-align: center; margin-top: 20px; font-size: 14px; }
  .fp-back a { color: var(--primary); text-decoration: none; font-weight: 500; }
  .fp-back a:hover { text-decoration: underline; }
</style>

<%- contentFor('body') %>
<%- include('../partials/navbar', { activePage: '' }) %>

<div class="fp-container">
  <div class="fp-card">
    <div class="fp-header">
      <img src="/assets/rImages/logo.png" alt="Now Shipping" height="56" style="margin-bottom:12px;">
      <h1 class="fp-title"><%= translation.auth.forgotPassword.title %></h1>
      <p class="fp-sub"><%= translation.auth.forgotPassword.subtitle %></p>
    </div>

    <div class="fp-steps-bar" aria-hidden="true">
      <div class="seg active" data-step-bar="1"></div>
      <div class="seg" data-step-bar="2"></div>
      <div class="seg" data-step-bar="3"></div>
    </div>

    <div class="alert alert-success" id="alertSuccess" role="alert"></div>
    <div class="alert alert-danger" id="alertError" role="alert"></div>

    <div id="step1" class="fp-step is-active" data-step="1">
      <span class="fp-step-badge"><%= translation.auth.forgotPassword.step1Badge %></span>
      <h2 class="fp-step-title"><%= translation.auth.forgotPassword.step1Title %></h2>
      <p class="fp-step-desc"><%= translation.auth.forgotPassword.step1Subtitle %></p>
      <div class="form-group">
        <label class="form-label" for="fp-email"><%= translation.auth.forgotPassword.emailLabel %></label>
        <input type="email" class="form-control" id="fp-email" autocomplete="email" inputmode="email">
      </div>
      <button type="button" class="btn-primary" id="btn-send-otp"><%= translation.auth.forgotPassword.sendCode %></button>
    </div>

    <div id="step2" class="fp-step" data-step="2">
      <span class="fp-step-badge"><%= translation.auth.forgotPassword.step2Badge %></span>
      <h2 class="fp-step-title"><%= translation.auth.forgotPassword.step2Title %></h2>
      <p class="fp-step-desc"><%= translation.auth.forgotPassword.step2Subtitle %></p>
      <div class="form-group">
        <label class="form-label" for="fp-otp"><%= translation.auth.forgotPassword.otpLabel %></label>
        <input type="text" class="form-control" id="fp-otp" inputmode="numeric" maxlength="8" autocomplete="one-time-code">
      </div>
      <button type="button" class="btn-primary" id="btn-verify-otp"><%= translation.auth.forgotPassword.verifyOtp %></button>
    </div>

    <div id="step3" class="fp-step" data-step="3">
      <span class="fp-step-badge"><%= translation.auth.forgotPassword.step3Badge %></span>
      <h2 class="fp-step-title"><%= translation.auth.forgotPassword.step3Title %></h2>
      <p class="fp-step-desc"><%= translation.auth.forgotPassword.step3Subtitle %></p>
      <div class="form-group">
        <label class="form-label" for="fp-new"><%= translation.auth.forgotPassword.newPassword %></label>
        <input type="password" class="form-control" id="fp-new" autocomplete="new-password" minlength="8">
      </div>
      <div class="form-group">
        <label class="form-label" for="fp-confirm"><%= translation.auth.forgotPassword.confirmPassword %></label>
        <input type="password" class="form-control" id="fp-confirm" autocomplete="new-password" minlength="8">
      </div>
      <button type="button" class="btn-primary" id="btn-reset"><%= translation.auth.forgotPassword.resetPassword %></button>
    </div>

    <div class="fp-back">
      <a href="/login"><%= translation.auth.forgotPassword.backToLogin %></a>
    </div>
  </div>
</div>

<%- contentFor('FooterJs') %>
<script>
  window.FP_I18N = {
    invalidEmail: <%- JSON.stringify(translation.auth.forgotPassword.invalidEmail) %>,
    passwordMin: <%- JSON.stringify(translation.auth.forgotPassword.passwordMin) %>,
    passwordMismatch: <%- JSON.stringify(translation.auth.forgotPassword.passwordMismatch) %>,
    networkError: <%- JSON.stringify(translation.auth.forgotPassword.networkError) %>,
    sendFailed: <%- JSON.stringify(translation.auth.forgotPassword.sendFailed) %>,
    invalidOtp: <%- JSON.stringify(translation.auth.messages.invalidOtp) %>,
    sessionExpired: <%- JSON.stringify(translation.auth.forgotPassword.sessionExpired) %>,
  };
</script>
<script src="/assets/rJS/forgot-password.js"></script>
<script src="/assets/rJS/multilingual.js"></script>
