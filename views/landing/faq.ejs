<%- contentFor('HeaderCss') %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/rCSS/landing-pages.css">

<%- contentFor('body') %>
<% var F = translation.pages.faq; %>
<div class="lp-page">
  <%- include('../partials/navbar', { activePage: 'faq' }) %>

  <section class="lp-hero">
    <div class="lp-container" style="text-align:center;max-width:640px;margin:0 auto">
      <h1><%= F.title %></h1>
      <p class="lead" style="margin-left:auto;margin-right:auto"><%= F.subtitle %></p>
  </div>
</section>

  <section class="lp-section lp-section--alt">
    <div class="lp-container" style="max-width:760px">
      <details class="lp-faq-item" open><summary><%= F.question1 %></summary><div class="lp-faq-body"><%= F.answer1 %></div></details>
      <details class="lp-faq-item"><summary><%= F.question2 %></summary><div class="lp-faq-body"><%= F.answer2 %></div></details>
      <details class="lp-faq-item"><summary><%= F.question3 %></summary><div class="lp-faq-body"><%= F.answer3 %> <a href="/tracking"><%= translation.navigation.tracking %></a>.</div></details>
      <details class="lp-faq-item"><summary><%= F.question4 %></summary><div class="lp-faq-body"><%= F.answer4 %></div></details>
  </div>
</section>

  <section class="lp-section">
    <div class="lp-container">
      <div class="lp-cta">
        <h2><%= translation.landing.cta.title %></h2>
        <p><%= translation.landing.cta.subtitle %></p>
        <a href="/register" class="lp-btn lp-btn--primary"><%= translation.navigation.register %></a>
    </div>
  </div>
</section>

  <%- include('../partials/landing-footer') %>
    </div>
