<%- contentFor('HeaderCss') %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/rCSS/landing-pages.css">

<%- contentFor('body') %>
<% var PP = translation.pages.privacyPolicy; %>
<div class="lp-page">
  <%- include('../partials/navbar', { activePage: '' }) %>

  <section class="lp-hero" style="padding-bottom:1.5rem">
    <div class="lp-container" style="text-align:center">
      <h1><%= PP.title %></h1>
      <p class="lead" style="margin:0 auto;max-width:520px"><%= PP.subtitle %></p>
    </div>
  </section>

  <section class="lp-section lp-section--alt" style="padding-top:0">
    <div class="lp-container">
      <article class="lp-doc">
        <p class="lp-meta"><i class="fas fa-calendar-days"></i> <%= PP.lastUpdated %></p>
        <h2><i class="fas fa-circle-info" style="color:var(--lp-primary)"></i> <%= PP.introduction %></h2>
        <p><%= PP.introductionText %></p>
        <h2><i class="fas fa-database" style="color:var(--lp-primary)"></i> <%= PP.informationCollection %></h2>
        <p><%= PP.informationCollectionText %></p>
        <h2><i class="fas fa-gears" style="color:var(--lp-primary)"></i> <%= PP.informationUse %></h2>
        <p><%= PP.informationUseText %></p>
        <h2><i class="fas fa-share-nodes" style="color:var(--lp-primary)"></i> <%= PP.informationSharing %></h2>
        <p><%= PP.informationSharingText %></p>
        <p style="margin-top:2rem;font-size:.9rem"><a href="/"><%= translation.navigation.home %></a> · <a href="/faq"><%= translation.navigation.faq %></a></p>
      </article>
    </div>
  </section>

  <%- include('../partials/landing-footer') %>
</div>
