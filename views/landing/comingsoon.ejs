<%- contentFor('HeaderCss') %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/rCSS/landing-pages.css">
<style>
  .lp-page-coming{display:flex;flex-direction:column;min-height:100vh}
  .cs-wrap{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:2.5rem 1.25rem 3rem;text-align:center;background:linear-gradient(160deg,#f8fafc 0%,#fff 40%,rgba(243,151,32,.08) 100%);position:relative;overflow:hidden}
  .cs-wrap::before,.cs-wrap::after{content:'';position:absolute;border-radius:50%;pointer-events:none}
  .cs-wrap::before{width:min(90vw,420px);height:min(90vw,420px);background:radial-gradient(circle,rgba(243,151,32,.12),transparent 65%);top:-10%;right:-15%}
  .cs-wrap::after{width:min(70vw,320px);height:min(70vw,320px);background:radial-gradient(circle,rgba(22,33,62,.08),transparent 70%);bottom:-5%;left:-10%}
  .cs-card{position:relative;z-index:1;max-width:440px;background:#fff;border-radius:var(--lp-radius);padding:2.5rem 2rem;box-shadow:0 20px 50px rgba(26,26,46,.12);border:1px solid rgba(26,26,46,.06)}
  .cs-card h1{font-size:clamp(1.75rem,4vw,2.25rem);color:var(--lp-navy);margin:0 0 .75rem;font-weight:800}
  .cs-card p{color:var(--lp-muted);margin:0 0 1.5rem;font-size:1rem;line-height:1.6}
  .cs-count{display:flex;gap:.75rem;justify-content:center;margin-bottom:1.5rem;font-variant-numeric:tabular-nums}
  .cs-count span{background:var(--lp-navy);color:#fff;font-weight:700;padding:.5rem .65rem;border-radius:.5rem;font-size:1.25rem;min-width:2.5rem}
  .cs-email{display:flex;flex-direction:column;gap:.5rem;text-align:left}
  .cs-email input{padding:.85rem 1rem;border-radius:.65rem;border:2px solid rgba(26,26,46,.1);font-family:inherit;font-size:.95rem}
  .cs-email input:focus{outline:none;border-color:var(--lp-primary)}
</style>

<%- contentFor('body') %>
<% var C = translation.pages.comingSoon; %>
<div class="lp-page-coming">
  <%- include('../partials/navbar', { activePage: '' }) %>
<div class="cs-wrap">
  <div class="cs-card">
    <div style="font-size:3rem;color:var(--lp-primary);margin-bottom:.5rem"><i class="fas fa-hourglass-half"></i></div>
    <h1><%= C.title %></h1>
    <p><%= C.subtitle %></p>
    <p style="font-size:.9rem;margin-bottom:1rem"><%= C.description %></p>
    <div class="cs-count" id="csCount" aria-live="polite">
      <span id="csD">00</span><span id="csH">00</span><span id="csM">00</span><span id="csS">00</span>
    </div>
    <p style="font-size:.75rem;color:var(--lp-muted);margin:0 0 .25rem">D&nbsp;&nbsp;H&nbsp;&nbsp;M&nbsp;&nbsp;S</p>
    <form class="cs-email" onsubmit="return false" aria-label="Notify">
      <label for="csEmail" style="font-size:.8rem;font-weight:600;color:var(--lp-navy)"><%= C.email %></label>
      <input id="csEmail" type="email" placeholder="<%= C.emailPlaceholder %>" autocomplete="email" />
      <button type="button" class="lp-btn lp-btn--primary" style="justify-content:center;margin-top:.25rem"><%= C.notifyMe %></button>
    </form>
  </div>
</div>
<%- include('../partials/landing-footer') %>
</div>

<%- contentFor('FooterJs') %>
<script>
(function(){
  var end = new Date(); end.setDate(end.getDate() + 14);
  function tick(){
    var now = new Date().getTime(), t = end - now;
    if (t < 0) t = 0;
    var d = Math.floor(t / 864e5), h = Math.floor((t % 864e5) / 36e5), m = Math.floor((t % 36e5) / 6e4), s = Math.floor((t % 6e4) / 1e3);
    function z(n){ return (n<10?'0':'')+n; }
    var el = function(id){ return document.getElementById(id); };
    if (el('csD')) el('csD').textContent = z(d);
    if (el('csH')) el('csH').textContent = z(h);
    if (el('csM')) el('csM').textContent = z(m);
    if (el('csS')) el('csS').textContent = z(s);
  }
  tick();
  setInterval(tick, 1000);
})();
</script>
