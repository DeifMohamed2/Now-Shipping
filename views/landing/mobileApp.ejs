<%- contentFor('HeaderCss') %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/rCSS/landing-pages.css">
<style>
/* ── Mobile App Page ───────────────────────────────────────────────── */
.ma-hero {
  padding: 5.5rem 0 5rem;
  background: linear-gradient(135deg, #fafbff 0%, #fff9f0 60%, #fffff9 100%);
  position: relative;
  overflow: hidden;
}
.ma-hero::before {
  content: '';
  position: absolute;
  width: 600px;
  height: 600px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(243,151,32,.10) 0%, transparent 65%);
  right: -80px;
  top: -120px;
  pointer-events: none;
}
.ma-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
  max-width: 1140px;
  margin: 0 auto;
  padding: 0 1.5rem;
}
@media (max-width: 860px) {
  .ma-grid { grid-template-columns: 1fr; gap: 3rem; text-align: center; }
}

/* ── Copy ── */
.ma-copy { position: relative; z-index: 1; }
.ma-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  background: rgba(243,151,32,.12);
  color: #e07d0a;
  font-size: .75rem;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  border-radius: 999px;
  padding: .32rem 1rem;
  margin-bottom: 1.1rem;
}
.ma-copy h1 {
  font-size: clamp(2rem, 4vw, 2.9rem);
  font-weight: 800;
  color: #1a1a2e;
  line-height: 1.12;
  margin: 0 0 .9rem;
  letter-spacing: -.02em;
}
.ma-copy p {
  font-size: 1.05rem;
  color: #64748b;
  line-height: 1.72;
  margin: 0 0 2.25rem;
  max-width: 36ch;
}
@media (max-width: 860px) { .ma-copy p { max-width: none; } }

/* ── Store buttons — hard-coded ── */
.ma-badges {
  display: flex;
  flex-direction: column;
  gap: .85rem;
  align-items: flex-start;
}
@media (max-width: 860px) { .ma-badges { align-items: center; } }

.ma-badge {
  display: inline-flex;
  align-items: center;
  gap: .85rem;
  width: 190px;
  padding: .75rem 1.15rem;
  background: #1a1a2e;
  border-radius: 14px;
  text-decoration: none;
  color: #fff;
  box-shadow: 0 6px 22px rgba(26,26,46,.22);
  transition: transform .22s ease, box-shadow .22s ease, background .22s;
  position: relative;
  overflow: hidden;
}
.ma-badge::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,.06) 0%, transparent 60%);
  pointer-events: none;
}
.ma-badge:hover {
  background: #111126;
  transform: translateY(-3px) scale(1.025);
  box-shadow: 0 14px 34px rgba(243,151,32,.28);
  color: #fff;
}
.ma-badge:focus-visible {
  outline: 3px solid #F39720;
  outline-offset: 3px;
}
.ma-badge__icon {
  font-size: 2rem;
  line-height: 1;
  flex-shrink: 0;
  color: #fff;
}
.ma-badge__text {
  display: flex;
  flex-direction: column;
  gap: .05rem;
}
.ma-badge__sub {
  font-size: .65rem;
  font-weight: 400;
  opacity: .75;
  letter-spacing: .03em;
}
.ma-badge__name {
  font-size: 1.05rem;
  font-weight: 700;
  letter-spacing: -.01em;
  line-height: 1.15;
}

/* ── Phone visual ── */
.ma-phone-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.ma-phone-wrap::before {
  content: '';
  position: absolute;
  width: 280px;
  height: 280px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(243,151,32,.15) 0%, transparent 70%);
  pointer-events: none;
}
.ma-phone {
  position: relative;
  z-index: 1;
  width: 220px;
  background: linear-gradient(170deg, #23233c 0%, #12121f 100%);
  border-radius: 2.75rem;
  padding: .65rem .55rem .55rem;
  box-shadow:
    0 0 0 1.5px rgba(255,255,255,.08) inset,
    0 0 0 5px #0e0e1d,
    0 0 0 6.5px rgba(255,255,255,.05),
    0 40px 70px rgba(0,0,0,.5),
    0 10px 20px rgba(0,0,0,.3);
  filter: drop-shadow(0 24px 48px rgba(26,26,46,.18));
}
/* notch */
.ma-phone::before {
  content: '';
  position: absolute;
  top: .6rem;
  left: 50%;
  transform: translateX(-50%);
  width: 52px;
  height: 8px;
  background: #0e0e1d;
  border-radius: 999px;
  z-index: 3;
}
/* home bar */
.ma-phone::after {
  content: '';
  position: absolute;
  bottom: .5rem;
  left: 50%;
  transform: translateX(-50%);
  width: 44px;
  height: 4px;
  background: rgba(255,255,255,.2);
  border-radius: 999px;
}

/* ── Carousel ── */
.ma-carousel { position: relative; width: 100%; }
.ma-carousel__viewport {
  overflow: hidden;
  border-radius: 1.85rem;
  background: #0f0f18;
  aspect-ratio: 9/18;
}
.ma-carousel__track {
  display: flex;
  height: 100%;
  transition: transform .45s cubic-bezier(.25,.8,.25,1);
  will-change: transform;
}
.ma-carousel__slide {
  flex: 0 0 100%;
  min-width: 0;
  display: flex;
  align-items: stretch;
}
.ma-carousel__slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* ── Controls ── */
.ma-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: .65rem;
  margin-top: 1.2rem;
}
.ma-btn {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  border: 1.5px solid rgba(26,26,46,.14);
  background: #fff;
  color: #1a1a2e;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: .75rem;
  box-shadow: 0 2px 8px rgba(26,26,46,.1);
  transition: background .2s, border-color .2s, transform .2s, box-shadow .2s;
}
.ma-btn:hover {
  background: #F39720;
  border-color: #F39720;
  color: #fff;
  transform: scale(1.1);
  box-shadow: 0 6px 18px rgba(243,151,32,.38);
}
.ma-btn:focus-visible { outline: 2px solid #F39720; outline-offset: 2px; }

.ma-dots {
  display: flex;
  align-items: center;
  gap: .38rem;
}
.ma-dot {
  width: 7px;
  height: 7px;
  border-radius: 999px;
  border: none;
  padding: 0;
  background: rgba(26,26,46,.18);
  cursor: pointer;
  transition: background .2s, width .25s;
}
.ma-dot[aria-selected='true'] {
  background: #F39720;
  width: 20px;
}
.ma-dot:hover { background: rgba(243,151,32,.6); }
</style>

<%- contentFor('body') %>
<% var M = translation.pages.mobileApp; %>

<div class="lp-page">
  <%- include('../partials/navbar', { activePage: 'mobileApp' }) %>

  <!-- ════ HERO ════════════════════════════════════════════════════ -->
  <section class="ma-hero">
    <div class="ma-grid">

      <!-- Copy -->
      <div class="ma-copy">
        <div class="ma-eyebrow">
          <i class="fas fa-mobile-screen-button" aria-hidden="true"></i>
          Now Shipping App
        </div>
        <h1><%= M.title %></h1>
        <p><%= M.subtitle %></p>

        <!-- Store badges — hard-coded, no image dependency -->
        <div class="ma-badges">

          <a href="#" class="ma-badge" target="_blank" rel="noopener noreferrer"
             aria-label="Download on the App Store">
            <span class="ma-badge__icon"><i class="fab fa-apple" aria-hidden="true"></i></span>
            <span class="ma-badge__text">
              <span class="ma-badge__sub">Download on the</span>
              <span class="ma-badge__name">App Store</span>
            </span>
          </a>

          <a href="#" class="ma-badge" target="_blank" rel="noopener noreferrer"
             aria-label="Get it on Google Play">
            <span class="ma-badge__icon">
              <!-- Google Play coloured triangle -->
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
                <path d="M5 3.5L22.5 14 5 24.5V3.5Z" fill="url(#gp-grad)"/>
                <defs>
                  <linearGradient id="gp-grad" x1="5" y1="3.5" x2="22.5" y2="14" gradientUnits="userSpaceOnUse">
                    <stop stop-color="#00C6FF"/>
                    <stop offset=".35" stop-color="#34E07F"/>
                    <stop offset=".65" stop-color="#F9E03B"/>
                    <stop offset="1"  stop-color="#F8622C"/>
                  </linearGradient>
                </defs>
              </svg>
            </span>
            <span class="ma-badge__text">
              <span class="ma-badge__sub">Get it on</span>
              <span class="ma-badge__name">Google Play</span>
            </span>
          </a>

        </div>
      </div>

      <!-- Phone + carousel -->
      <div class="ma-phone-wrap">
        <div>
          <div class="ma-phone">
            <div class="ma-carousel" id="ma-carousel" data-autoplay-ms="5000">
              <div class="ma-carousel__viewport">
                <div class="ma-carousel__track" id="ma-track" role="list">
                  <div class="ma-carousel__slide" role="listitem" aria-hidden="false">
                    <img src="/assets/rImages/app-screenshots/slide-1.svg" alt="Dashboard preview" loading="eager">
                  </div>
                  <div class="ma-carousel__slide" role="listitem" aria-hidden="true">
                    <img src="/assets/rImages/app-screenshots/slide-2.svg" alt="Live tracking preview" loading="lazy">
                  </div>
                  <div class="ma-carousel__slide" role="listitem" aria-hidden="true">
                    <img src="/assets/rImages/app-screenshots/slide-3.svg" alt="Orders list preview" loading="lazy">
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Prev · Dots · Next -->
          <div class="ma-controls">
            <button class="ma-btn" id="ma-prev" aria-label="Previous slide">
              <i class="fas fa-chevron-left" aria-hidden="true"></i>
            </button>
            <div class="ma-dots" role="tablist">
              <button class="ma-dot" role="tab" aria-selected="true"  data-go="0" tabindex="0"  aria-label="Slide 1"></button>
              <button class="ma-dot" role="tab" aria-selected="false" data-go="1" tabindex="-1" aria-label="Slide 2"></button>
              <button class="ma-dot" role="tab" aria-selected="false" data-go="2" tabindex="-1" aria-label="Slide 3"></button>
            </div>
            <button class="ma-btn" id="ma-next" aria-label="Next slide">
              <i class="fas fa-chevron-right" aria-hidden="true"></i>
            </button>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ════ FEATURES ══════════════════════════════════════════════ -->
  <section class="lp-section lp-section--alt">
    <div class="lp-container">
      <div class="lp-section__head">
        <h2><%= M.features %></h2>
        <p><%= M.download %></p>
      </div>
      <div class="lp-grid">
        <article class="lp-card">
          <div class="lp-card__icon"><i class="fas fa-location-crosshairs"></i></div>
          <h3><%= M.tracking %></h3>
          <p><%= M.trackingText %></p>
        </article>
        <article class="lp-card">
          <div class="lp-card__icon"><i class="fas fa-bell"></i></div>
          <h3><%= M.notifications %></h3>
          <p><%= M.notificationsText %></p>
        </article>
        <article class="lp-card">
          <div class="lp-card__icon"><i class="fas fa-cart-plus"></i></div>
          <h3><%= M.easyOrdering %></h3>
          <p><%= M.easyOrderingText %></p>
        </article>
      </div>
    </div>
  </section>

  <!-- ════ CTA ════════════════════════════════════════════════════ -->
  <section class="lp-section">
    <div class="lp-container">
      <div class="lp-cta">
        <h2><%= M.download %></h2>
        <p><%= translation.landing.hero.subtitle %></p>
        <a href="/register" class="lp-btn lp-btn--primary"><%= translation.landing.hero.cta %></a>
      </div>
    </div>
  </section>

  <%- include('../partials/landing-footer') %>
</div>

<script>
(function () {
  var root    = document.getElementById('ma-carousel');
  var track   = document.getElementById('ma-track');
  if (!root || !track) return;

  var slides  = track.querySelectorAll('.ma-carousel__slide');
  var dots    = document.querySelectorAll('.ma-dot');
  var prevBtn = document.getElementById('ma-prev');
  var nextBtn = document.getElementById('ma-next');
  var n       = slides.length;
  if (!n) return;

  var cur   = 0;
  var ms    = parseInt(root.getAttribute('data-autoplay-ms'), 10) || 0;
  var timer = null;

  function go(to) {
    cur = (to + n) % n;
    track.style.transform = 'translateX(-' + cur * 100 + '%)';
    slides.forEach(function (el, j) { el.setAttribute('aria-hidden', j === cur ? 'false' : 'true'); });
    dots.forEach(function (d, j) {
      d.setAttribute('aria-selected', j === cur ? 'true' : 'false');
      d.setAttribute('tabindex',      j === cur ? '0' : '-1');
    });
  }
  function arm()   { if (ms) { clearInterval(timer); timer = setInterval(function(){ go(cur+1); }, ms); } }
  function pause() { clearInterval(timer); }

  prevBtn && prevBtn.addEventListener('click', function(){ go(cur-1); arm(); });
  nextBtn && nextBtn.addEventListener('click', function(){ go(cur+1); arm(); });
  dots.forEach(function(d){ d.addEventListener('click', function(){ go(+d.getAttribute('data-go')); arm(); }); });

  var wrap = document.querySelector('.ma-phone-wrap');
  if (wrap) { wrap.addEventListener('mouseenter', pause); wrap.addEventListener('mouseleave', arm); }

  var x0 = null;
  track.addEventListener('touchstart', function(e){ x0 = e.changedTouches[0].screenX; pause(); }, {passive:true});
  track.addEventListener('touchend',   function(e){
    if (x0 == null) return;
    var dx = e.changedTouches[0].screenX - x0; x0 = null;
    if (dx < -40) go(cur+1); else if (dx > 40) go(cur-1);
    arm();
  }, {passive:true});

  document.addEventListener('visibilitychange', function(){ document.hidden ? pause() : arm(); });
  go(0); arm();
})();
</script>
