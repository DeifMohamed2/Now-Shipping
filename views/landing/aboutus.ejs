<%- contentFor('HeaderCss') %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/css/rtl-support.css">
<link rel="stylesheet" href="/assets/rCSS/landing-pages.css">
<style>.about-values{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1rem;margin-top:2rem}.about-value{background:#fff;border-radius:var(--lp-radius);padding:1.5rem;border:1px solid rgba(26,26,46,.08);box-shadow:var(--lp-shadow)}.about-value h3{color:var(--lp-primary);font-size:1rem;margin:0 0 .5rem}</style>

<%- contentFor('body') %>
<div class="lp-page">
<%- include('../partials/navbar', { activePage: 'about' }) %>

  <section class="lp-hero">
    <div class="lp-container lp-hero__grid">
      <div>
        <h1><%= translation.pages.aboutus.title %></h1>
        <p class="lead"><%= translation.pages.aboutus.subtitle %></p>
        <a href="/register" class="lp-btn lp-btn--primary"><i class="fas fa-rocket"></i> <%= translation.landing.hero.cta %></a>
      </div>
      <div class="lp-hero__visual" aria-hidden="true">
        <span class="lp-hero__icon"><i class="fas fa-boxes-stacked"></i></span>
    </div>
  </div>
</section>

  <section class="lp-section lp-section--alt">
    <div class="lp-container">
      <div class="lp-grid" style="margin-bottom:2rem">
        <article class="lp-card"><h3 style="margin:0 0 .5rem;color:var(--lp-navy)"><%= translation.pages.aboutus.mission %></h3><p style="margin:0"><%= translation.pages.aboutus.missionText %></p></article>
        <article class="lp-card"><h3 style="margin:0 0 .5rem;color:var(--lp-navy)"><%= translation.pages.aboutus.vision %></h3><p style="margin:0"><%= translation.pages.aboutus.visionText %></p></article>
    </div>
      <div class="lp-section__head">
        <h2><%= translation.pages.aboutus.values %></h2>
        <p><%= translation.pages.aboutus.subtitle %></p>
        </div>
      <div class="about-values">
        <div class="about-value"><h3><i class="fas fa-shield-halved"></i> <%= translation.pages.aboutus.reliability %></h3><p style="font-size:.9rem;margin:0"><%= translation.pages.aboutus.reliabilityText %></p></div>
        <div class="about-value"><h3><i class="fas fa-lightbulb"></i> <%= translation.pages.aboutus.innovation %></h3><p style="font-size:.9rem;margin:0"><%= translation.pages.aboutus.innovationText %></p></div>
        <div class="about-value"><h3><i class="fas fa-scale-balanced"></i> <%= translation.pages.aboutus.transparency %></h3><p style="font-size:.9rem;margin:0"><%= translation.pages.aboutus.transparencyText %></p></div>
      </div>
        </div>
  </section>

  <section class="lp-section">
    <div class="lp-container">
      <div class="lp-section__head">
        <h2><%= translation.landing.about.title %></h2>
        <p><%= translation.landing.about.subtitle %></p>
        </div>
      <div class="lp-grid">
        <article class="lp-card"><div class="lp-card__icon"><i class="fas fa-bolt"></i></div><h3><%= translation.landing.about.features.speed.title %></h3><p><%= translation.landing.about.features.speed.description %></p></article>
        <article class="lp-card"><div class="lp-card__icon"><i class="fas fa-shield-halved"></i></div><h3><%= translation.landing.about.features.reliability.title %></h3><p><%= translation.landing.about.features.reliability.description %></p></article>
        <article class="lp-card"><div class="lp-card__icon"><i class="fas fa-coins"></i></div><h3><%= translation.landing.about.features.cost.title %></h3><p><%= translation.landing.about.features.cost.description %></p></article>
        <article class="lp-card"><div class="lp-card__icon"><i class="fas fa-headset"></i></div><h3><%= translation.landing.about.features.support.title %></h3><p><%= translation.landing.about.features.support.description %></p></article>
    </div>
  </div>
</section>

  <section class="lp-section lp-section--alt">
    <div class="lp-container">
      <div class="lp-cta">
        <h2><%= translation.landing.cta.title %></h2>
        <p><%= translation.landing.cta.subtitle %></p>
        <a href="/register" class="lp-btn lp-btn--primary"><%= translation.landing.cta.button %></a>
    </div>
  </div>
</section>

  <%- include('../partials/landing-footer') %>
  </div>
