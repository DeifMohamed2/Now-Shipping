<% 
  var Am = (typeof translation !== 'undefined' && translation.business && translation.business.shared && translation.business.shared.areaSelectionModal)
    ? translation.business.shared.areaSelectionModal
    : {};
  var _amLang = (typeof currentLang !== 'undefined' && currentLang) ? String(currentLang).toLowerCase().split('-')[0] : 'en';
  if (_amLang !== 'ar' && _amLang !== 'en') _amLang = 'en';
  var _amRtl = (typeof isRTL !== 'undefined' && isRTL) || _amLang === 'ar';
%>
<!-- Area Selection Modal — RTL-aware layout + scoped design -->
<div class="modal fade area-selection-modal<%= _amRtl ? ' area-selection-modal--rtl' : ' area-selection-modal--ltr' %>" id="areaSelectionModal" tabindex="-1" aria-labelledby="areaSelectionModalLabel" aria-hidden="true"
     lang="<%= _amLang %>"
     dir="<%= _amRtl ? 'rtl' : 'ltr' %>"
     data-swal-title="<%= Am.swalSelectTitle || 'Please Select' %>"
     data-swal-text="<%= Am.swalSelectText || 'Please select both a governorate and an area.' %>">
  <div class="modal-dialog modal-dialog-centered area-selection-modal__dialog">
    <div class="modal-content area-selection-modal__shell">
      <div class="modal-header area-selection-modal__header border-0">
        <% if (_amRtl) { %>
          <button type="button" class="btn-close btn-close-white area-selection-modal__close" data-bs-dismiss="modal" aria-label="<%= Am.closeAria || 'Close' %>"></button>
          <h5 class="modal-title area-selection-modal__title mb-0" id="areaSelectionModalLabel">
            <span class="area-selection-modal__title-icon" aria-hidden="true"><i class="ri-map-pin-line"></i></span>
            <span class="area-selection-modal__title-text"><%= Am.title || 'Select Area' %></span>
          </h5>
        <% } else { %>
          <h5 class="modal-title area-selection-modal__title mb-0" id="areaSelectionModalLabel">
            <span class="area-selection-modal__title-icon" aria-hidden="true"><i class="ri-map-pin-line"></i></span>
            <span class="area-selection-modal__title-text"><%= Am.title || 'Select Area' %></span>
          </h5>
          <button type="button" class="btn-close btn-close-white area-selection-modal__close" data-bs-dismiss="modal" aria-label="<%= Am.closeAria || 'Close' %>"></button>
        <% } %>
      </div>

      <div class="modal-body area-selection-modal__body">
        <label class="visually-hidden" for="areaSearchInput"><%= Am.searchPlaceholder || 'Search area' %></label>
        <div class="area-selection-modal__search-pill">
          <span class="area-selection-modal__search-affix" aria-hidden="true"><i class="ri-search-line"></i></span>
          <input type="search" class="form-control area-selection-modal__search-input" id="areaSearchInput"
                 placeholder="<%= Am.searchPlaceholder || 'Type your area (e.g., Nasr City)' %>"
                 autocomplete="off" inputmode="search">
          <span class="area-selection-modal__search-affix" aria-hidden="true"><i class="ri-map-pin-line"></i></span>
        </div>

        <div class="area-selection-modal__hint" role="note">
          <span class="area-selection-modal__hint-icon" aria-hidden="true"><i class="ri-information-line"></i></span>
          <p class="area-selection-modal__hint-text mb-0"><%= Am.hint || 'Click on any governorate to view and select available areas' %></p>
        </div>

        <div class="area-selection-modal__list-scroll">
          <div id="governorateList" class="area-selection-modal__list" data-loading-text="<%= Am.loadingRegions || 'Loading regions…' %>"></div>
        </div>
      </div>

      <div class="modal-footer area-selection-modal__footer border-0">
        <% if (_amRtl) { %>
          <button type="button" class="btn area-selection-modal__btn-primary btn-lg" id="confirmAreaSelection">
            <%= Am.confirm || 'Confirm Selection' %>
          </button>
          <button type="button" class="btn area-selection-modal__btn-secondary btn-lg" data-bs-dismiss="modal"><%= Am.cancel || 'Cancel' %></button>
        <% } else { %>
          <button type="button" class="btn area-selection-modal__btn-secondary btn-lg" data-bs-dismiss="modal"><%= Am.cancel || 'Cancel' %></button>
          <button type="button" class="btn area-selection-modal__btn-primary btn-lg" id="confirmAreaSelection">
            <%= Am.confirm || 'Confirm Selection' %>
          </button>
        <% } %>
      </div>
    </div>
  </div>
</div>
