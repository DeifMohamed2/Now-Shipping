        <div class="dropdown ms-sm-3 header-item topbar-user">
          <button type="button" class="btn material-shadow-none topbar-user-btn" id="page-header-user-dropdown" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
            <span class="d-flex align-items-center">
              <% 
                var profileFallback = '/assets/rImages/logo.png';
                // Determine user info based on context (admin or business)
                var userName = '';
                var userRole = '';
                var userPhoto = profileFallback;
                var __BS = (typeof translation !== 'undefined' && translation.business && translation.business.shell) ? translation.business.shell : {};
                if (typeof adminData !== 'undefined' && adminData) {
                  userName = adminData.name || 'Admin';
                  userRole = __BS.roleAdmin || 'Administrator';
                  userPhoto = (adminData.profileImage && String(adminData.profileImage).trim()) ? String(adminData.profileImage).trim() : profileFallback;
                } else if (typeof userData !== 'undefined' && userData) {
                  userName = userData.brandInfo?.brandName || userData.name || __BS.userFallback || 'User';
                  userRole = userData.role === 'business' ? (__BS.roleBusiness || 'Business') + ' ' + (__BS.roleAccount || 'Account') : userData.role || __BS.userFallback || 'User';
                  userPhoto = (userData.profileImage && String(userData.profileImage).trim()) ? String(userData.profileImage).trim() : profileFallback;
                } else if (typeof courierData !== 'undefined' && courierData) {
                  userName = courierData.name || __BS.roleCourier || 'Courier';
                  userRole = __BS.roleCourier || 'Courier';
                  userPhoto = (courierData.profileImage && String(courierData.profileImage).trim()) ? String(courierData.profileImage).trim() : profileFallback;
                } else if (typeof courier !== 'undefined' && courier) {
                  userName = courier.name || __BS.roleCourier || 'Courier';
                  userRole = __BS.roleCourier || 'Courier';
                  userPhoto = (courier.profileImage && String(courier.profileImage).trim()) ? String(courier.profileImage).trim() : profileFallback;
                } else if (typeof user !== 'undefined' && user) {
                  userName = user.brandInfo?.brandName || user.name || __BS.userFallback || 'User';
                  userRole = user.role === 'business' ? (__BS.roleBusiness || 'Business') + ' ' + (__BS.roleAccount || 'Account') : user.role || __BS.userFallback || 'User';
                  userPhoto = (user.profileImage && String(user.profileImage).trim()) ? String(user.profileImage).trim() : profileFallback;
                } else {
                  userName = __BS.guestUser || 'Guest';
                  userRole = __BS.roleGuest || 'Guest';
                }
                var profileIsFallback = userPhoto === profileFallback;
                var topbarPhIcon = 'ri-user-smile-line';
                if (typeof adminData !== 'undefined' && adminData) {
                  topbarPhIcon = 'ri-shield-user-line';
                } else if ((typeof courierData !== 'undefined' && courierData) || (typeof courier !== 'undefined' && courier)) {
                  topbarPhIcon = 'ri-truck-line';
                } else if ((typeof userData !== 'undefined' && userData && userData.role === 'business') || (typeof user !== 'undefined' && user && user.role === 'business')) {
                  topbarPhIcon = 'ri-store-2-line';
                } else if ((typeof userData !== 'undefined' && userData) || (typeof user !== 'undefined' && user)) {
                  topbarPhIcon = 'ri-user-line';
                }
              %>
              <div class="topbar-user-avatar-wrapper<%= profileIsFallback ? ' topbar-user-avatar-wrapper--placeholder' : '' %>">
                <% if (!profileIsFallback) { %>
                <img class="rounded-circle header-profile-user" src="<%= userPhoto %>" alt="<%= userName %>" width="36" height="36" decoding="async" onerror="this.onerror=null;this.style.display='none';var w=this.closest('.topbar-user-avatar-wrapper');if(w){w.classList.add('topbar-user-avatar-wrapper--placeholder');var p=this.nextElementSibling;if(p){p.classList.remove('d-none');p.classList.add('d-inline-flex');p.setAttribute('aria-hidden','true');}}">
                <span class="topbar-user-avatar-placeholder rounded-circle d-none align-items-center justify-content-center" aria-hidden="true"><i class="<%= topbarPhIcon %>"></i></span>
                <span class="topbar-user-status" aria-hidden="true"></span>
                <% } else { %>
                <span class="topbar-user-avatar-placeholder rounded-circle d-inline-flex align-items-center justify-content-center" aria-hidden="true"><i class="<%= topbarPhIcon %>"></i></span>
                <% } %>
              </div>
              <span class="text-start ms-xl-2 topbar-user-meta">
                <span class="d-none d-xl-inline-block fw-semibold user-name-text"><%= userName %></span>
                <span class="d-none d-xl-block fs-12 text-muted user-name-sub-text text-capitalize"><%= userRole %></span>
              </span>
              <i class="ri-arrow-down-s-line ms-2 d-none d-xl-inline-block dropdown-arrow"></i>
            </span>
          </button>
          <div class="dropdown-menu dropdown-menu-end topbar-dropdown-menu">
            <!-- item-->
            <div class="dropdown-header topbar-dropdown-header">
              <div class="d-flex align-items-center">
                <% if (!profileIsFallback) { %>
                <div class="topbar-user-avatar-wrapper topbar-dropdown-avatar flex-shrink-0 me-2">
                  <img class="rounded-circle header-profile-user" src="<%= userPhoto %>" alt="" width="40" height="40" decoding="async" onerror="this.onerror=null;this.style.display='none';var w=this.closest('.topbar-user-avatar-wrapper');if(w){w.classList.add('topbar-user-avatar-wrapper--placeholder');var p=this.nextElementSibling;if(p){p.classList.remove('d-none');p.classList.add('d-inline-flex');}}">
                  <span class="topbar-user-avatar-placeholder rounded-circle d-none align-items-center justify-content-center" style="width:40px;height:40px" aria-hidden="true"><i class="<%= topbarPhIcon %>"></i></span>
                </div>
                <% } else { %>
                <span class="topbar-user-avatar-placeholder rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0 me-2" style="width:40px;height:40px" aria-hidden="true"><i class="<%= topbarPhIcon %>"></i></span>
                <% } %>
                <div class="min-w-0">
                  <h6 class="mb-0 fw-semibold text-truncate"><%= __BS.welcomeUser ? __BS.welcomeUser.replace('{name}', userName) : ('Welcome ' + userName + '!') %></h6>
                  <small class="text-muted text-truncate d-block"><%= userRole %></small>
                </div>
              </div>
            </div>
            <div class="dropdown-divider"></div>
            <% if (typeof userData !== 'undefined' && userData && userData.role === 'business') { %>
            <a class="dropdown-item topbar-dropdown-item" href="/business/settings">
              <i class="ri-user-line fs-16 align-middle me-2" style="color: #E4A24A;"></i>
              <span class="align-middle"><%= __BS.profileSettings || 'Profile Settings' %></span>
            </a>
            <a class="dropdown-item topbar-dropdown-item" href="/business/dashboard">
              <i class="ri-dashboard-line fs-16 align-middle me-2" style="color: #E4A24A;"></i>
              <span class="align-middle"><%= __BS.dashboard || 'Dashboard' %></span>
            </a>
            <a class="dropdown-item topbar-dropdown-item" href="/business/orders">
              <i class="ri-shopping-cart-line fs-16 align-middle me-2" style="color: #E4A24A;"></i>
              <span class="align-middle"><%= __BS.myOrders || 'My Orders' %></span>
            </a>
            <a class="dropdown-item topbar-dropdown-item" href="/business/wallet/total-balance">
              <i class="ri-wallet-line fs-16 align-middle me-2" style="color: #E4A24A;"></i>
              <span class="align-middle"><%= __BS.myWallet || 'My Wallet' %></span>
            </a>
            <div class="dropdown-divider"></div>
            <% } else if (typeof adminData !== 'undefined' && adminData) { %>
            <a class="dropdown-item topbar-dropdown-item" href="/admin/dashboard">
              <i class="ri-dashboard-line fs-16 align-middle me-2" style="color: #E4A24A;"></i>
              <span class="align-middle"><%= __BS.dashboard || 'Dashboard' %></span>
            </a>
            <div class="dropdown-divider"></div>
            <% } else if ((typeof courierData !== 'undefined' && courierData) || (typeof courier !== 'undefined' && courier)) { %>
