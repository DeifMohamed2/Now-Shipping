            <a class="dropdown-item topbar-dropdown-item text-danger" href="<% if ((typeof courierData !== 'undefined' && courierData) || (typeof courier !== 'undefined' && courier)) { %>/courier/logout<% } else if (typeof adminData !== 'undefined' && adminData) { %>/admin/logout<% } else { %>/business/logout<% } %>">
