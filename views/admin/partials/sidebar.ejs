<!-- ========== Admin App Menu (matches business dark shell) ========== -->
<% var AS = (typeof translation !== 'undefined' && translation.admin && translation.admin.shell) ? translation.admin.shell : {}; %>
<% var __hl = (typeof currentLang !== 'undefined' && currentLang) ? currentLang : 'en'; %>

<div class="app-menu navbar-menu ns-sidebar-dark">
  <div class="sidebar-mobile-bar" role="presentation">
    <span class="sidebar-mobile-bar__label text-uppercase"><%= AS.menu || 'Menu' %></span>
    <button type="button" class="sidebar-mobile-close" id="sidebar-mobile-close" aria-label="<%= AS.closeMenu || 'Close menu' %>">
      <i class="ri-close-line" aria-hidden="true"></i>
    </button>
  </div>

  <div class="navbar-brand-box ns-logo-box">
    <a href="<%= typeof logoHomeHref !== 'undefined' ? logoHomeHref : '/admin/dashboard' %>" class="logo ns-logo-link">
      <div class="ns-logo-container">
        <img src="/assets/rImages/app_inside_logo.png" alt="Now Shipping" class="ns-logo-img ns-logo-img--expanded" width="200" height="48" loading="eager" decoding="async">
        <img src="/assets/rImages/mainlogospining.png" alt="" class="ns-logo-img ns-logo-img--collapsed" width="40" height="40" loading="eager" decoding="async" aria-hidden="true">
      </div>
    </a>
    <button class="ns-collapse-btn d-none d-md-flex" id="nsSidebarToggle" aria-label="<%= AS.toggleNav || 'Toggle sidebar' %>" title="<%= AS.toggleNav || 'Toggle sidebar' %>">
      <i id="nsSidebarToggleIcon" class="ri-menu-fold-line"></i>
    </button>
  </div>

  <div class="dropdown ns-user-card m-2 rounded">
    <button type="button" class="btn w-100 d-flex align-items-center ns-user-btn" id="page-header-user-dropdown" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
      <span class="d-flex align-items-center gap-2">
        <%
          var sbProfileFallback = '/assets/rImages/logo.png';
          var sbUserName = AS.userFallback || 'Admin';
          var sbUserSub = AS.roleAdmin || 'Administrator';
          var sbUserPhoto = sbProfileFallback;
          if (typeof adminData !== 'undefined' && adminData) {
            sbUserName = adminData.name || sbUserName;
            sbUserPhoto = (adminData.profileImage && String(adminData.profileImage).trim()) ? String(adminData.profileImage).trim() : sbProfileFallback;
          }
          var sbProfileIsFallback = sbUserPhoto === sbProfileFallback;
        %>
        <img class="rounded-circle ns-user-avatar<%= sbProfileIsFallback ? ' profile-img--fallback' : '' %>"
             src="<%= sbUserPhoto %>"
             alt="<%= sbUserName %>"
             onerror="this.onerror=null;this.src='<%= sbProfileFallback %>';this.classList.add('profile-img--fallback');">
        <span class="text-start">
          <span class="d-block fw-semibold ns-user-name"><%= sbUserName %></span>
          <span class="d-block ns-user-role">
            <i class="ri ri-circle-fill fs-10 text-success align-baseline"></i>
            <span class="align-middle<%= __hl === 'ar' ? '' : ' text-capitalize' %>"><%= sbUserSub %></span>
          </span>
        </span>
      </span>
      <i class="ri-chevron-down-line ns-chevron"></i>
    </button>
    <div class="dropdown-menu dropdown-menu-end border-0 ns-user-dropdown">
      <div class="dropdown-header px-3 py-2 ns-dd-header">
        <span><%= AS.welcome || 'Welcome!' %></span>
      </div>
      <div class="dropdown-divider my-1 ns-dd-divider"></div>
      <a class="dropdown-item d-flex align-items-center px-3 py-2 ns-dd-item" href="/admin/dashboard">
        <i class="ri-dashboard-line fs-16 align-middle me-2 ns-dd-icon"></i>
        <span class="align-middle"><%= AS.dashboard || 'Dashboard' %></span>
      </a>
      <a class="dropdown-item d-flex align-items-center px-3 py-2 ns-dd-item" href="/admin/orders">
        <i class="ri-shopping-cart-line fs-16 align-middle me-2 ns-dd-icon"></i>
        <span class="align-middle"><%= AS.orders || 'Orders' %></span>
      </a>
      <a class="dropdown-item d-flex align-items-center px-3 py-2 ns-dd-item" href="/admin/businesses">
        <i class="ri-building-line fs-16 align-middle me-2 ns-dd-icon"></i>
        <span class="align-middle"><%= AS.businesses || 'Businesses' %></span>
      </a>
      <div class="dropdown-divider my-2 ns-dd-divider"></div>
      <a class="dropdown-item d-flex align-items-center px-3 py-2 ns-dd-item ns-dd-item--danger" href="/admin/logout">
        <i class="ri-logout-box-r-line fs-16 align-middle me-2"></i>
        <span class="align-middle fw-semibold"><%= AS.logoutNav || 'Logout' %></span>
      </a>
    </div>
  </div>

  <div id="scrollbar">
    <div class="container-fluid">
      <div id="two-column-menu"></div>
      <ul class="navbar-nav" id="navbar-nav">

        <li class="menu-title ns-section-label"><span><%= AS.sectionDashboard || 'Dashboard' %></span></li>
        <li class="nav-item">
          <a class="nav-link menu-link ns-link" href="/admin/dashboard" role="button">
            <i class="ri-dashboard-2-line ns-icon"></i>
            <span><%= AS.dashboard || 'Dashboard' %></span>
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link menu-link ns-link" href="/admin/orders" role="button">
            <i class="ri-shopping-cart-line ns-icon"></i>
            <span><%= AS.orders || 'Orders' %></span>
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link menu-link ns-link" href="/admin/pickups" role="button">
            <i class="ri-truck-line ns-icon"></i>
            <span><%= AS.pickups || 'Pickups' %></span>
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link menu-link ns-link" href="/admin/couriers" role="button">
            <i class="ri-user-line ns-icon"></i>
            <span><%= AS.couriers || 'Couriers' %></span>
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link menu-link ns-link" href="/admin/couriers-follow-up" role="button">
            <i class="ri-user-search-line ns-icon"></i>
            <span><%= AS.couriersFollowUp || 'Couriers Follow-Up' %></span>
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link menu-link ns-link" href="#sidebarStockManagement" data-bs-toggle="collapse" role="button" aria-expanded="false" aria-controls="sidebarStockManagement">
            <i class="ri-store-line ns-icon"></i>
            <span><%= AS.stockManagement || 'Stock Management' %></span>
          </a>
          <div class="collapse ms-3" id="sidebarStockManagement">
            <ul class="nav flex-column ns-submenu">
              <li class="nav-item">
                <a class="nav-link ns-link ns-sublink" href="/admin/stock-management/pickups">
                  <i class="ri-truck-line ns-icon"></i>
                  <span><%= AS.stockFromPickups || 'From Pickups' %></span>
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link ns-link ns-sublink" href="/admin/stock-management/returns">
                  <i class="ri-arrow-go-back-line ns-icon"></i>
                  <span><%= AS.stockFromReturns || 'From Returns' %></span>
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link ns-link ns-sublink" href="/admin/stock-management/storages">
                  <i class="ri-archive-line ns-icon"></i>
                  <span><%= AS.storages || 'Storages' %></span>
                </a>
              </li>
            </ul>
          </div>
        </li>
        <li class="nav-item">
          <a class="nav-link menu-link ns-link" href="#sidebarWallet" data-bs-toggle="collapse" role="button" aria-expanded="false" aria-controls="sidebarWallet">
            <i class="ri-wallet-line ns-icon"></i>
            <span><%= AS.walletManagement || 'Wallet Management' %></span>
          </a>
          <div class="collapse ms-3" id="sidebarWallet">
            <ul class="nav flex-column ns-submenu">
              <li class="nav-item">
                <a class="nav-link ns-link ns-sublink" href="/admin/payouts">
                  <i class="ri-bank-line ns-icon"></i>
                  <span><%= AS.payouts || 'Payouts' %></span>
                </a>
              </li>
            </ul>
          </div>
        </li>
        <li class="nav-item">
          <a class="nav-link menu-link ns-link" href="#sidebarShop" data-bs-toggle="collapse" role="button" aria-expanded="false" aria-controls="sidebarShop">
            <i class="ri-store-2-line ns-icon"></i>
            <span><%= AS.shopManagement || 'Shop Management' %></span>
          </a>
          <div class="collapse ms-3" id="sidebarShop">
            <ul class="nav flex-column ns-submenu">
              <li class="nav-item">
                <a class="nav-link ns-link ns-sublink" href="/admin/shop/products">
                  <i class="ri-product-hunt-line ns-icon"></i>
                  <span><%= AS.shopProducts || 'Products' %></span>
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link ns-link ns-sublink" href="/admin/shop/orders">
                  <i class="ri-shopping-bag-line ns-icon"></i>
                  <span><%= AS.shopOrders || 'Shop Orders' %></span>
                </a>
              </li>
            </ul>
          </div>
        </li>
        <li class="nav-item">
          <a class="nav-link menu-link ns-link" href="/admin/businesses" role="button">
            <i class="ri-building-line ns-icon"></i>
            <span><%= AS.businesses || 'Businesses' %></span>
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link menu-link ns-link" href="/admin/tickets" role="button">
            <i class="ri-ticket-line ns-icon"></i>
            <span><%= AS.tickets || 'Tickets' %></span>
          </a>
        </li>

        <li class="menu-title ns-section-label"><span><%= AS.sectionTools || 'Tools' %></span></li>
        <li class="nav-item">
          <a class="nav-link menu-link ns-link" href="/admin/notifications" role="button">
            <i class="ri-notification-line ns-icon"></i>
            <span><%= AS.notifyCouriers || 'Send Courier Notifications' %></span>
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link menu-link ns-link" href="/admin/notifications/businesses" role="button">
            <i class="ri-notification-3-line ns-icon"></i>
            <span><%= AS.notifyBusinesses || 'Send Business Notifications' %></span>
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link menu-link ns-link" href="/admin/courier-tracking" role="button">
            <i class="ri-map-pin-line ns-icon"></i>
            <span><%= AS.courierTracking || 'Courier Tracking' %></span>
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link menu-link ns-link" href="/admin/print-smart-flyers" role="button">
            <i class="ri-printer-line ns-icon"></i>
            <span><%= AS.printFlyers || 'Print Smart Flyers' %></span>
          </a>
        </li>

        <li class="menu-title ns-section-label"><span><%= AS.sectionAccount || 'Account' %></span></li>
        <li class="nav-item">
          <a class="nav-link menu-link ns-link ns-link--logout" href="/admin/logout">
            <i class="ri-logout-box-line ns-icon"></i>
            <span><%= AS.logOut || 'Log Out' %></span>
          </a>
        </li>
      </ul>

      <div class="ns-lang-section">
        <span class="ns-lang-section-label"><%= AS.language || 'Language' %></span>
        <div class="ns-lang-btns">
          <a href="?lang=en" class="ns-lang-btn<%= __hl === 'en' ? ' ns-lang-active' : '' %>" title="English">
            <img src="/assets/images/flags/us.svg" alt="" width="20" height="14" class="ns-lang-flag" decoding="async">
            <span class="ns-lang-text">English</span>
          </a>
          <a href="?lang=ar" class="ns-lang-btn<%= __hl === 'ar' ? ' ns-lang-active' : '' %>" title="العربية">
            <img src="/assets/images/flags/ae.svg" alt="" width="20" height="14" class="ns-lang-flag" decoding="async">
            <span class="ns-lang-text">العربية</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="vertical-overlay"></div>

<button class="ns-mobile-menu-btn d-md-none" id="nsMobileMenuBtn" aria-label="<%= AS.openMenu || 'Open menu' %>">
  <i class="ri-menu-line"></i>
</button>

<script>
(function () {
  function initSidebarToggle() {
    var btn = document.getElementById('nsSidebarToggle');
    var icon = document.getElementById('nsSidebarToggleIcon');
    var htmlEl = document.documentElement;
    function getSidebarSize() {
      return htmlEl.getAttribute('data-sidebar-size') || 'lg';
    }
    function updateToggleIcon() {
      if (!icon) return;
      var size = getSidebarSize();
      icon.className = (size === 'sm' || size === 'sm-hover')
        ? 'ri-menu-unfold-line'
        : 'ri-menu-fold-line';
    }
    if (btn) {
      btn.addEventListener('click', function () {
        var hamburger = document.getElementById('topnav-hamburger-icon');
        if (hamburger) {
          hamburger.dispatchEvent(new MouseEvent('click', { bubbles: true, cancelable: true }));
        } else {
          htmlEl.setAttribute('data-sidebar-size', getSidebarSize() === 'sm' ? 'lg' : 'sm');
        }
        setTimeout(updateToggleIcon, 80);
      });
    }
    var mo = new MutationObserver(updateToggleIcon);
    mo.observe(htmlEl, { attributes: true, attributeFilter: ['data-sidebar-size'] });
    updateToggleIcon();
  }
  function initMobileMenuBtn() {
    var btn = document.getElementById('nsMobileMenuBtn');
    if (!btn) return;
    btn.addEventListener('click', function () {
      var hamburger = document.getElementById('topnav-hamburger-icon');
      if (hamburger) {
        hamburger.dispatchEvent(new MouseEvent('click', { bubbles: true, cancelable: true }));
      } else {
        document.body.classList.toggle('vertical-sidebar-enable');
      }
    });
    var mo = new MutationObserver(function () {
      btn.style.display = document.body.classList.contains('vertical-sidebar-enable') ? 'none' : '';
    });
    mo.observe(document.body, { attributes: true, attributeFilter: ['class'] });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () {
      initSidebarToggle();
      initMobileMenuBtn();
    });
  } else {
    initSidebarToggle();
    initMobileMenuBtn();
  }
})();
</script>
