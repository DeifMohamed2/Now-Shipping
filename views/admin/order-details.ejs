<%- contentFor('FooterJs') %>

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
async function cancelOrder(orderId) {
  const confirm = await Swal.fire({
    title: 'Cancel this order?',
    html: '<p class="text-muted mb-0">Depending on status, the order may be marked canceled or moved into the <strong>return</strong> flow (e.g. return to warehouse).</p>',
    icon: 'warning',
    showCancelButton: true,
    confirmButtonColor: '#3085d6',
    cancelButtonColor: '#d33',
    confirmButtonText: 'Yes, proceed',
  });
  if (!confirm.isConfirmed) return;
  try {
    const response = await fetch('/admin/orders/cancel-order/' + orderId, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
    });
    const data = await response.json().catch(() => ({}));
    if (response.ok) {
      await Swal.fire({
        icon: 'success',
        title: 'Updated',
        text: data.message || 'Order updated.',
        confirmButtonText: 'OK',
      });
      window.location.reload();
    } else {
      Swal.fire({ icon: 'error', title: 'Cannot cancel', text: data.error || 'Request failed.' });
    }
  } catch (e) {
    Swal.fire({ icon: 'error', title: 'Error', text: 'Something went wrong. Try again.' });
  }
}

async function resendReturnOtp(orderNumber) {
  const confirm = await Swal.fire({
    title: 'Resend Return OTP?',
    html: `<p class="text-muted">A new 6-digit OTP will be generated and sent via SMS to the customer for order <strong>#${orderNumber}</strong>. The previous OTP will be invalidated.</p>`,
    icon: 'question',
    showCancelButton: true,
    confirmButtonText: 'Send OTP',
    confirmButtonColor: '#F39720',
  });
  if (!confirm.isConfirmed) return;

  try {
    const res = await fetch(`/admin/orders/${orderNumber}/resend-return-otp`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Failed to resend OTP');
    Swal.fire({ icon: 'success', title: 'OTP Sent!', text: data.message, confirmButtonColor: '#F39720' })
      .then(() => window.location.reload());
  } catch (err) {
    Swal.fire({ icon: 'error', title: 'Error', text: err.message });
  }
}
</script>
<!-- App js -->