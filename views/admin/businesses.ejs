<%- contentFor('FooterJs') %>
<script src="/assets/libs/flatpickr/flatpickr.min.js"></script>
<script src="/assets/libs/sweetalert2/sweetalert2.min.js"></script>

<script>
  let currentPage = 1;
  let lastPagination = { totalPages: 1, currentPage: 1 };
  let datePickerInstance = null;
  let searchDebounce = null;

  const filters = {
    search: '',
    status: '',
    sortBy: 'createdAt',
    sortOrder: 'desc',
    dateFrom: '',
    dateTo: '',
  };

  function parseSortSelect() {
    const v = document.getElementById('sortByFilter').value || 'createdAt|desc';
    const [sortBy, sortOrder] = v.split('|');
    filters.sortBy = sortBy;
    filters.sortOrder = sortOrder || 'desc';
  }

  function initDatePicker() {
    datePickerInstance = flatpickr('#dateRangeFilter', {
      mode: 'range',
      dateFormat: 'Y-m-d',
      onClose(selectedDates) {
        if (selectedDates.length === 2) {
          filters.dateFrom = selectedDates[0].toISOString().split('T')[0];
          filters.dateTo = selectedDates[1].toISOString().split('T')[0];
        } else if (selectedDates.length === 0) {
          filters.dateFrom = '';
          filters.dateTo = '';
        }
      },
    });
  }

  async function loadBusinesses() {
    parseSortSelect();
    const limit = 12;
    const params = new URLSearchParams({
      page: currentPage,
      limit,
      search: filters.search,
      status: filters.status,
      sortBy: filters.sortBy,
      sortOrder: filters.sortOrder,
      dateFrom: filters.dateFrom,
      dateTo: filters.dateTo,
    });

    try {
      const response = await fetch(`/admin/get-businesses?${params}`);
      const data = await response.json();

      if (!data.businesses) {
        showError('Invalid response from server');
        return;
      }

      renderLeaderboard(data.leaderboard || []);
      updateSummary(data.summary, data.pagination);
      renderTable(data.businesses, data.pagination);
      lastPagination = data.pagination || lastPagination;
      renderPagination(data.pagination);
    } catch (e) {
      console.error(e);
      showError('Failed to load businesses');
    }
  }

  function updateSummary(summary, pagination) {
    const s = summary || {};
    document.getElementById('kpiTotal').textContent =
      pagination && typeof pagination.totalCount === 'number'
        ? pagination.totalCount
        : 0;
    document.getElementById('summaryTotalDisplay').textContent =
      pagination && typeof pagination.totalCount === 'number'
        ? pagination.totalCount
        : 0;
    document.getElementById('kpiVerified').textContent = s.verified ?? '—';
    document.getElementById('kpiPending').textContent = s.pending ?? '—';
    document.getElementById('kpiThisMonth').textContent = s.thisMonth ?? '—';
  }

  function renderLeaderboard(items) {
    const el = document.getElementById('leaderboardStrip');
    if (!items.length) {
      el.innerHTML =
        '<span class="text-white-50 small">No ranking data yet (no orders in the system).</span>';
      return;
    }
    el.innerHTML = items
      .map((b, i) => {
        const initial = (b.brandName || 'B').charAt(0).toUpperCase();
        const rate = b.stats && typeof b.stats.successRate === 'number' ? b.stats.successRate : 0;
        const w = Math.min(100, Math.max(0, rate));
        const id = b._id || b.id;
        return `
        <div class="admin-biz-lb-card" role="button" data-biz-id="${escapeAttr(String(id))}">
          <div class="admin-biz-lb-rank mb-2">#${i + 1} · ${b.stats?.totalOrders || 0} orders</div>
          <div class="d-flex align-items-center gap-2">
            ${businessLogoMarkup(initial, b.profileImage, 'admin-biz-lb-avatar')}
            <div class="flex-grow-1 min-w-0">
              <div class="fw-semibold text-truncate">${escapeHtml(b.brandName || 'Business')}</div>
              <div class="d-flex align-items-center gap-1 mt-1">
                <span class="badge bg-success">${rate.toFixed(1)}%</span>
                ${b.isVerified ? '<i class="ri-checkbox-circle-fill text-success" title="Verified"></i>' : ''}
              </div>
              <div class="admin-biz-rate-bar"><span style="width:${w}%"></span></div>
            </div>
          </div>
        </div>`;
      })
      .join('');

    el.querySelectorAll('.admin-biz-lb-card').forEach((card) => {
      card.addEventListener('click', () => {
        const id = card.getAttribute('data-biz-id');
        if (id) window.location.href = `/admin/business-details/${id}`;
      });
    });
  }

  function escapeHtml(s) {
    if (!s) return '';
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function escapeAttr(s) {
    return escapeHtml(s).replace(/'/g, '&#39;');
  }

  /** Letter fallback when missing URL or when image fails to load (broken link). */
  function businessLogoMarkup(initial, imageUrl, wrapClass) {
    const ini = escapeHtml((initial || 'B').charAt(0).toUpperCase());
    const url = imageUrl && String(imageUrl).trim();
    if (!url) {
      return `<div class="${wrapClass}"><span class="admin-biz-logo-letter">${ini}</span></div>`;
    }
    return `<div class="${wrapClass}"><span class="admin-biz-logo-letter">${ini}</span><img class="admin-biz-logo-img" src="${escapeAttr(
      url
    )}" alt="" loading="lazy" onerror="this.style.display='none'"></div>`;
  }

  function rateBarClass() {
    return 'admin-biz-progress-brand';
  }

  function renderTable(businesses, pagination) {
    const tbody = document.getElementById('businessesTableBody');
    const noResult = document.getElementById('businessesNoResult');
    const tableWrap = document.querySelector('#adminBusinessesCard .admin-table-scroll');

    if (!businesses.length) {
      tbody.innerHTML = '';
      noResult.style.display = 'block';
      if (tableWrap) tableWrap.style.display = 'none';
      return;
    }
    noResult.style.display = 'none';
    if (tableWrap) tableWrap.style.display = '';

    const offset = ((pagination?.currentPage || 1) - 1) * (pagination?.limit || 12);

    tbody.innerHTML = businesses
      .map((b, idx) => {
        const id = b._id || b.id;
        const name = b.brandInfo?.brandName || b.name || '—';
        const industry = b.brandInfo?.industry || '—';
        const orders = b.stats?.totalOrders ?? 0;
        const rate = parseFloat(b.stats?.successRate) || 0;
        const rateW = Math.min(100, Math.max(0, rate));
        const bal = b.balance || 0;
        const balClass = bal >= 0 ? 'text-success' : 'text-danger';
        const initial = name.charAt(0).toUpperCase();
        const statusHtml = b.isVerified
          ? '<span class="badge bg-soft-success text-success">Verified</span>'
          : '<span class="badge bg-soft-warning text-warning">Pending</span>';

        return `
        <tr class="admin-biz-row" data-href="/admin/business-details/${escapeAttr(String(id))}">
          <td class="text-muted">${offset + idx + 1}</td>
          <td>
            <div class="d-flex align-items-center gap-2">
              ${businessLogoMarkup(initial, b.profileImage, 'admin-biz-table-logo')}
              <div class="min-w-0">
                <div class="fw-semibold text-truncate">${escapeHtml(name)}</div>
                <div class="text-muted small text-truncate d-md-none">${escapeHtml(b.email || '')}</div>
              </div>
            </div>
          </td>
          <td class="cell-muted small">${escapeHtml(industry)}</td>
          <td class="small"><span class="text-truncate d-inline-block" style="max-width:200px">${escapeHtml(b.email || '—')}</span></td>
          <td class="cell-compact small">${escapeHtml(b.phoneNumber || '—')}</td>
          <td><span class="fw-semibold">${orders}</span></td>
          <td class="admin-biz-mini-rate">
            <div class="d-flex align-items-center gap-2">
              <span class="badge admin-biz-badge-rate">${rate.toFixed(1)}%</span>
            </div>
            <div class="progress mt-1">
              <div class="progress-bar ${rateBarClass()}" style="width:${rateW}%"></div>
            </div>
          </td>
          <td class="fw-semibold ${balClass}">${formatCurrency(bal)}</td>
          <td>${statusHtml}</td>
          <td class="admin-biz-row-actions text-end" onclick="event.stopPropagation()">
            <div class="dropdown">
              <button class="btn btn-sm btn-icon btn-ghost-secondary" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="ri-more-2-fill"></i>
              </button>
              <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" href="/admin/business-details/${escapeAttr(String(id))}"><i class="ri-eye-line me-2"></i>View details</a></li>
              </ul>
            </div>
          </td>
        </tr>`;
      })
      .join('');

    tbody.querySelectorAll('tr.admin-biz-row').forEach((row) => {
      row.addEventListener('click', (e) => {
        if (e.target.closest('.dropdown')) return;
        const href = row.getAttribute('data-href');
        if (href) window.location.href = href;
      });
    });
  }

  function renderPagination(pagination) {
    const ul = document.getElementById('paginationContainer');
    const prev = document.getElementById('bizPagePrev');
    const next = document.getElementById('bizPageNext');
    if (!pagination || pagination.totalPages <= 1) {
      ul.innerHTML = '';
      prev.classList.add('disabled');
      next.classList.add('disabled');
      return;
    }
    const { currentPage: p, totalPages: total } = pagination;
    prev.classList.toggle('disabled', p <= 1);
    next.classList.toggle('disabled', p >= total);

    const pages = new Set([1, total, p, p - 1, p + 1, p - 2, p + 2]);
    const sorted = [...pages].filter((n) => n >= 1 && n <= total).sort((a, b) => a - b);
    let html = '';
    let last = 0;
    sorted.forEach((i) => {
      if (last && i > last + 1) {
        html += `<li class="page-item disabled"><span class="page-link">…</span></li>`;
      }
      html += `<li class="page-item ${i === p ? 'active' : ''}">
        <a class="page-link" href="javascript:void(0);" data-page="${i}">${i}</a>
      </li>`;
      last = i;
    });
    ul.innerHTML = html;
    ul.querySelectorAll('a.page-link[data-page]').forEach((a) => {
      a.addEventListener('click', () => {
        const pg = parseInt(a.getAttribute('data-page'), 10);
        if (!Number.isNaN(pg)) goToPage(pg);
      });
    });
  }

  function goToPage(p) {
    currentPage = p;
    loadBusinesses();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function formatCurrency(amount) {
    return new Intl.NumberFormat('en-EG', {
      style: 'currency',
      currency: 'EGP',
      minimumFractionDigits: 0,
      maximumFractionDigits: 0,
    }).format(amount);
  }

  function showError(message) {
    Swal.fire({
      icon: 'error',
      title: 'Error',
      text: message,
      confirmButtonColor: '#F39720',
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    initDatePicker();
    loadBusinesses();

    document.getElementById('applyFiltersBtn').addEventListener('click', () => {
      currentPage = 1;
      loadBusinesses();
    });

    document.getElementById('resetFilters').addEventListener('click', () => {
      filters.search = '';
      filters.status = '';
      filters.sortBy = 'createdAt';
      filters.sortOrder = 'desc';
      filters.dateFrom = '';
      filters.dateTo = '';
      document.getElementById('searchInput').value = '';
      document.getElementById('statusFilter').value = '';
      document.getElementById('sortByFilter').value = 'createdAt|desc';
      if (datePickerInstance) datePickerInstance.clear();
      currentPage = 1;
      loadBusinesses();
    });

    document.getElementById('statusFilter').addEventListener('change', () => {
      filters.status = document.getElementById('statusFilter').value;
      currentPage = 1;
      loadBusinesses();
    });

    document.getElementById('sortByFilter').addEventListener('change', () => {
      currentPage = 1;
      loadBusinesses();
    });

    document.getElementById('searchInput').addEventListener('input', function () {
      clearTimeout(searchDebounce);
      searchDebounce = setTimeout(() => {
        filters.search = this.value;
        currentPage = 1;
        loadBusinesses();
      }, 450);
    });

    document.getElementById('bizPagePrev').addEventListener('click', function () {
      if (this.classList.contains('disabled')) return;
      if (currentPage > 1) goToPage(currentPage - 1);
    });
    document.getElementById('bizPageNext').addEventListener('click', function () {
      if (this.classList.contains('disabled')) return;
      const max = lastPagination.totalPages || 1;
      if (currentPage < max) goToPage(currentPage + 1);
    });
  });
</script>
