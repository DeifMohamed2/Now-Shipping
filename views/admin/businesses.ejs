          <div class="col-lg-3 col-md-6">
            <div class="d-flex align-items-center p-3 rounded border border-dashed">
              <div class="avatar-sm flex-shrink-0">
                <div class="avatar-title admin-biz-kpi-icon-brand rounded fs-4">
                  <i class="ri-building-4-line"></i>
