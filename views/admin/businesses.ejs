<%- contentFor('HeaderCss') %>
<link href="/assets/libs/sweetalert2/sweetalert2.min.css" rel="stylesheet" type="text/css" />
<link href="/assets/libs/flatpickr/flatpickr.min.css" rel="stylesheet" type="text/css" />
<style>
  .admin-biz-page {
    --biz-brand: #f39720;
    --biz-brand-dark: #c97d12;
    --biz-brand-soft: rgba(243, 151, 32, 0.18);
    --biz-brand-ink: #8a5a0f;
  }
  .admin-biz-page .admin-biz-hero {
    border-radius: 0.5rem;
    background: linear-gradient(135deg, #f39720 0%, #c97d12 55%, #a86a0f 100%);
    color: #fff;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1rem;
  }
  .admin-biz-page .admin-biz-hero h5 {
    color: #fff;
  }
  .admin-biz-leaderboard {
    display: flex;
    gap: 0.75rem;
    overflow-x: auto;
    padding-bottom: 0.25rem;
    margin-bottom: 0.25rem;
    -webkit-overflow-scrolling: touch;
  }
  .admin-biz-leaderboard::-webkit-scrollbar {
    height: 6px;
  }
  .admin-biz-leaderboard::-webkit-scrollbar-thumb {
    background: rgba(243, 151, 32, 0.45);
    border-radius: 4px;
  }
  .admin-biz-lb-card {
    flex: 0 0 auto;
    min-width: 200px;
    max-width: 240px;
    border: 1px solid var(--vz-border-color, rgba(0, 0, 0, 0.08));
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    background: #fff;
    cursor: pointer;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }
  .admin-biz-lb-card:hover {
    box-shadow: 0 0.35rem 1rem rgba(243, 151, 32, 0.2);
    transform: translateY(-2px);
  }
  .admin-biz-lb-rank {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #878a99;
  }
  .admin-biz-lb-avatar {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    color: #fff;
    background: linear-gradient(135deg, #f39720, #e8891a);
    overflow: hidden;
    flex-shrink: 0;
    position: relative;
  }
  .admin-biz-lb-avatar .admin-biz-logo-letter {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }
  .admin-biz-lb-avatar .admin-biz-logo-img {
    position: absolute;
    inset: 0;
    z-index: 2;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .admin-biz-rate-bar {
    height: 6px;
    border-radius: 4px;
    background: #eef0f7;
    overflow: hidden;
    margin-top: 0.35rem;
  }
  .admin-biz-rate-bar > span {
    display: block;
    height: 100%;
    border-radius: 4px;
    background: linear-gradient(90deg, #ffb45c, #f39720);
  }
  .admin-biz-table-logo {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    font-weight: 700;
    font-size: 1rem;
    color: #fff;
    background: linear-gradient(135deg, #f39720, #e8891a);
    overflow: hidden;
    flex-shrink: 0;
    position: relative;
  }
  .admin-biz-table-logo .admin-biz-logo-letter {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }
  .admin-biz-table-logo .admin-biz-logo-img {
    position: absolute;
    inset: 0;
    z-index: 2;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .admin-biz-mini-rate {
    min-width: 120px;
  }
  .admin-biz-mini-rate .progress {
    height: 6px;
    border-radius: 4px;
    background: #eef0f7;
  }
  .admin-biz-mini-rate .progress-bar {
    border-radius: 4px;
  }
  tr.admin-biz-row {
    cursor: pointer;
  }
  tr.admin-biz-row:hover {
    background-color: rgba(243, 151, 32, 0.06) !important;
  }
  .admin-biz-page .admin-biz-kpi-icon-brand {
    background: var(--biz-brand-soft) !important;
    color: var(--biz-brand-dark) !important;
  }
  .admin-biz-page .admin-biz-badge-accent {
    background: var(--biz-brand-soft);
    color: var(--biz-brand-ink);
    border: 1px solid rgba(243, 151, 32, 0.35);
  }
  .admin-biz-page .admin-biz-badge-rate {
    background: var(--biz-brand-soft);
    color: var(--biz-brand-ink);
    font-weight: 600;
  }
  .admin-biz-page .admin-biz-progress-brand {
    background: linear-gradient(90deg, #ffd08a, #f39720) !important;
  }
  .admin-biz-page #adminBusinessesCard .btn-primary {
    background-color: var(--biz-brand);
    border-color: var(--biz-brand);
  }
  .admin-biz-page #adminBusinessesCard .btn-primary:hover {
    background-color: var(--biz-brand-dark);
    border-color: var(--biz-brand-dark);
  }
  .admin-biz-page #adminBusinessesCard .pagination .page-item.active .page-link {
    background-color: var(--biz-brand);
    border-color: var(--biz-brand);
    color: #fff;
  }
  .admin-biz-page #adminBusinessesCard .btn-soft-primary {
    color: var(--biz-brand-ink) !important;
    background: var(--biz-brand-soft) !important;
    border-color: rgba(243, 151, 32, 0.35) !important;
  }
  .admin-biz-page #adminBusinessesCard .spinner-border {
    color: var(--biz-brand);
    border-right-color: transparent;
  }
  .admin-biz-row-actions .btn {
    pointer-events: auto;
  }
  tr.admin-biz-row .admin-biz-row-actions {
    pointer-events: none;
  }
  tr.admin-biz-row .admin-biz-row-actions .dropdown,
  tr.admin-biz-row .admin-biz-row-actions .btn,
  tr.admin-biz-row .admin-biz-row-actions a {
    pointer-events: auto;
  }
</style>

<%- contentFor('body') %>
