<%- contentFor('HeaderCss') %>
<link href="/assets/libs/sweetalert2/sweetalert2.min.css" rel="stylesheet" />
<link rel="stylesheet" href="/assets/rCSS/tickets-new.css">

<%- contentFor('body') %>
<div class="tickets-page">
  <div class="container-fluid tickets-page__inner py-2">
    <div class="row mb-3">
      <div class="col-12">
        <div class="tickets-page__masthead d-flex flex-wrap align-items-center justify-content-between gap-2">
          <div>
            <h1 class="tickets-page__title mb-1">
              <i class="ri-customer-service-2-line tickets-page__title-icon" aria-hidden="true"></i>
              Support tickets
            </h1>
            <p class="tickets-page__lead text-muted mb-0">Review conversations, update status, and reply in one place.</p>
          </div>
          <div class="d-flex flex-wrap gap-2 align-items-center">
            <button type="button" class="btn btn-outline-secondary btn-sm" id="refreshBtn" title="Refresh">
              <i class="ri-refresh-line" aria-hidden="true"></i>
            </button>
            <button type="button" class="btn btn-tickets-primary btn-sm" id="exportBtn" title="Export tickets">
              <i class="ri-download-line me-1" aria-hidden="true"></i>Export
            </button>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-3 mb-3">
      <div class="col-md-3 col-sm-6">
        <div class="card stats-card h-100 border-0" style="border-left: 4px solid #e4a24a;">
          <div class="card-body">
            <div class="d-flex align-items-center justify-content-between">
              <div class="flex-grow-1">
                <p class="text-muted mb-1 small fw-semibold text-uppercase">Total</p>
                <h3 class="mb-0 fw-bold tickets-stat-value" id="totalTickets">0</h3>
                <small class="text-muted" id="totalTicketsChange"></small>
              </div>
              <div class="stats-icon" style="background: #e4a24a;">
                <i class="ri-ticket-2-line" aria-hidden="true"></i>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-md-3 col-sm-6">
        <div class="card stats-card h-100 border-0" style="border-left: 4px solid #28a745;">
          <div class="card-body">
            <div class="d-flex align-items-center justify-content-between">
              <div class="flex-grow-1">
                <p class="text-muted mb-1 small fw-semibold text-uppercase">New</p>
                <h3 class="mb-0 fw-bold text-success" id="newTickets">0</h3>
                <small class="text-muted" id="newTicketsChange"></small>
              </div>
              <div class="stats-icon" style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%);">
                <i class="ri-notification-badge-line" aria-hidden="true"></i>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-md-3 col-sm-6">
        <div class="card stats-card h-100 border-0" style="border-left: 4px solid #17a2b8;">
          <div class="card-body">
            <div class="d-flex align-items-center justify-content-between">
              <div class="flex-grow-1">
                <p class="text-muted mb-1 small fw-semibold text-uppercase">Open</p>
                <h3 class="mb-0 fw-bold text-info" id="openTickets">0</h3>
                <small class="text-muted" id="openTicketsChange"></small>
              </div>
              <div class="stats-icon" style="background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);">
                <i class="ri-mail-open-line" aria-hidden="true"></i>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-md-3 col-sm-6">
        <div class="card stats-card h-100 border-0" style="border-left: 4px solid #6c757d;">
          <div class="card-body">
            <div class="d-flex align-items-center justify-content-between">
              <div class="flex-grow-1">
                <p class="text-muted mb-1 small fw-semibold text-uppercase">Resolved</p>
                <h3 class="mb-0 fw-bold text-secondary" id="resolvedTickets">0</h3>
                <small class="text-muted" id="resolvedTicketsChange"></small>
              </div>
              <div class="stats-icon" style="background: linear-gradient(135deg, #6c757d 0%, #495057 100%);">
                <i class="ri-checkbox-circle-line" aria-hidden="true"></i>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-3">
      <div class="col-lg-4">
        <div class="card tickets-panel h-100 border-0">
          <div class="tickets-panel__head card-header border-0">
            <div class="d-flex align-items-center justify-content-between">
              <h2 class="tickets-panel__title mb-0">
                <i class="ri-ticket-2-line me-2" aria-hidden="true"></i>All tickets
              </h2>
              <span class="badge tickets-count-badge" id="ticketCount">0</span>
            </div>
          </div>
          <div class="card-body p-0 d-flex flex-column tickets-panel__body">
            <div class="p-3 border-bottom bg-light">
              <div class="input-group mb-3">
                <span class="input-group-text bg-white border-end-0">
                  <i class="ri-search-line text-muted" aria-hidden="true"></i>
                </span>
                <input type="text" class="form-control border-start-0" id="searchTickets" placeholder="Search by number, subject, or business…">
              </div>
              <div class="mb-0">
                <label class="form-label small fw-semibold mb-1">Type</label>
                <select class="form-select form-select-sm" id="filterType">
                  <option value="all">All types</option>
                  <option value="order_issue">Order issue</option>
                  <option value="delivery_issue">Delivery issue</option>
                  <option value="payment_issue">Payment issue</option>
                  <option value="return_request">Return request</option>
                  <option value="technical_support">Technical support</option>
                  <option value="general_inquiry">General inquiry</option>
                  <option value="other">Other</option>
                </select>
              </div>
            </div>
            <div class="tickets-filter-bar border-bottom" role="toolbar" aria-label="Filter by status">
              <button type="button" class="tickets-filter-pill active filter-tab" data-status="all">
                <i class="ri-list-check" aria-hidden="true"></i> All
              </button>
              <button type="button" class="tickets-filter-pill filter-tab" data-status="new">
                <i class="ri-add-circle-line" aria-hidden="true"></i> New
              </button>
              <button type="button" class="tickets-filter-pill filter-tab" data-status="open">
                <i class="ri-mail-open-line" aria-hidden="true"></i> Open
              </button>
              <button type="button" class="tickets-filter-pill filter-tab" data-status="pending">
                <i class="ri-time-line" aria-hidden="true"></i> Pending
              </button>
              <button type="button" class="tickets-filter-pill filter-tab" data-status="resolved">
                <i class="ri-check-line" aria-hidden="true"></i> Resolved
              </button>
            </div>
            <div id="ticketList" class="flex-grow-1 overflow-auto" style="max-height: 100%;"></div>
          </div>
        </div>
      </div>

      <div class="col-lg-8">
        <div class="card tickets-chat-card border-0 h-100">
          <div id="emptyState" class="tickets-empty h-100 d-flex flex-column align-items-center justify-content-center p-4 p-md-5">
            <div class="tickets-empty__icon mb-3" aria-hidden="true">
              <i class="ri-message-3-line"></i>
            </div>
            <h2 class="tickets-empty__title mb-2">No ticket selected</h2>
            <p class="tickets-empty__text text-muted text-center mb-0">Choose a ticket from the list to read the thread and reply.</p>
          </div>

          <div id="chatContainer" class="h-100 d-flex flex-column hidden">
            <div class="tickets-chat-head card-header border-0">
              <div class="d-flex flex-column flex-lg-row gap-3 justify-content-between align-items-lg-start">
                <div class="flex-grow-1 min-w-0">
                  <h2 id="chatTitle" class="tickets-chat-head__title mb-1">Ticket #…</h2>
                  <div id="chatInfo" class="tickets-chat-head__meta small"></div>
                </div>
                <div class="tickets-chat-actions d-flex flex-wrap gap-2 align-items-center flex-shrink-0">
                  <label class="visually-hidden" for="statusSelect">Status</label>
                  <select class="form-select form-select-sm" id="statusSelect" style="min-width: 9.5rem;">
                    <option value="new">New</option>
                    <option value="open">Open</option>
                    <option value="pending">Pending</option>
                    <option value="in_progress">In progress</option>
                    <option value="resolved">Resolved</option>
                    <option value="closed">Closed</option>
                  </select>
                  <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" id="ticketActions" data-bs-toggle="dropdown" aria-expanded="false">
                      <i class="ri-more-2-line" aria-hidden="true"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                      <li><a class="dropdown-item" href="#" id="assignTicketBtn"><i class="ri-user-add-line me-2"></i>Assign ticket</a></li>
                      <li><a class="dropdown-item" href="#" id="viewTimelineBtn"><i class="ri-time-line me-2"></i>View timeline</a></li>
                      <li><hr class="dropdown-divider"></li>
                      <li><a class="dropdown-item text-danger" href="#" id="deleteTicketBtn"><i class="ri-delete-bin-line me-2"></i>Delete ticket</a></li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <div id="chatMessages" class="flex-grow-1 overflow-auto p-4"></div>

            <div class="tickets-composer card-footer border-0 bg-white">
              <div id="attachmentPreview" class="mb-2"></div>
              <div class="input-group">
                <button type="button" class="btn btn-tickets-attach" id="attachImageBtn" title="Attach image">
                  <i class="ri-image-add-line" aria-hidden="true"></i>
                </button>
                <input type="file" id="imageInput" accept="image/*" class="visually-hidden">
                <textarea id="messageInput" class="form-control tickets-composer__input" placeholder="Write a reply…" rows="2"></textarea>
                <button type="button" class="btn btn-tickets-primary px-3" id="sendBtn">
                  <i class="ri-send-plane-fill me-1" aria-hidden="true"></i>Send
                </button>
              </div>
              <div class="form-check mt-2">
                <input class="form-check-input" type="checkbox" id="internalNoteCheck">
                <label class="form-check-label small" for="internalNoteCheck">
                  <i class="ri-lock-line me-1" aria-hidden="true"></i>Internal note (not visible to customer)
                </label>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

<!-- Assign Ticket Modal -->
<div class="modal fade" id="assignTicketModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content tickets-modal">
      <div class="modal-header tickets-modal__header border-0">
        <h5 class="modal-title tickets-modal__title mb-0">Assign ticket</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label">Select admin</label>
          <select class="form-select" id="assignToSelect">
            <option value="">Unassign</option>
          </select>
        </div>
      </div>
      <div class="modal-footer border-top">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-tickets-primary" id="confirmAssignBtn">Assign</button>
      </div>
    </div>
  </div>
</div>

<!-- Ticket Timeline Modal -->
<div class="modal fade" id="timelineModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content tickets-modal">
      <div class="modal-header tickets-modal__header border-0">
        <h5 class="modal-title tickets-modal__title mb-0">Ticket timeline</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div id="timelineContent"></div>
      </div>
    </div>
  </div>
</div>
</div>

<%- contentFor('FooterJs') %>
<script src="/assets/libs/sweetalert2/sweetalert2.min.js"></script>
<script src="/socket.io/socket.io.js"></script>
<script src="/assets/rJS/tickets-admin.js"></script>
