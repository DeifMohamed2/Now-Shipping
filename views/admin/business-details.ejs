    document.getElementById('totalIncome').textContent = formatCurrency(data.revenueBreakdown.income || 0);
    document.getElementById('totalExpenses').textContent = formatCurrency(data.revenueBreakdown.expenses || 0);

    const transactionsBody = document.getElementById('transactionsTableBody');
