  function renderStatistics(stats) {
    const total = stats.orders.total || 0;
    const ok = stats.orders.successful || 0;
    const rate = total > 0 ? (ok / total) * 100 : 0;

    document.getElementById('kpiTotalOrders').textContent = total;
    document.getElementById('kpiSuccessfulOrders').textContent = ok;
    document.getElementById('kpiTotalPickups').textContent = stats.pickups.total;
    document.getElementById('kpiCompletedPickups').textContent = stats.pickups.completed;
    document.getElementById('kpiTotalShop').textContent = stats.shopOrders.total;
    document.getElementById('kpiDeliveredShop').textContent = stats.shopOrders.delivered;

    const bal = stats.financial.currentBalance || 0;
    const balEl = document.getElementById('kpiBalance');
    balEl.textContent = formatCurrency(bal);
    balEl.className = 'bd-kpi-value ' + (bal >= 0 ? 'text-success' : 'text-danger');

    document.getElementById('kpiPendingReleases').textContent =
      stats.financial.pendingReleases ?? 0;

    const donut = document.getElementById('kpiDonut');
    donut.style.setProperty('--p', Math.min(100, Math.max(0, rate)).toFixed(2));
    document.getElementById('kpiDonutLabel').textContent = `${rate.toFixed(1)}%`;
  }

  /** Matches keys from views/business/settings.ejs */
  const SOCIAL_CHANNEL_DEFS = [
    { key: 'instagram', label: 'Instagram', icon: 'ri-instagram-line' },
    { key: 'tiktok', label: 'TikTok', icon: 'ri-tiktok-line' },
    { key: 'woocommerce', label: 'WooCommerce', icon: 'ri-store-2-line' },
    { key: 'customWebsite', label: 'Website', icon: 'ri-global-line' },
    { key: 'facebookShop', label: 'Facebook Shop', icon: 'ri-facebook-circle-line' },
    { key: 'facebookMessenger', label: 'Facebook / Messenger', icon: 'ri-messenger-line' },
    { key: 'shopify', label: 'Shopify', icon: 'ri-shopping-cart-line' },
  ];

  function socialLinkHost(url) {
    try {
      const u = new URL(String(url).trim());
      return u.hostname.replace(/^www\./, '');
    } catch {
      return String(url).slice(0, 48);
    }
  }

  function renderSocialChannels(business) {
    const mount = document.getElementById('socialLinksMount');
    if (!mount) return;
    const sl = business.brandInfo?.socialLinks;
    if (!sl || typeof sl !== 'object') {
      mount.innerHTML = '<p class="text-muted small mb-0">No channels linked.</p>';
      return;
    }
    const used = new Set();
    const items = [];
    for (const def of SOCIAL_CHANNEL_DEFS) {
      const raw = sl[def.key];
      if (!raw || !String(raw).trim()) continue;
      used.add(def.key);
      items.push({ ...def, href: String(raw).trim() });
    }
    for (const key of Object.keys(sl)) {
      if (used.has(key)) continue;
      const raw = sl[key];
      if (!raw || !String(raw).trim()) continue;
      const label = key
        .replace(/([A-Z])/g, ' $1')
        .replace(/^./, (s) => s.toUpperCase())
        .trim();
      items.push({ key, label, icon: 'ri-link', href: String(raw).trim() });
    }
    if (!items.length) {
      mount.innerHTML = '<p class="text-muted small mb-0">No channels linked.</p>';
      return;
    }
    mount.innerHTML = `<div class="bd-social-grid">${items
      .map(
        (it) => `
      <a class="bd-social-link" href="${escapeAttr(it.href)}" target="_blank" rel="noopener noreferrer">
        <i class="${escapeHtml(it.icon)}"></i>
        <span>
          <span class="bd-social-label">${escapeHtml(it.label)}</span>
          <span class="bd-social-host">${escapeHtml(socialLinkHost(it.href))}</span>
        </span>
        <i class="ri-external-link-line ms-auto text-muted flex-shrink-0"></i>
      </a>`
      )
      .join('')}</div>`;
  }

  function buildAddressSearchQuery(addr) {
    return [
      addr.adressDetails || addr.addressDetails,
      addr.zone,
      addr.city || addr.government,
      addr.country,
    ]
      .filter((p) => p && String(p).trim())
      .join(', ');
  }

  function getCoordLatLng(addr) {
    const c = addr.coordinates;
    if (!c) return { lat: null, lng: null };
    const lat = c.lat ?? c.latitude;
    const lng = c.lng ?? c.longitude;
    if (lat == null || lng == null) return { lat: null, lng: null };
    const la = Number(lat);
    const ln = Number(lng);
    if (Number.isNaN(la) || Number.isNaN(ln)) return { lat: null, lng: null };
    return { lat: la, lng: ln };
  }

  function renderAddressRows(addr) {
    const cell = (val) => (val != null && String(val).trim() ? String(val) : '—');
    const row = (label, val) =>
      `<div class="bd-row"><span class="bd-row-label">${escapeHtml(label)}</span><span class="bd-row-value">${escapeHtml(
        cell(val)
      )}</span></div>`;
    return `
      ${row('Country', addr.country)}
      ${row('City / governorate', addr.city || addr.government)}
      ${row('Zone', addr.zone)}
      ${row('Address details', addr.adressDetails || addr.addressDetails)}
      ${row('Landmark', addr.nearbyLandmark)}
      ${row('Pickup phone', addr.pickupPhone)}
      ${row('Other phone', addr.otherPickupPhone)}
    `;
  }

  function renderPickupAddresses(business) {
    const mount = document.getElementById('pickupAddressesMount');
    if (!mount) return;
    let list = [];
    if (business.pickUpAddresses && business.pickUpAddresses.length) {
      list = [...business.pickUpAddresses].sort((a, b) => {
        if (a.isDefault && !b.isDefault) return -1;
        if (!a.isDefault && b.isDefault) return 1;
        return 0;
      });
    } else if (business.pickUpAdress && typeof business.pickUpAdress === 'object') {
      const legacy = business.pickUpAdress;
      const hasAny = ['country', 'city', 'zone', 'adressDetails', 'addressDetails', 'pickupPhone', 'nearbyLandmark'].some(
        (k) => legacy[k]
      );
      if (hasAny) {
        list = [{ ...legacy, addressName: 'Main address', isDefault: true, addressId: 'legacy' }];
      }
    }

    if (!list.length) {
      mount.innerHTML = '<p class="text-muted small mb-0">No pickup addresses on file.</p>';
      return;
    }

    mount.innerHTML = `<div class="bd-pickup-stack">${list
      .map((addr, idx) => {
        const title = addr.addressName || `Address ${idx + 1}`;
        const defaultBadge = addr.isDefault
          ? '<span class="badge" style="background:rgba(243,151,32,0.22);color:#7a4a0c">Default pickup</span>'
          : '';
        const idLine =
          addr.addressId && addr.addressId !== 'legacy'
            ? `<div class="text-muted small font-monospace mt-1">${escapeHtml(addr.addressId)}</div>`
            : '';
        const { lat, lng } = getCoordLatLng(addr);
        let mapBlock = '';
        if (lat != null && lng != null) {
          const d = 0.012;
          const bbox = `${lng - d},${lat - d},${lng + d},${lat + d}`;
          const osmLarge = `https://www.openstreetmap.org/?mlat=${lat}&mlon=${lng}#map=16/${lat}/${lng}`;
          mapBlock = `
        <div class="bd-map-wrap rounded overflow-hidden border mt-2">
          <iframe title="Map: ${escapeAttr(title)}" width="100%" height="240" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
            src="https://www.openstreetmap.org/export/embed.html?bbox=${encodeURIComponent(bbox)}&layer=mapnik&marker=${encodeURIComponent(`${lat},${lng}`)}"></iframe>
        </div>
        <div class="bd-map-actions">
          <a class="btn btn-sm btn-outline-secondary" href="${escapeAttr(osmLarge)}" target="_blank" rel="noopener">Larger map (OpenStreetMap)</a>
        </div>`;
        } else {
          const q = buildAddressSearchQuery(addr);
          const gMaps = q ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(q)}` : '';
          const osmSearch = q ? `https://www.openstreetmap.org/search?query=${encodeURIComponent(q)}` : '';
          mapBlock = `
        <div class="bd-map-fallback rounded border mt-2 p-3 bg-white text-center">
          <p class="small text-muted mb-2">No coordinates on file — search by address.</p>
          <div class="bd-map-actions justify-content-center">
            ${gMaps ? `<a class="btn btn-sm btn-outline-secondary" href="${escapeAttr(gMaps)}" target="_blank" rel="noopener"><i class="ri-map-pin-line me-1"></i>Google Maps</a>` : ''}
            ${osmSearch ? `<a class="btn btn-sm btn-outline-secondary" href="${escapeAttr(osmSearch)}" target="_blank" rel="noopener"><i class="ri-map-2-line me-1"></i>OpenStreetMap</a>` : ''}
          </div>
        </div>`;
        }

        const mapLinkHtml =
          addr.pickUpPointInMaps && String(addr.pickUpPointInMaps).trim()
            ? `<div class="mt-2 small"><a href="${escapeAttr(String(addr.pickUpPointInMaps).trim())}" target="_blank" rel="noopener" class="link-secondary"><i class="ri-links-line me-1"></i>Map link from business</a></div>`
            : '';

        return `
      <div class="bd-pickup-card">
        <div class="bd-pickup-card-header">
          <div>
            <div class="bd-pickup-card-title">${escapeHtml(title)}</div>
            ${idLine}
          </div>
          <div>${defaultBadge}</div>
        </div>
        ${renderAddressRows(addr)}
        ${mapBlock}
        ${mapLinkHtml}
      </div>`;
      })
      .join('')}</div>`;
  }

  function renderAnalytics(stats, revenueBreakdown) {
    const o = stats.orders;
    const parts = [
      { key: 'new', label: 'New', val: o.new || 0, color: '#ffb45c' },
      { key: 'processing', label: 'Processing', val: o.processing || 0, color: '#f7b84b' },
      { key: 'successful', label: 'Successful', val: o.successful || 0, color: '#e8891a' },
      { key: 'unsuccessful', label: 'Unsuccessful', val: o.unsuccessful || 0, color: '#f06548' },
    ];
    const sum = parts.reduce((a, p) => a + p.val, 0) || 1;
    const bar = document.getElementById('analyticsOrderBar');
    bar.innerHTML = parts
      .map((p) => {
        const w = ((p.val / sum) * 100).toFixed(2);
        return `<div class="bd-stack-seg" style="width:${w}%;background:${p.color}" title="${escapeHtml(
          p.label
        )}: ${p.val}">${p.val > 0 && w > 8 ? p.val : ''}</div>`;
      })
      .join('');

    document.getElementById('analyticsOrderLegend').innerHTML = parts
      .map(
        (p) => `<div class="col-6 col-md-3"><span class="d-inline-block rounded-circle me-1" style="width:8px;height:8px;background:${p.color}"></span>${escapeHtml(
          p.label
        )}: <strong>${p.val}</strong></div>`
      )
      .join('');

    document.getElementById('anPickTotal').textContent = stats.pickups.total;
    document.getElementById('anPickDone').textContent = stats.pickups.completed;
    document.getElementById('anPickPending').textContent = stats.pickups.pending;

    const inc = revenueBreakdown.income || 0;
    const exp = revenueBreakdown.expenses || 0;
    document.getElementById('anRevIncome').textContent = formatCurrency(inc);
    document.getElementById('anRevExpense').textContent = formatCurrency(exp);
    const t = inc + exp || 1;
    const iw = ((inc / t) * 100).toFixed(1);
    const ew = ((exp / t) * 100).toFixed(1);
    document.getElementById(
      'anRevBar'
    ).innerHTML = `<div style="width:${iw}%;background:#f39720"></div><div style="width:${ew}%;background:#f06548"></div>`;
  }

  function renderOverview(business) {
    document.getElementById('brandName').textContent = business.brandInfo?.brandName || '—';
    document.getElementById('industryName').textContent = business.brandInfo?.industry || '—';
    document.getElementById('monthlyOrders').textContent =
      business.brandInfo?.monthlyOrders != null ? String(business.brandInfo.monthlyOrders) : '—';
    const sp = business.brandInfo?.sellingPoints;
    document.getElementById('sellingPoints').textContent =
      Array.isArray(sp) && sp.length ? sp.join(', ') : '—';

    renderSocialChannels(business);
    renderPickupAddresses(business);

    const paymentContainer = document.getElementById('paymentMethodContent');
    if (business.paymentMethod?.paymentChoice) {
      const method = business.paymentMethod.paymentChoice;
      const details = business.paymentMethod.details || {};
      let detailsHTML = '';
      if (method === 'instaPay') {
        detailsHTML = `<p class="mb-0 small text-muted">IPA / phone: ${escapeHtml(details.IPAorPhoneNumber || '—')}</p>`;
      } else if (method === 'mobileWallet') {
        detailsHTML = `<p class="mb-0 small text-muted">Wallet: ${escapeHtml(details.mobileWalletNumber || '—')}</p>`;
      } else if (method === 'bankTransfer') {
        const iban = details.IBAN || details.iban;
        const acct = details.accountNumber || details.accountNo;
        const bankLines = [
          `Bank: ${escapeHtml(details.bankName || '—')}`,
          iban ? `IBAN: ${escapeHtml(iban)}` : null,
          acct ? `Account no.: ${escapeHtml(acct)}` : null,
          `Account name: ${escapeHtml(details.accountName || '—')}`,
        ]
          .filter(Boolean)
          .join('<br>');
        detailsHTML = `<p class="mb-0 small text-muted">${bankLines}</p>`;
      }
      paymentContainer.innerHTML = `<div class="p-2 rounded bg-light"><div class="fw-semibold text-capitalize">${escapeHtml(
        method
      )}</div>${detailsHTML}</div>`;
    } else {
      paymentContainer.innerHTML = '<p class="text-muted mb-0 small">No payment method configured</p>';
    }

    const brandTypeContainer = document.getElementById('brandTypeContent');
    if (business.brandType?.brandChoice) {
      const type = business.brandType.brandChoice;
      const details = business.brandType.brandDetails || {};
      let detailsHTML = '';
      if (type === 'personal') {
        detailsHTML = `<p class="mb-0 small text-muted">National ID: ${escapeHtml(details.nationalId || '—')}</p>`;
      } else if (type === 'company') {
        detailsHTML = `<p class="mb-0 small text-muted">Tax number: ${escapeHtml(details.taxNumber || '—')}</p>`;
      }
      brandTypeContainer.innerHTML = `<div class="p-2 rounded bg-light"><div class="fw-semibold text-capitalize">${escapeHtml(
        type
      )}</div>${detailsHTML}</div>`;
    } else {
      brandTypeContainer.innerHTML = '<p class="text-muted mb-0 small">No brand type configured</p>';
    }
  }

  function renderDocuments(business) {
    const container = document.getElementById('documentsContent');
    const photos = business.brandType?.brandDetails?.photos || [];
    if (!photos.length) {
      container.innerHTML = '<div class="col-12"><p class="text-muted mb-0">No documents uploaded</p></div>';
      return;
    }
    const label = business.brandType?.brandChoice === 'personal' ? 'National ID' : 'Tax document';
    container.innerHTML = photos
      .map((photo, index) => {
        const safe = JSON.stringify(photo);
        return `
      <div class="col-md-4 col-sm-6">
        <div class="bd-doc-thumb" role="button" tabindex="0" data-doc-url=${safe}>
          <img src="${escapeHtml(photo)}" alt="">
          <div class="small p-2 bg-light">${escapeHtml(label)} ${index + 1}</div>
        </div>
      </div>`;
      })
      .join('');
    container.querySelectorAll('.bd-doc-thumb[data-doc-url]').forEach((el) => {
      const open = () => {
        try {
          const u = JSON.parse(el.getAttribute('data-doc-url'));
          if (u) window.open(u, '_blank');
        } catch (_) {}
      };
      el.addEventListener('click', open);
      el.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') open();
      });
    });
  }

