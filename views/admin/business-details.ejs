  async function loadBusinessDetails() {
    try {
      const response = await fetch(`/admin/get-business-details/${businessId}`);
      const data = await response.json();
      if (!data.business) {
        Swal.fire({ icon: 'error', title: 'Not found', text: data.error || 'Business not found', confirmButtonColor: '#F39720' });
        return;
      }
      renderBusinessProfile(data.business);
      renderStatistics(data.stats);
      renderOverview(data.business);
      renderDocuments(data.business);
      renderOrders(data.recentOrders || []);
      renderPickups(data.recentPickups || []);
      renderShopOrders(data.recentShopOrders || []);
      renderFinancial(data);
      renderAnalytics(data.stats, data.revenueBreakdown || { income: 0, expenses: 0 });
    } catch (e) {
      console.error(e);
      Swal.fire({ icon: 'error', title: 'Error', text: 'Failed to load business details', confirmButtonColor: '#F39720' });
    }
  }

  document.addEventListener('DOMContentLoaded', loadBusinessDetails);
</script>
