  function renderBusinessProfile(business) {
    const avatar = document.getElementById('profileAvatar');
    const display = business.brandInfo?.brandName || business.name || '—';
    const letter = escapeHtml(display.charAt(0).toUpperCase());
    const url = business.profileImage && String(business.profileImage).trim();
    if (!url) {
      avatar.innerHTML = `<span class="bd-hero-letter">${letter}</span>`;
    } else {
      avatar.innerHTML = `<span class="bd-hero-letter">${letter}</span><img class="bd-hero-img" src="${escapeHtml(
        url
      )}" alt="" loading="lazy" onerror="this.style.display='none'">`;
    }
    document.getElementById('businessName').textContent = display;
    document.getElementById('businessIndustry').textContent =
      business.brandInfo?.industry || 'Industry not specified';
    document.getElementById('businessEmail').textContent = business.email || '—';
    document.getElementById('businessPhone').textContent = business.phoneNumber || '—';
    document.getElementById('businessJoined').textContent = formatDate(business.createdAt);

    const badge = document.getElementById('verificationBadge');
    if (business.isVerified) {
      badge.style.display = 'inline-block';
      badge.className = 'badge bg-success';
      badge.textContent = 'Verified';
    } else {
      badge.style.display = 'inline-block';
      badge.className = 'badge bg-warning text-dark';
      badge.textContent = 'Pending verification';
