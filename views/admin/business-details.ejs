<%- contentFor('HeaderCss') %>
<link href="/assets/libs/sweetalert2/sweetalert2.min.css" rel="stylesheet" type="text/css" />
<style>
  .bd-page {
    --bd-brand: #f39720;
    --bd-brand-dark: #c97d12;
    --bd-brand-soft: rgba(243, 151, 32, 0.18);
  }
  .bd-hero {
    border-radius: 0.5rem;
    background: linear-gradient(135deg, #f39720 0%, #e8891a 45%, #c97d12 100%);
    color: #fff;
    padding: 1.75rem 1.5rem;
    margin-bottom: 1.25rem;
    box-shadow: 0 0.5rem 1.5rem rgba(243, 151, 32, 0.28);
  }
  .bd-hero-avatar {
    width: 88px;
    height: 88px;
    border-radius: 16px;
    border: 3px solid rgba(255, 255, 255, 0.45);
    background: rgba(255, 255, 255, 0.2);
    font-size: 2.25rem;
    font-weight: 700;
    overflow: hidden;
    flex-shrink: 0;
    position: relative;
  }
  .bd-hero-avatar .bd-hero-letter {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    color: #fff;
  }
  .bd-hero-avatar .bd-hero-img {
    position: absolute;
    inset: 0;
    z-index: 2;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 12px;
  }
  .bd-kpi-card {
    border: 1px solid var(--vz-border-color, rgba(0, 0, 0, 0.08));
    border-radius: 0.5rem;
    padding: 1rem 1.1rem;
    height: 100%;
    background: #fff;
    transition: box-shadow 0.2s ease;
  }
  .bd-kpi-card:hover {
    box-shadow: 0 0.35rem 1rem rgba(243, 151, 32, 0.12);
  }
  .bd-kpi-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #878a99;
    font-weight: 600;
  }
  .bd-kpi-value {
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.2;
  }
  .bd-donut-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .bd-donut {
    --p: 0;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: conic-gradient(#f39720 calc(var(--p) * 1%), #e9ecef 0);
    position: relative;
    flex-shrink: 0;
  }
  .bd-donut-hole {
    position: absolute;
    inset: 9px;
    border-radius: 50%;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    font-weight: 700;
    color: #212529;
  }
  .bd-nav-pills {
    background: #f3f6f9;
    border-radius: 0.5rem;
    padding: 0.25rem;
    flex-wrap: wrap;
    gap: 0.15rem;
  }
  .bd-nav-pills .nav-link {
    border-radius: 0.35rem;
    color: #6c757d;
    font-weight: 600;
    font-size: 0.8125rem;
    padding: 0.55rem 0.85rem;
    white-space: nowrap;
  }
  .bd-nav-pills .nav-link.active {
    background: var(--bd-brand);
    color: #fff;
  }
  .bd-info-card {
    border: 1px solid var(--vz-border-color, rgba(0, 0, 0, 0.08));
    border-radius: 0.5rem;
    padding: 1.25rem;
    height: 100%;
    background: #fff;
  }
  .bd-info-title {
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: #212529;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .bd-info-title i {
    color: var(--bd-brand-dark);
  }
  .bd-row {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.55rem 0;
    border-bottom: 1px solid #f0f0f0;
    font-size: 0.875rem;
  }
  .bd-row:last-child {
    border-bottom: none;
  }
  .bd-row-label {
    color: #878a99;
    flex-shrink: 0;
  }
  .bd-row-value {
    font-weight: 600;
    text-align: right;
    word-break: break-word;
  }
  .bd-stack-bar {
    display: flex;
    height: 28px;
    border-radius: 6px;
    overflow: hidden;
    font-size: 0.7rem;
    font-weight: 700;
    color: #fff;
  }
  .bd-stack-seg {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 0;
  }
  .bd-rev-bar {
    height: 12px;
    border-radius: 6px;
    overflow: hidden;
    display: flex;
    margin-top: 0.5rem;
  }
  .bd-doc-thumb {
    border-radius: 0.5rem;
    overflow: hidden;
    border: 1px solid #e9ecef;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .bd-doc-thumb:hover {
    border-color: var(--bd-brand);
  }
  .bd-page .bd-info-card .btn-soft-primary {
    color: var(--bd-brand-dark) !important;
    background: var(--bd-brand-soft) !important;
    border-color: rgba(243, 151, 32, 0.4) !important;
  }
  .bd-page #kpiTotalOrders.text-primary {
    color: var(--bd-brand-dark) !important;
  }
  .bd-doc-thumb img {
    width: 100%;
    height: 160px;
    object-fit: cover;
  }
  .admin-table-scroll {
    max-height: 60vh;
  }
  .bd-social-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.65rem;
  }
  .bd-social-link {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.65rem 0.75rem;
    border: 1px solid rgba(243, 151, 32, 0.35);
    border-radius: 0.5rem;
    background: rgba(243, 151, 32, 0.06);
    text-decoration: none;
    color: #212529;
    transition: background 0.15s ease, border-color 0.15s ease;
  }
  .bd-social-link:hover {
    background: rgba(243, 151, 32, 0.14);
    border-color: rgba(243, 151, 32, 0.55);
    color: #212529;
  }
  .bd-social-link i:first-child {
    font-size: 1.35rem;
    color: var(--bd-brand-dark);
    flex-shrink: 0;
  }
  .bd-social-link span {
    min-width: 0;
    font-size: 0.8125rem;
  }
  .bd-social-link .bd-social-label {
    font-weight: 700;
    display: block;
    color: var(--bd-brand-dark);
  }
  .bd-social-link .bd-social-host {
    display: block;
    color: #878a99;
    font-weight: 500;
    text-overflow: ellipsis;
    overflow: hidden;
    white-space: nowrap;
  }
  .bd-pickup-stack {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .bd-pickup-card {
    border: 1px solid var(--vz-border-color, rgba(0, 0, 0, 0.08));
    border-radius: 0.5rem;
    padding: 1rem 1.1rem;
    background: #fafbfc;
  }
  .bd-pickup-card-header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.65rem;
    border-bottom: 1px solid #e9ecef;
  }
  .bd-pickup-card-title {
    font-weight: 700;
    font-size: 0.95rem;
    color: #212529;
  }
  .bd-map-wrap iframe {
    display: block;
  }
  .bd-map-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }
</style>

<%- contentFor('body') %>
